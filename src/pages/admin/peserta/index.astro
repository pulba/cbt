---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { userGroups } from "../../../db/schema";
import { eq } from "drizzle-orm";

const allGroups = await db.select().from(userGroups);
---

<AdminLayout title="Data Peserta">
    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <h2 class="text-xl font-bold text-surface-800">
                Manajemen Peserta
            </h2>
            <p class="text-sm text-surface-500 mt-1">
                Kelola data siswa (peserta ujian) dan grup/kelas.
            </p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a
                href="/admin/peserta/kartu"
                class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm"
            >
                <i class="icon-printer w-4 h-4 inline-block mr-1"></i> Cetak Kartu
            </a>
            <a
                href="/admin/peserta/grup"
                class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm"
            >
                <i class="icon-users w-4 h-4 inline-block mr-1"></i> Data Grup
            </a>
            <a
                href="/admin/peserta/import"
                class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm"
            >
                <i class="icon-upload w-4 h-4 inline-block mr-1"></i> Import Excel
            </a>
            <a
                href="/admin/peserta/tambah"
                class="px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-primary-500/30"
            >
                <i class="icon-plus w-4 h-4 inline-block mr-1"></i> Tambah Peserta
            </a>
        </div>
    </div>

    <!-- Stats & Filters -->
    <div
        class="bg-white p-4 rounded-xl border border-surface-200 shadow-sm mb-6 flex flex-wrap gap-4 items-center justify-between"
    >
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <div class="flex items-center gap-2">
                <input
                    type="checkbox"
                    id="check-all"
                    class="w-4 h-4 text-primary-600 border-surface-300 rounded focus:ring-primary-500"
                />
                <label for="check-all" class="text-sm text-surface-600"
                    >Pilih Semua</label
                >
            </div>
            <div class="w-px h-6 bg-surface-200 mx-1"></div>
            <button
                id="btn-hapus-massal"
                class="px-3 py-1.5 bg-danger/10 text-danger hover:bg-danger/20 rounded-md text-sm font-medium transition cursor-not-allowed opacity-50 flex items-center gap-1"
                disabled
            >
                <i class="icon-trash-2 w-3.5 h-3.5"></i> Hapus Terpilih
            </button>
        </div>
        <div class="flex flex-wrap items-center gap-3 w-full sm:w-auto">
            <select
                id="filter-grup"
                class="px-3 py-2 w-full sm:w-auto bg-surface-50 border border-surface-200 rounded-lg text-sm text-surface-700 focus:ring-primary-500 focus:border-primary-500"
            >
                <option value="">Semua Grup / Kelas</option>
                {
                    allGroups.map((group) => (
                        <option value={group.id}>{group.name}</option>
                    ))
                }
            </select>
            <div class="relative w-full sm:w-64">
                <i
                    class="icon-search absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400"
                ></i>
                <input
                    type="text"
                    id="search-input"
                    placeholder="Cari nama atau username..."
                    class="w-full pl-9 pr-4 py-2 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500"
                />
            </div>
        </div>
    </div>

    <!-- Data Table Container -->
    <div
        class="bg-white rounded-xl border border-surface-200 shadow-sm overflow-hidden"
        id="peserta-container"
    >
        <table class="w-full text-left text-sm text-surface-600">
            <thead
                class="bg-surface-50 border-b border-surface-200 text-surface-700 font-semibold"
            >
                <tr>
                    <th class="px-5 py-3 w-10 text-center">#</th>
                    <th class="px-5 py-3 w-12 text-center">No</th>
                    <th class="px-5 py-3">Username / No. Peserta</th>
                    <th class="px-5 py-3">Password</th>
                    <th class="px-5 py-3">Nama Lengkap</th>
                    <th class="px-5 py-3">Grup / Kelas</th>
                    <th class="px-5 py-3 text-center">Status</th>
                    <th class="px-5 py-3 w-32 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody id="peserta-table-body" class="divide-y divide-surface-100">
                <tr>
                    <td
                        colspan="8"
                        class="px-5 py-8 text-center text-surface-400"
                    >
                        <i class="icon-loader w-6 h-6 animate-spin mx-auto mb-2"
                        ></i> Memuat data peserta...
                    </td>
                </tr>
            </tbody>
        </table>

        <!-- Pagination Placeholder -->
        <div
            class="p-4 border-t border-surface-200 flex justify-between items-center bg-surface-50"
        >
            <span class="text-xs text-surface-500" id="pagination-info"
                >Menampilkan 0 dari total peserta</span
            >
            <div class="flex gap-1" id="pagination-controls">
                <button
                    id="btn-prev"
                    disabled
                    title="Previous"
                    class="w-8 h-8 rounded-md flex items-center justify-center border border-surface-200 bg-white text-surface-400"
                >
                    <i class="icon-chevron-left w-4 h-4"></i>
                </button>
                <button
                    id="btn-next"
                    disabled
                    title="Next"
                    class="w-8 h-8 rounded-md flex items-center justify-center border border-surface-200 bg-white text-surface-400"
                >
                    <i class="icon-chevron-right w-4 h-4"></i>
                </button>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    let currentPage = 1;
    const limit = 20;

    async function loadPeserta(page = 1) {
        const tbody = document.getElementById("peserta-table-body");
        const paginationInfo = document.getElementById("pagination-info");
        const btnPrev = document.getElementById(
            "btn-prev",
        ) as HTMLButtonElement;
        const btnNext = document.getElementById(
            "btn-next",
        ) as HTMLButtonElement;

        const search =
            (document.getElementById("search-input") as HTMLInputElement)
                ?.value || "";
        const groupId =
            (document.getElementById("filter-grup") as HTMLSelectElement)
                ?.value || "";

        if (!tbody) return;

        try {
            const res = await fetch(
                `/api/peserta?page=${page}&limit=${limit}&search=${encodeURIComponent(search)}&groupId=${encodeURIComponent(groupId)}`,
            );
            const json = await res.json();

            if (json.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="px-5 py-8 text-center text-surface-500">Belum ada peserta yang ditemukan.</td></tr>`;
                if (paginationInfo)
                    paginationInfo.textContent = "Menampilkan 0 peserta";
                btnPrev.disabled = true;
                btnNext.disabled = true;
                return;
            }

            let html = "";
            json.data.forEach((peserta: any, idx: number) => {
                html += `
                    <tr class="hover:bg-surface-50/50 transition-colors">
                        <td class="px-5 py-4 text-center">
                            <input type="checkbox" value="${peserta.id}" class="row-checkbox w-4 h-4 text-primary-600 border-surface-300 rounded focus:ring-primary-500">
                        </td>
                        <td class="px-5 py-4 text-center text-surface-400">${idx + 1 + (page - 1) * limit}</td>
                        <td class="px-5 py-4 font-medium text-surface-800">${peserta.username}</td>
                        <td class="px-5 py-4 font-mono font-semibold tracking-wider text-surface-700">${peserta.password}</td>
                        <td class="px-5 py-4">${peserta.firstName}</td>
                        <td class="px-5 py-4">
                            <span class="px-2 py-1 bg-surface-100 text-surface-700 rounded-md text-xs font-medium">
                                ${peserta.groupName || "-"}
                            </span>
                        </td>
                        <td class="px-5 py-4 text-center">
                            ${peserta.isLogin 
                                ? `<span class="inline-flex items-center gap-1.5 px-2 py-1 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-full text-[10px] font-bold uppercase tracking-wider animate-pulse">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Sedang Aktif
                                   </span>`
                                : `<span class="text-[10px] text-surface-400 font-medium uppercase tracking-widest italic opacity-50">Offline</span>`
                            }
                        </td>
                        <td class="px-5 py-4 text-center">
                            <div class="flex items-center justify-center gap-2">
                                ${peserta.isLogin ? `
                                    <button title="Reset Login (Siswa tidak bisa login?)" class="w-8 h-8 rounded-lg text-amber-600 hover:bg-amber-50 transition flex items-center justify-center border border-amber-100 shadow-sm" onclick="resetPeserta(${peserta.id}, '${peserta.firstName}')">
                                        <i class="icon-key w-4 h-4"></i>
                                    </button>
                                ` : ''}
                                <a href="/admin/peserta/edit/${peserta.id}" title="Edit Peserta" class="w-8 h-8 rounded-lg text-primary-600 hover:bg-primary-50 transition flex items-center justify-center">
                                    <i class="icon-edit-2 w-4 h-4"></i>
                                </a>
                                <button title="Hapus Peserta" class="w-8 h-8 rounded-lg text-danger hover:bg-danger/10 transition flex items-center justify-center" onclick="deletePeserta(${peserta.id}, '${peserta.username}')">
                                    <i class="icon-trash-2 w-4 h-4"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;

            // Update Checkbox Listeners
            updateCheckboxListeners();

            // Pagination Info
            if (paginationInfo) {
                const start = (page - 1) * limit + 1;
                const end = Math.min(page * limit, json.total);
                paginationInfo.textContent = `Menampilkan ${start}-${end} dari ${json.total} peserta`;
            }

            // Pagination Controls
            btnPrev.disabled = page <= 1;
            btnNext.disabled = page >= json.totalPages;

            // Set handlers for pagination buttons
            btnPrev.onclick = () => {
                currentPage = page - 1;
                loadPeserta(currentPage);
            };
            btnNext.onclick = () => {
                currentPage = page + 1;
                loadPeserta(currentPage);
            };
        } catch (e) {
            tbody.innerHTML = `<tr><td colspan="8" class="px-5 py-8 text-center text-danger">Gagal memuat data. Silakan refresh halaman.</td></tr>`;
        }
    }

    (window as any).deletePeserta = async (id: number, username: string) => {
        if (
            !confirm(
                `Apakah Anda yakin ingin menghapus peserta dengan username "${username}"?`,
            )
        )
            return;

        try {
            const res = await fetch("/api/peserta", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ ids: [id] }),
            });
            const data = await res.json();

            if (!data.success) {
                alert("Gagal menghapus: " + data.error);
                return;
            }
            loadPeserta(currentPage);
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };
    
    (window as any).resetPeserta = async (id: number, name: string) => {
        if (!confirm(`Reset status login atas nama ${name}? Siswa tersebut akan bisa login kembali.`)) return;

        try {
            const res = await fetch("/api/peserta/reset", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id }),
            });

            const data = await res.json();
            if (data.success) {
                alert(`Reset login ${name} berhasil!`);
                loadPeserta(currentPage);
            } else {
                alert("Gagal mereset: " + data.error);
            }
        } catch (err) {
            alert("Kesalahan jaringan.");
        }
    };

    // Events
    document.getElementById("search-input")?.addEventListener("input", () => {
        currentPage = 1;
        loadPeserta(1);
    });

    document.getElementById("filter-grup")?.addEventListener("change", () => {
        currentPage = 1;
        loadPeserta(1);
    });

    // Initial load
    loadPeserta(1);

    // Mass Delete Logic
    const checkAll = document.getElementById("check-all") as HTMLInputElement;
    const btnHapusMassal = document.getElementById(
        "btn-hapus-massal",
    ) as HTMLButtonElement;

    checkAll?.addEventListener("change", (e) => {
        const isChecked = (e.target as HTMLInputElement).checked;
        const checkboxes = document.querySelectorAll(
            ".row-checkbox",
        ) as NodeListOf<HTMLInputElement>;

        checkboxes.forEach((cb) => {
            cb.checked = isChecked;
        });
        updateDeleteButtonState();
    });

    function updateCheckboxListeners() {
        const checkboxes = document.querySelectorAll(
            ".row-checkbox",
        ) as NodeListOf<HTMLInputElement>;
        checkboxes.forEach((cb) => {
            cb.addEventListener("change", () => {
                const allChecked = Array.from(checkboxes).every(
                    (c) => c.checked,
                );
                if (checkAll) checkAll.checked = allChecked;
                updateDeleteButtonState();
            });
        });
    }

    function updateDeleteButtonState() {
        const checkboxes = document.querySelectorAll(
            ".row-checkbox:checked",
        ) as NodeListOf<HTMLInputElement>;
        if (checkboxes.length > 0) {
            btnHapusMassal.disabled = false;
            btnHapusMassal.classList.remove("cursor-not-allowed", "opacity-50");
        } else {
            btnHapusMassal.disabled = true;
            btnHapusMassal.classList.add("cursor-not-allowed", "opacity-50");
            if (checkAll) checkAll.checked = false;
        }
    }

    btnHapusMassal?.addEventListener("click", async () => {
        const checkboxes = document.querySelectorAll(
            ".row-checkbox:checked",
        ) as NodeListOf<HTMLInputElement>;
        const ids = Array.from(checkboxes).map((cb) => parseInt(cb.value));

        if (ids.length === 0) return;

        if (
            !confirm(
                `Apakah Anda yakin ingin menghapus ${ids.length} peserta yang dipilih?`,
            )
        )
            return;

        const originalHtml = btnHapusMassal.innerHTML;
        btnHapusMassal.innerHTML = `<i class="icon-loader w-3.5 h-3.5 animate-spin"></i> Menghapus...`;
        btnHapusMassal.disabled = true;

        try {
            const res = await fetch("/api/peserta", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ ids }),
            });
            const data = await res.json();

            if (!data.success) {
                alert("Gagal menghapus massal: " + data.error);
                btnHapusMassal.innerHTML = originalHtml;
                updateDeleteButtonState();
                return;
            }

            // reset all UI
            if (checkAll) checkAll.checked = false;
            btnHapusMassal.innerHTML = originalHtml;
            updateDeleteButtonState();

            loadPeserta(currentPage);
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
            btnHapusMassal.innerHTML = originalHtml;
            updateDeleteButtonState();
        }
    });
</script>
