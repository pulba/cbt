---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Import Peserta">
    <div class="mb-6">
        <nav class="flex text-sm text-surface-500 mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li class="inline-flex items-center">
                    <a
                        href="/admin/peserta"
                        class="hover:text-primary-600 transition-colors"
                        >Peserta</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                        <span class="text-surface-700 font-medium"
                            >Import Excel</span
                        >
                    </div>
                </li>
            </ol>
        </nav>
        <h2 class="text-xl font-bold text-surface-800">Import Data Peserta</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Panel Form Import -->
        <div
            class="bg-white p-6 rounded-xl border border-surface-200 shadow-sm"
        >
            <h3
                class="font-bold text-surface-800 mb-4 border-b border-surface-100 pb-2"
            >
                Upload File Excel
            </h3>

            <form id="form-import" class="space-y-4">
                <div
                    class="border-2 border-dashed border-surface-300 rounded-lg p-8 text-center bg-surface-50 hover:bg-surface-100 transition relative"
                >
                    <input
                        type="file"
                        id="file"
                        name="file"
                        accept=".xls,.xlsx"
                        required
                        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
                    />
                    <div class="pointer-events-none">
                        <i
                            class="icon-upload-cloud w-10 h-10 text-primary-500 mx-auto mb-3"
                        ></i>
                        <p
                            class="font-medium text-surface-700 text-sm"
                            id="filename-display"
                        >
                            Pilih file Excel (.xls, .xlsx) atau seret ke sini
                        </p>
                        <p class="text-xs text-surface-500 mt-1">
                            Ukuran maksimal file: 5MB
                        </p>
                    </div>
                </div>

                <div class="pt-2">
                    <button
                        type="submit"
                        id="btn-submit"
                        class="w-full px-5 py-2.5 text-white bg-primary-600 hover:bg-primary-500 font-medium rounded-lg transition flex items-center justify-center uppercase tracking-wide text-xs shadow-soft-xl shadow-primary-500/30"
                    >
                        <i class="icon-play w-4 h-4 mr-2"></i> Mulai Proses Import
                    </button>
                    <a
                        href="/admin/peserta"
                        class="w-full px-5 py-2.5 mt-3 text-surface-600 bg-surface-100 hover:bg-surface-200 font-medium rounded-lg transition flex items-center justify-center uppercase tracking-wide text-xs text-center"
                    >
                        Batal & Kembali
                    </a>
                </div>
            </form>

            <div id="result-container" class="mt-4 hidden">
                <div id="result-alert" class="p-4 rounded-lg text-sm mb-3">
                </div>
                <div id="error-list-container" class="hidden">
                    <p class="text-xs font-bold text-surface-700 mb-1">
                        Log Peringatan / Error:
                    </p>
                    <ul
                        id="error-list"
                        class="text-[11px] text-danger bg-danger/5 border border-danger/10 p-3 rounded-md h-32 overflow-y-auto space-y-1 font-mono"
                    >
                    </ul>
                </div>
            </div>
        </div>

        <!-- Panel Petunjuk -->
        <div class="bg-surface-50 p-6 rounded-xl border border-surface-200">
            <h3
                class="font-bold text-surface-800 mb-4 border-b border-surface-200 pb-2"
            >
                Aturan & Petunjuk Import
            </h3>

            <ul class="text-sm text-surface-600 space-y-3 list-disc pl-5">
                <li>
                    Gunakan format Microsoft Excel dengan ekstensi <b>.xls</b> atau
                    <b>.xlsx</b>
                </li>
                <li>
                    Baris pertama (Row 1) pada sheet akan dianggap sebagai <b
                        >Header</b
                    > (Judul Kolom) dan akan <b>diabaikan</b> oleh sistem.
                </li>
                <li>Data baru akan mulai dibaca dari Baris kedua (Row 2).</li>
                <li>
                    <b>Grup/Kelas tujuan harus dibuat terlebih dahulu</b> di menu
                    <a
                        href="/admin/peserta/grup"
                        class="text-primary-600 underline">Grup & Kelas</a
                    >.
                </li>
                <li>
                    Pastikan tulisan nama grup di file Excel <b>sama persis</b> (tidak
                    case-sensitive) dengan yang ada di database.
                </li>
            </ul>

            <h4 class="font-bold text-surface-800 mt-6 mb-2 text-sm">
                Susunan Kolom Excel:
            </h4>
            <div
                class="overflow-x-auto rounded border border-surface-200 bg-white"
            >
                <table
                    class="w-full text-left text-xs text-surface-600 whitespace-nowrap"
                >
                    <thead
                        class="bg-surface-100 font-semibold text-surface-700"
                    >
                        <tr>
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Kolom A</td
                            >
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Kolom B</td
                            >
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Kolom C</td
                            >
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Kolom D</td
                            >
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Kolom E</td
                            >
                            <td class="px-3 py-2">Kolom F</td>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td
                                class="px-3 py-2 border-r border-surface-200 font-bold text-danger"
                                >Username *</td
                            >
                            <td
                                class="px-3 py-2 border-r border-surface-200 font-bold text-danger"
                                >Password *</td
                            >
                            <td
                                class="px-3 py-2 border-r border-surface-200 font-bold text-danger"
                                >Nama Lengkap *</td
                            >
                            <td class="px-3 py-2 border-r border-surface-200"
                                >Email</td
                            >
                            <td
                                class="px-3 py-2 border-r border-surface-200 font-bold text-danger"
                                >Nama Grup *</td
                            >
                            <td class="px-3 py-2">Catatan</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-surface-400 mt-2">
                * Tanda bintang berwarna merah menandakan kolom tersebut wajib
                diisi.
            </p>
        </div>
    </div>
</AdminLayout>

<script>
    const fileInput = document.getElementById("file") as HTMLInputElement;
    const filenameDisplay = document.getElementById("filename-display");
    const form = document.getElementById("form-import") as HTMLFormElement;
    const btnSubmit = document.getElementById(
        "btn-submit",
    ) as HTMLButtonElement;
    const resultContainer = document.getElementById("result-container");
    const resultAlert = document.getElementById("result-alert");
    const errorListContainer = document.getElementById("error-list-container");
    const errorList = document.getElementById("error-list");

    fileInput?.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file && filenameDisplay) {
            filenameDisplay.innerHTML = `<span class="text-primary-600 font-bold"><i class="icon-file-text w-4 h-4 inline-block mr-1"></i> ${file.name}</span>`;
        } else if (filenameDisplay) {
            filenameDisplay.textContent =
                "Pilih file Excel (.xls, .xlsx) atau seret ke sini";
        }
    });

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const file = fileInput.files?.[0];
        if (!file) return;

        const formData = new FormData();
        formData.append("file", file);

        const originalText = btnSubmit.innerHTML;
        btnSubmit.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Sedang Memproses...`;
        btnSubmit.disabled = true;

        if (resultContainer) resultContainer.classList.add("hidden");

        try {
            const res = await fetch("/api/peserta/import", {
                method: "POST",
                body: formData, // Tanpa header content-type agar browser yang set multipart form-data
            });
            const result = await res.json();

            if (resultContainer) resultContainer.classList.remove("hidden");

            if (!result.success) {
                if (resultAlert) {
                    resultAlert.className =
                        "p-4 rounded-lg text-sm mb-3 bg-danger/10 text-danger border border-danger/20";
                    resultAlert.innerHTML = `<b>Error:</b> ${result.error}`;
                }
                if (errorListContainer)
                    errorListContainer.classList.add("hidden");
            } else {
                if (resultAlert) {
                    resultAlert.className =
                        "p-4 rounded-lg text-sm mb-3 bg-success/10 text-success-700 border border-success/20";
                    resultAlert.innerHTML = `<b>Proses Selesai:</b> ${result.message}`;
                }

                if (
                    result.errors &&
                    result.errors.length > 0 &&
                    errorListContainer &&
                    errorList
                ) {
                    errorListContainer.classList.remove("hidden");
                    errorList.innerHTML = result.errors
                        .map((err: string) => `<li>- ${err}</li>`)
                        .join("");
                } else if (errorListContainer) {
                    errorListContainer.classList.add("hidden");
                }

                // File input reset on partial or full success
                fileInput.value = "";
                if (filenameDisplay)
                    filenameDisplay.textContent =
                        "Pilih file Excel (.xls, .xlsx) atau seret ke sini";
            }
        } catch (error) {
            if (resultContainer) resultContainer.classList.remove("hidden");
            if (resultAlert) {
                resultAlert.className =
                    "p-4 rounded-lg text-sm mb-3 bg-danger/10 text-danger border border-danger/20";
                resultAlert.innerHTML = `<b>Kesalahan Fatal:</b> Gagal terhubung ke server.`;
            }
            if (errorListContainer) errorListContainer.classList.add("hidden");
        } finally {
            btnSubmit.innerHTML = originalText;
            btnSubmit.disabled = false;
        }
    });
</script>
