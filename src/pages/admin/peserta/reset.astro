---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { users, userGroups } from "../../../db/schema";
import { eq } from "drizzle-orm";

// Ambil semua peserta yang isLogin = true (sedang ujian / nyangkut)
const activeUsers = await db
    .select({
        id: users.id,
        username: users.username,
        firstName: users.firstName,
        groupName: userGroups.name,
    })
    .from(users)
    .leftJoin(userGroups, eq(users.groupId, userGroups.id))
    .where(eq(users.isLogin, true))
    .all();
---

<AdminLayout title="Reset Login">
    <div class="mb-6">
        <nav class="flex text-sm text-surface-500 mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li class="inline-flex items-center">
                    <a
                        href="/admin/peserta"
                        class="hover:text-primary-600 transition-colors"
                        >Peserta</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                        <span class="text-surface-700 font-medium"
                            >Reset Login</span
                        >
                    </div>
                </li>
            </ol>
        </nav>
        <h2 class="text-xl font-bold text-surface-800">Reset Status Login</h2>
        <p class="text-sm text-surface-500 mt-1">
            Gunakan fitur ini jika ada siswa yang tidak bisa masuk ujian karena
            statusnya masih terdeteksi "Sedang Ujian" (misalnya akibat komputer
            mati/jaringan putus).
        </p>
    </div>

    <div
        class="bg-white rounded-xl border border-surface-200 shadow-sm overflow-hidden"
    >
        <div
            class="p-4 border-b border-surface-200 flex justify-between items-center bg-surface-50"
        >
            <h3 class="font-bold text-surface-800">
                Daftar Akun Sedang Ujian ({activeUsers.length})
            </h3>
            {
                activeUsers.length > 0 && (
                    <div class="flex items-center gap-3">
                        <div class="flex items-center gap-2 px-3 py-1 bg-amber-50 border border-amber-200 rounded-lg">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
                            </span>
                            <span class="text-[10px] font-bold text-amber-700 uppercase tracking-widest">Auto-Refresh: 30s</span>
                        </div>
                        <button
                            id="btn-reset-semua"
                            class="px-3 py-1.5 bg-warning border border-warning/20 text-white rounded-lg text-sm font-medium hover:bg-warning-700 transition shadow-sm"
                        >
                            <i class="icon-refresh-cw w-4 h-4 inline-block mr-1" />{" "}
                            Reset Semua
                        </button>
                    </div>
                )
            }
        </div>

        <table class="w-full text-left text-sm text-surface-600">
            <thead
                class="bg-white border-b border-surface-200 text-surface-700 font-semibold"
            >
                <tr>
                    <th class="px-5 py-3 w-12 text-center">No</th>
                    <th class="px-5 py-3">Username / No. Peserta</th>
                    <th class="px-5 py-3">Nama Lengkap</th>
                    <th class="px-5 py-3">Grup / Kelas</th>
                    <th class="px-5 py-3 w-32 text-center">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-surface-100">
                {
                    activeUsers.length === 0 ? (
                        <tr>
                            <td
                                colspan="5"
                                class="px-5 py-8 text-center text-surface-500"
                            >
                                <i class="icon-check-circle w-8 h-8 mx-auto text-success-500 mb-2 opacity-50" />
                                Tidak ada peserta yang statusnya sedang
                                login/ujian.
                            </td>
                        </tr>
                    ) : (
                        activeUsers.map((peserta, idx) => (
                            <tr class="hover:bg-surface-50/50 transition-colors">
                                <td class="px-5 py-4 text-center text-surface-400">
                                    {idx + 1}
                                </td>
                                <td class="px-5 py-4 font-mono font-medium text-surface-800">
                                    {peserta.username}
                                </td>
                                <td class="px-5 py-4">{peserta.firstName}</td>
                                <td class="px-5 py-4 font-medium">
                                    {peserta.groupName}
                                </td>
                                <td class="px-5 py-4 text-center">
                                    <button
                                        class="px-3 py-1.5 bg-surface-100 text-surface-700 hover:bg-surface-200 hover:text-surface-900 rounded-md text-xs font-medium transition btn-reset-single"
                                        data-id={peserta.id}
                                        data-name={peserta.firstName}
                                    >
                                        Reset
                                    </button>
                                </td>
                            </tr>
                        ))
                    )
                }
            </tbody>
        </table>
    </div>
</AdminLayout>

<script>
    // Auto-Refresh every 30 seconds
    const refreshTimer = setTimeout(() => {
        window.location.reload();
    }, 30000);

    // Reset Single User
    document.querySelectorAll(".btn-reset-single").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const id = parseInt(target.getAttribute("data-id") || "0");
            const name = target.getAttribute("data-name");

            if (!id) return;
            if (
                !confirm(
                    `Reset status login atas nama ${name}? Siswa tersebut akan bisa login kembali.`,
                )
            )
                return;

            // Stop refresh while processing
            clearTimeout(refreshTimer);

            const originalHtml = target.innerHTML;
            target.innerHTML = `<i class="icon-loader w-3 h-3 animate-spin inline-block"></i>`;
            target.disabled = true;

            try {
                const res = await fetch("/api/peserta/reset", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id }),
                });

                const data = await res.json();
                if (data.success) {
                    // Berhasil, sembunyikan baris tabel
                    const tr = target.closest("tr");
                    if (tr) tr.remove();
                    // Kasih feedback ringan
                    alert(`Reset login ${name} berhasil!`);
                    // Kalau butuh load ulang halaman biar counter berkurang:
                    window.location.reload();
                } else {
                    alert("Gagal mereset: " + data.error);
                    target.innerHTML = originalHtml;
                    target.disabled = false;
                }
            } catch (err) {
                alert("Kesalahan jaringan.");
                target.innerHTML = originalHtml;
                target.disabled = false;
            }
        });
    });

    // Reset Semua User Active
    const btnResetSemua = document.getElementById(
        "btn-reset-semua",
    ) as HTMLButtonElement;
    btnResetSemua?.addEventListener("click", async () => {
        const buttons = document.querySelectorAll(".btn-reset-single");
        const ids = Array.from(buttons).map((btn) =>
            parseInt(btn.getAttribute("data-id") || "0"),
        );

        if (ids.length === 0) return;
        if (
            !confirm(
                `PERINGATAN! Anda akan mereset SEMUA (${ids.length}) peserta yang terdeteksi sedang login. Apakah Anda yakin?`,
            )
        )
            return;

        // Stop refresh while processing
        clearTimeout(refreshTimer);

        const originalHtml = btnResetSemua.innerHTML;
        btnResetSemua.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Mereset...`;
        btnResetSemua.disabled = true;

        try {
            const res = await fetch("/api/peserta/reset", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ ids }),
            });

            const data = await res.json();
            if (data.success) {
                alert("Reset massal berhasil!");
                window.location.reload();
            } else {
                alert("Gagal mereset: " + data.error);
                btnResetSemua.innerHTML = originalHtml;
                btnResetSemua.disabled = false;
            }
        } catch (err) {
            alert("Kesalahan jaringan.");
            btnResetSemua.innerHTML = originalHtml;
            btnResetSemua.disabled = false;
        }
    });
</script>
