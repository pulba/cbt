---
import AdminLayout from "../../../../../layouts/AdminLayout.astro";
import { db } from "../../../../../db";
import { userGroups } from "../../../../../db/schema";
import { eq } from "drizzle-orm";

const { id } = Astro.params;

if (!id) {
    return Astro.redirect("/admin/peserta/grup");
}

const grup = await db
    .select()
    .from(userGroups)
    .where(eq(userGroups.id, parseInt(id)))
    .get();

if (!grup) {
    return Astro.redirect("/admin/peserta/grup");
}
---

<AdminLayout title="Ubah Grup">
    <div class="mb-6">
        <nav class="flex text-sm text-surface-500 mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li class="inline-flex items-center">
                    <a
                        href="/admin/peserta"
                        class="hover:text-primary-600 transition-colors"
                        >Peserta</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                        <a
                            href="/admin/peserta/grup"
                            class="hover:text-primary-600 transition-colors"
                            >Grup & Kelas</a
                        >
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                        <span class="text-surface-700 font-medium">Ubah</span>
                    </div>
                </li>
            </ol>
        </nav>
        <h2 class="text-xl font-bold text-surface-800">
            Ubah Data Grup / Kelas
        </h2>
    </div>

    <div
        class="bg-white p-6 rounded-xl border border-surface-200 shadow-sm max-w-2xl"
    >
        <form id="form-ubah-grup" class="space-y-4">
            <input type="hidden" name="id" value={grup.id} />
            <div>
                <label
                    for="name"
                    class="block text-sm font-medium text-surface-700 mb-1"
                    >Nama Grup / Kelas <span class="text-danger">*</span></label
                >
                <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    value={grup.name}
                    placeholder="Contoh: Kelas 10A"
                    class="w-full px-4 py-2 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500"
                />
            </div>

            <div>
                <label
                    for="description"
                    class="block text-sm font-medium text-surface-700 mb-1"
                    >Deskripsi Ruang / Jurusan (Opsional)</label
                >
                <textarea
                    id="description"
                    name="description"
                    rows="3"
                    placeholder="Keterangan tambahan..."
                    class="w-full px-4 py-2 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500"
                    >{grup.description}</textarea
                >
            </div>

            <div class="pt-4 flex justify-end gap-3">
                <a
                    href="/admin/peserta/grup"
                    class="px-5 py-2 text-surface-600 bg-surface-100 hover:bg-surface-200 font-medium rounded-lg transition"
                >
                    Batal
                </a>
                <button
                    type="submit"
                    id="btn-submit"
                    class="px-5 py-2 text-white bg-primary-600 hover:bg-primary-500 font-medium rounded-lg transition flex items-center shadow-soft-xl shadow-primary-500/30"
                >
                    <i class="icon-save w-4 h-4 mr-2"></i> Simpan Perubahan
                </button>
            </div>
        </form>
    </div>
</AdminLayout>

<script>
    const form = document.getElementById("form-ubah-grup") as HTMLFormElement;
    const btnSubmit = document.getElementById(
        "btn-submit",
    ) as HTMLButtonElement;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        const originalText = btnSubmit.innerHTML;
        btnSubmit.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Menyimpan...`;
        btnSubmit.disabled = true;

        try {
            const res = await fetch("/api/peserta/grup", {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            });
            const result = await res.json();

            if (!result.success) {
                alert("Gagal menyimpan: " + result.error);
                btnSubmit.innerHTML = originalText;
                btnSubmit.disabled = false;
                return;
            }

            window.location.href = "/admin/peserta/grup";
        } catch (error) {
            alert("Terjadi kesalahan jaringan.");
            btnSubmit.innerHTML = originalText;
            btnSubmit.disabled = false;
        }
    });
</script>
