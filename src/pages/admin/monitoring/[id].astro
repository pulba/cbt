---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import {
    tests,
    testUsers,
    users,
    testQuestions,
    testQuestionAnswers,
    userGroups,
} from "../../../db/schema";
import { eq, and, count, sql } from "drizzle-orm";

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'guru' && user.role !== 'operator')) {
    return Astro.redirect("/admin");
}

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/ujian");

const testId = parseInt(id);

// 1. Fetch Test Info
const testData = await db
    .select()
    .from(tests)
    .where(eq(tests.id, testId))
    .get();
if (!testData) return Astro.redirect("/admin/ujian");

// 2. Fetch all students who have a session for this test
const sessions = await db
    .select({
        sessionId: testUsers.id,
        sessionStatus: testUsers.status,
        usedToken: testUsers.usedToken,
        userId: users.id,
        userName: users.firstName,
        userLogin: users.username,
        groupId: users.groupId,
        violationCount: testUsers.violationCount,
    })
    .from(testUsers)
    .innerJoin(users, eq(testUsers.userId, users.id))
    .where(eq(testUsers.testId, testId))
    .all();

// 3. For each session, calculate progress (answered / total questions)
const sessionProgress = await Promise.all(
    sessions.map(async (s) => {
        const totalQ = await db
            .select({ count: count() })
            .from(testQuestions)
            .where(eq(testQuestions.testUserId, s.sessionId))
            .get();

        const answeredQ = await db
            .select({ count: count() })
            .from(testQuestions)
            .innerJoin(
                testQuestionAnswers,
                and(
                    eq(testQuestionAnswers.testQuestionId, testQuestions.id),
                    eq(testQuestionAnswers.isSelected, true),
                ),
            )
            .where(eq(testQuestions.testUserId, s.sessionId))
            .get();

        const total = totalQ?.count ?? 0;
        const answered = answeredQ?.count ?? 0;

        return {
            ...s,
            total,
            answered,
            percent: total > 0 ? Math.round((answered / total) * 100) : 0,
        };
    }),
);

// Summary Stats
const totalPeserta = sessionProgress.length;
const finishedCount = sessionProgress.filter(
    (s) => s.sessionStatus === 4,
).length;
const doingCount = sessionProgress.filter((s) => s.sessionStatus === 1).length;

const statusMap: Record<number, string> = {
    1: "Sedang Mengerjakan",
    4: "Selesai",
    10: "TERKUNCI (Pelanggaran)",
};
const statusColorMap: Record<number, string> = {
    1: "bg-primary-100 text-primary-700",
    4: "bg-success-100 text-success-700",
    10: "bg-rose-600 text-white",
};
---

<AdminLayout title={`Monitoring: ${testData.name}`}>
    <!-- Page Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <div class="flex items-center gap-2 text-sm text-surface-500 mb-1">
                <a href="/admin/ujian" class="hover:text-primary-600 transition"
                    >Manajemen Ujian</a
                >
                <i class="icon-chevron-right w-4 h-4"></i>
                <span class="font-medium text-surface-700">Live Monitoring</span
                >
            </div>
            <h1
                class="text-2xl font-bold text-surface-900 flex items-center gap-2"
            >
                <i class="icon-monitor w-6 h-6 text-primary-600"></i>
                {testData.name}
            </h1>
        </div>
        <div class="flex items-center gap-3">
            <button
                onclick="refreshPage()"
                title="Refresh Data"
                class="w-9 h-9 flex items-center justify-center rounded-xl border border-surface-200 hover:bg-surface-100 text-surface-600 transition"
            >
                <i class="icon-refresh-cw w-4 h-4" id="refresh-icon"></i>
            </button>
            <a
                href={`/admin/ujian`}
                class="px-4 py-2 bg-white border border-surface-200 hover:bg-surface-50 text-surface-700 rounded-xl text-sm font-medium transition"
            >
                ← Kembali
            </a>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="grid grid-cols-3 gap-4 mb-6">
        <div
            class="bg-white rounded-2xl border border-surface-200 p-5 shadow-sm"
        >
            <div class="text-sm font-medium text-surface-500 mb-1">
                Total Peserta
            </div>
            <div class="text-3xl font-bold text-surface-800">
                {totalPeserta}
            </div>
        </div>
        <div
            class="bg-white rounded-2xl border border-surface-200 p-5 shadow-sm"
        >
            <div class="text-sm font-medium text-surface-500 mb-1">
                Sedang Mengerjakan
            </div>
            <div class="text-3xl font-bold text-primary-600">{doingCount}</div>
        </div>
        <div
            class="bg-white rounded-2xl border border-surface-200 p-5 shadow-sm"
        >
            <div class="text-sm font-medium text-surface-500 mb-1">
                Telah Selesai
            </div>
            <div class="text-3xl font-bold text-success-500">
                {finishedCount}
            </div>
        </div>
    </div>

    <!-- Monitoring Table -->
    <div
        class="bg-white rounded-2xl border border-surface-200 shadow-sm overflow-hidden"
    >
        <div
            class="p-5 border-b border-surface-100 flex items-center justify-between"
        >
            <div
                class="font-semibold text-surface-800 text-sm flex items-center gap-2"
            >
                <i class="icon-users w-4 h-4 text-primary-500"></i>
                Daftar Peserta
            </div>
            <span class="text-xs text-surface-400"
                >Auto-refresh setiap 30 detik</span
            >
        </div>

        {
            sessionProgress.length === 0 ? (
                <div class="p-16 text-center">
                    <i class="icon-inbox w-12 h-12 text-surface-300 mx-auto mb-3" />
                    <p class="text-surface-500 font-medium">
                        Belum ada peserta yang memulai ujian ini.
                    </p>
                </div>
            ) : (
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-50 border-b border-surface-200">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    #
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Nama
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Username
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Status
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Pelanggaran
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide w-48">
                                    Progress Jawaban
                                </th>
                                <th class="px-4 py-3 text-left font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Token
                                </th>
                                <th class="px-4 py-3 text-right font-semibold text-surface-600 text-xs uppercase tracking-wide">
                                    Aksi
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-surface-100">
                            {sessionProgress.map((s, idx) => (
                                <tr class="hover:bg-surface-50/70 transition-colors">
                                    <td class="px-4 py-3.5 text-surface-400 text-xs">
                                        {idx + 1}
                                    </td>
                                    <td class="px-4 py-3.5">
                                        <div class="font-semibold text-surface-800">
                                            {s.userName}
                                        </div>
                                    </td>
                                    <td class="px-4 py-3.5 text-surface-500 font-mono text-xs">
                                        {s.userLogin}
                                    </td>
                                    <td class="px-4 py-3.5">
                                        <span
                                            class={`px-2 py-1 rounded-full text-xs font-bold ${statusColorMap[s.sessionStatus ?? 1] ?? "bg-surface-100 text-surface-600"}`}
                                        >
                                            {statusMap[s.sessionStatus ?? 1] ??
                                                "Tidak Diketahui"}
                                        </span>
                                    </td>
                                    <td class="px-4 py-3.5 text-center">
                                        <span class={`font-bold text-xs ${s.violationCount! > 0 ? 'text-rose-600' : 'text-surface-400'}`}>
                                            {s.violationCount ?? 0} / 3
                                        </span>
                                    </td>
                                    <td class="px-4 py-3.5">
                                        <div class="flex items-center gap-2">
                                            <div class="flex-1 bg-surface-100 rounded-full h-2 overflow-hidden">
                                                <div
                                                    class={`h-full rounded-full transition-all ${s.sessionStatus === 4 ? "bg-success-500" : "bg-primary-500"}`}
                                                    style={`width: ${s.percent}%`}
                                                />
                                            </div>
                                            <span class="text-xs font-bold text-surface-600 w-14 shrink-0 text-right">
                                                {s.answered}/{s.total}
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-4 py-3.5">
                                        {s.usedToken ? (
                                            <span class="font-mono text-xs bg-surface-100 px-2 py-1 rounded-lg text-surface-600">
                                                {s.usedToken}
                                            </span>
                                        ) : (
                                            <span class="text-surface-300 text-xs">
                                                —
                                            </span>
                                        )}
                                    </td>
                                    <td class="px-4 py-3.5 text-right">
                                        <div class="flex justify-end gap-2">
                                            {s.sessionStatus === 10 && (
                                                <button
                                                    onclick={`unlockSession(${s.sessionId}, '${s.userName}')`}
                                                    class="px-3 py-1.5 text-xs font-bold rounded-xl bg-emerald-600 text-white hover:bg-emerald-500 transition shadow-sm shadow-emerald-500/30"
                                                    title="Buka blokir ujian peserta ini"
                                                >
                                                    <i class="icon-unlock w-3 h-3 inline-block mr-1" />
                                                    Buka Blokir
                                                </button>
                                            )}
                                            {s.sessionStatus === 1 && (
                                                <button
                                                    onclick={`forceFinish(${s.sessionId}, '${s.userName}')`}
                                                    class="px-3 py-1.5 text-xs font-bold rounded-xl bg-danger text-white hover:bg-danger/80 transition shadow-sm shadow-danger/30"
                                                    title="Paksa selesaikan ujian peserta ini"
                                                >
                                                    <i class="icon-check-square w-3 h-3 inline-block mr-1" />
                                                    Force Selesai
                                                </button>
                                            )}
                                            <button
                                                onclick={`resetSession(${s.sessionId}, '${s.userName}')`}
                                                class="px-3 py-1.5 text-xs font-bold rounded-xl bg-surface-100 text-surface-700 hover:bg-amber-50 hover:text-amber-700 transition border border-surface-200"
                                                title="Reset sesi (hapus progress, siswa bisa mulai lagi)"
                                            >
                                                <i class="icon-rotate-ccw w-3 h-3 inline-block mr-1" />
                                                Reset
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            )
        }
    </div>
</AdminLayout>

<script>
    // Auto-refresh page every 30 seconds
    let autoRefreshTimer = setInterval(() => {
        window.location.reload();
    }, 30000);

    (window as any).refreshPage = () => {
        const icon = document.getElementById("refresh-icon");
        if (icon) icon.classList.add("animate-spin");
        window.location.reload();
    };

    (window as any).forceFinish = async (sessionId: number, name: string) => {
        if (
            !confirm(
                `Apakah Anda yakin ingin MEMAKSA ${name} menyelesaikan ujian sekarang? Jawaban yang sudah diisi akan dinilai.`,
            )
        )
            return;

        try {
            const res = await fetch(`/api/admin/monitoring/force-finish`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ sessionId }),
            });
            const data = await res.json();
            if (data.status) {
                alert(`Sesi ${name} berhasil diselesaikan.`);
                window.location.reload();
            } else {
                alert(data.message || "Gagal menyelesaikan sesi.");
            }
        } catch {
            alert("Error koneksi ke server.");
        }
    };

    (window as any).resetSession = async (sessionId: number, name: string) => {
        if (
            !confirm(
                `PERINGATAN! Ini akan MENGHAPUS SELURUH PROGRESS ${name} (termasuk semua jawaban). Siswa harus memulai dari awal lagi. Lanjutkan?`,
            )
        )
            return;

        try {
            const res = await fetch(`/api/admin/monitoring/reset-session`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ sessionId }),
            });
            const data = await res.json();
            if (data.status) {
                alert(`Sesi ${name} berhasil direset.`);
                window.location.reload();
            } else {
                alert(data.message || "Gagal mereset sesi.");
            }
        } catch {
            alert("Error koneksi ke server.");
        }
    };

    (window as any).unlockSession = async (sessionId: number, name: string) => {
        if (!confirm(`Buka blokir untuk ${name}? Siswa akan bisa melanjutkan ujian kembali.`)) return;

        try {
            const res = await fetch(`/api/admin/monitoring/unlock`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ sessionId }),
            });
            const data = await res.json();
            if (data.status) {
                alert(`Blokir ${name} berhasil dibuka.`);
                window.location.reload();
            } else {
                alert(data.message || "Gagal membuka blokir.");
            }
        } catch {
            alert("Error koneksi ke server.");
        }
    };
</script>
