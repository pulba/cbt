---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Hasil & Laporan">
    <!-- Header -->
    <div class="mb-6 flex flex-col sm:flex-row items-start justify-between gap-4">
        <div>
            <h2 class="text-xl font-bold text-surface-800">Laporan Hasil Ujian & Laporan</h2>
            <p class="text-sm text-surface-500 mt-1">Pilih menu di bawah ini untuk mengelola hasil ujian dan esai.</p>
        </div>
    </div>

    <!-- Navigation Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <!-- Rekap Nilai Card -->
        <a
            href="/admin/hasil/rekap"
            class="group relative overflow-hidden flex items-start gap-4 p-5 bg-gradient-to-br from-white to-primary-50/50 rounded-2xl border border-primary-100 shadow-sm hover:border-primary-300 hover:shadow-md transition-all duration-300"
        >
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-100/40 rounded-full blur-3xl -mr-10 -mt-10 transition-all group-hover:bg-primary-200/40"></div>
            
            <div class="relative w-12 h-12 rounded-xl bg-primary-100 flex items-center justify-center shrink-0 group-hover:bg-primary-500 group-hover:scale-105 transition-all duration-300">
                <i class="icon-bar-chart-2 w-6 h-6 text-primary-600 group-hover:text-white transition-colors"></i>
            </div>
            <div class="relative min-w-0 z-10">
                <p class="text-[15px] font-bold text-surface-800 group-hover:text-primary-700 transition-colors">Rekap Nilai Ujian</p>
                <p class="text-xs text-surface-500 mt-1.5 leading-relaxed">Lihat rekapitulasi nilai seluruh peserta per-ujian, ekspor CSV, dan cetak laporan PDF.</p>
            </div>
            <i class="relative icon-chevron-right w-5 h-5 text-primary-300 group-hover:text-primary-500 group-hover:translate-x-1 mt-1 shrink-0 transition-all"></i>
        </a>

        <!-- Koreksi Esai Card -->
        <a
            href="/admin/hasil/koreksi-esai"
            class="group relative overflow-hidden flex items-start gap-4 p-5 bg-gradient-to-br from-white to-amber-50/50 rounded-2xl border border-amber-100 shadow-sm hover:border-amber-300 hover:shadow-md transition-all duration-300"
        >
            <div class="absolute bottom-0 right-0 w-32 h-32 bg-amber-100/40 rounded-full blur-3xl -mr-10 -mb-10 transition-all group-hover:bg-amber-200/40"></div>

            <div class="relative w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center shrink-0 group-hover:bg-amber-500 group-hover:scale-105 transition-all duration-300">
                <i class="icon-edit-3 w-6 h-6 text-amber-600 group-hover:text-white transition-colors"></i>
            </div>
            <div class="relative min-w-0 z-10">
                <p class="text-[15px] font-bold text-surface-800 group-hover:text-amber-700 transition-colors">Koreksi &amp; Penilaian Esai</p>
                <p class="text-xs text-surface-500 mt-1.5 leading-relaxed">Periksa manual jawaban esai siswa atau kelola penilaian otomatis (auto-grading).</p>
            </div>
            <i class="relative icon-chevron-right w-5 h-5 text-amber-300 group-hover:text-amber-500 group-hover:translate-x-1 mt-1 shrink-0 transition-all"></i>
        </a>
    </div>
</AdminLayout>
