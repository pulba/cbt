---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import {
    tests,
    testUsers,
    testQuestions,
    questions,
    testQuestionAnswers,
    questionAnswers,
    users,
    userGroups,
} from "../../../db/schema";
import { eq, and, inArray } from "drizzle-orm";

interface Choice {
    tqaId: number;
    tqId: number;
    isSelected: boolean;
    ansId: number;
    ansText: string;
    isCorrect: boolean;
    orderIdx: number;
}

const sessionId = Astro.url.searchParams.get("sessionId");

if (!sessionId) {
    return Astro.redirect("/admin/hasil");
}

const sessId = parseInt(sessionId);

// 1. Fetch Session Info
const session = await db
    .select({
        id: testUsers.id,
        status: testUsers.status,
        creationTime: testUsers.creationTime,
        testId: testUsers.testId,
        userId: testUsers.userId,
        testName: tests.name,
        scoreRight: tests.scoreRight,
        scoreWrong: tests.scoreWrong,
        scoreUnanswered: tests.scoreUnanswered,
        maxScore: tests.maxScore,
        firstName: users.firstName,
        username: users.username,
        groupName: userGroups.name,
    })
    .from(testUsers)
    .innerJoin(tests, eq(testUsers.testId, tests.id))
    .innerJoin(users, eq(testUsers.userId, users.id))
    .leftJoin(userGroups, eq(users.groupId, userGroups.id))
    .where(eq(testUsers.id, sessId))
    .get();

if (!session) {
    return Astro.redirect("/admin/hasil");
}

// 2. Fetch all questions in this session
const sessionQuestions = await db
    .select({
        tqId: testQuestions.id,
        qId: questions.id,
        orderIdx: testQuestions.orderIdx,
        qText: questions.text,
        qType: questions.type,
    })
    .from(testQuestions)
    .innerJoin(questions, eq(testQuestions.questionId, questions.id))
    .where(eq(testQuestions.testUserId, sessId))
    .orderBy(testQuestions.orderIdx)
    .all();

// 3. Fetch all choices and responses
const tqIds = sessionQuestions.map((q) => q.tqId);
let allChoices: Choice[] = [];
if (tqIds.length > 0) {
    allChoices = await db
        .select({
            tqaId: testQuestionAnswers.id,
            tqId: testQuestionAnswers.testQuestionId,
            isSelected: testQuestionAnswers.isSelected,
            ansId: questionAnswers.id,
            ansText: questionAnswers.text,
            isCorrect: questionAnswers.isCorrect,
            orderIdx: testQuestionAnswers.orderIdx,
        })
        .from(testQuestionAnswers)
        .innerJoin(questionAnswers, eq(testQuestionAnswers.answerId, questionAnswers.id))
        .where(inArray(testQuestionAnswers.testQuestionId, tqIds))
        .all() as Choice[];
}

const charMap = ["A", "B", "C", "D", "E", "F"];

// 4. Calculate stats
let correctCount = 0;
let wrongCount = 0;
let unansweredCount = 0;

const processedQuestions = sessionQuestions.map((q: typeof sessionQuestions[0]) => {
    const choices = allChoices
        .filter((c) => c.tqId === q.tqId)
        .sort((a, b) => a.orderIdx - b.orderIdx);
    
    const correctIdx = choices.findIndex(c => !!c.isCorrect);
    const correctKey = correctIdx >= 0 ? charMap[correctIdx] : "-";

    const selectedIdx = choices.findIndex(c => !!c.isSelected);
    const selected = selectedIdx >= 0 ? choices[selectedIdx] : null;
    const selectedKey = selectedIdx >= 0 ? charMap[selectedIdx] : "-";
    
    let status = "unanswered";
    let earnedPoints = session.scoreUnanswered || 0;

    if (selected) {
        if (!!selected.isCorrect) {
            status = "correct";
            earnedPoints = session.scoreRight || 1;
            correctCount++;
        } else {
            status = "wrong";
            earnedPoints = session.scoreWrong || 0;
            wrongCount++;
        }
    } else {
        // User wants empty to be counted as wrong/incorrect
        status = "unanswered";
        wrongCount++; // Grouping unanswered into wrong count for summary
        unansweredCount++;
    }

    return {
        ...q,
        choices,
        selected,
        selectedKey,
        correctKey,
        status,
        earnedPoints,
    };
});

const rawScore = (correctCount * (session.scoreRight || 1)) + 
                 (wrongCount * (session.scoreWrong || 0)) + 
                 (unansweredCount * (session.scoreUnanswered || 0));

const maxScoreScale = session.maxScore && session.maxScore > 0 ? session.maxScore : 100;
const totalQs = processedQuestions.length;
const maxRaw = totalQs * (session.scoreRight || 1);
const finalScore = maxRaw > 0 ? Math.round((rawScore / maxRaw) * maxScoreScale * 100) / 100 : 0;
---

<AdminLayout title={`Detail Hasil: ${session.firstName}`}>
    <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 print:hidden">
        <div>
            <nav class="flex text-sm text-surface-500 mb-2" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a href="/admin/hasil" class="hover:text-primary-600 transition-colors">Laporan</a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <span class="text-surface-700 font-medium">Detail Siswa</span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h2 class="text-xl font-bold text-surface-800 flex items-center">
                <a href={`/admin/hasil?testId=${session.testId}`} class="mr-3 p-1.5 rounded-lg hover:bg-surface-100 transition-colors text-surface-500">
                    <i class="icon-arrow-left w-5 h-5"></i>
                </a>
                Analisis Butir Soal: {session.firstName}
            </h2>
        </div>
        <div class="flex gap-2">
            <button onclick="window.print()" class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm flex items-center gap-2">
                <i class="icon-printer w-4 h-4"></i> Cetak Analisis
            </button>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white p-5 rounded-2xl border border-surface-200 shadow-sm flex flex-col justify-center">
            <span class="text-[10px] uppercase font-black tracking-widest text-surface-400 mb-1">Skor Akhir</span>
            <div class="text-4xl font-black text-primary-600">{finalScore.toFixed(1).replace('.0', '')}</div>
            <div class="text-xs text-surface-500 mt-1 capitalize">{processedQuestions.length} Soal · {session.testName}</div>
        </div>
        
        <div class="bg-white p-5 rounded-2xl border border-surface-200 shadow-sm">
            <div class="flex items-center justify-between mb-3 text-emerald-600">
                <span class="text-[10px] uppercase font-black tracking-widest text-surface-400">Jawaban Benar</span>
                <i class="icon-check-circle w-5 h-5"></i>
            </div>
            <div class="text-2xl font-black text-emerald-600">{correctCount}</div>
            <div class="text-xs text-surface-500 mt-1">Berhasil menjawab benar</div>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-surface-200 shadow-sm">
            <div class="flex items-center justify-between mb-3 text-rose-500">
                <span class="text-[10px] uppercase font-black tracking-widest text-surface-400">Jawaban Salah / Kosong</span>
                <i class="icon-x-circle w-5 h-5"></i>
            </div>
            <div class="text-2xl font-black text-rose-500">{wrongCount}</div>
            <div class="text-xs text-surface-500 mt-1">Gagal mendapatkan poin penuh</div>
        </div>

        <div class="bg-white p-5 rounded-2xl border border-surface-200 shadow-sm">
            <div class="flex items-center justify-between mb-3 text-surface-400">
                <span class="text-[10px] uppercase font-black tracking-widest text-surface-400">Benar vs Total</span>
                <i class="icon-sliders w-5 h-5"></i>
            </div>
            <div class="text-2xl font-black text-surface-400">{correctCount} <span class="text-lg text-surface-200">/</span> {processedQuestions.length}</div>
            <div class="text-xs text-surface-500 mt-1">Akurasi pengerjaan soal</div>
        </div>
    </div>

    <!-- Details List -->
    <div class="space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <h3 class="font-black text-surface-800 uppercase tracking-widest text-sm flex items-center gap-2">
                <i class="icon-list w-4 h-4 text-primary-500"></i> Daftar Pengerjaan Soal
            </h3>
            
            <!-- Legend Indicators -->
            <div class="flex items-center gap-4 text-[10px] font-black uppercase tracking-widest text-surface-500 bg-surface-50 px-3 py-1.5 rounded-xl border border-surface-200">
                <div class="flex items-center gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
                    <span>Kunci Jawaban</span>
                </div>
                <div class="flex items-center gap-1.5">
                    <div class="w-2.5 h-2.5 rounded-full bg-rose-500"></div>
                    <span>Pilihan Siswa</span>
                </div>
            </div>
        </div>

        {processedQuestions.map((q, idx) => (
            <div class={`bg-white rounded-2xl border overflow-hidden shadow-sm transition-all ${
                q.status === 'correct' ? 'border-emerald-100' : 
                q.status === 'wrong' ? 'border-rose-100' : 'border-surface-200'
            }`}>
                <div class={`px-5 py-3 flex items-center justify-between border-b ${
                    q.status === 'correct' ? 'bg-emerald-50/50 border-emerald-100' : 
                    q.status === 'wrong' ? 'bg-rose-50/50 border-rose-100' : 'bg-surface-50/50 border-surface-200'
                }`}>
                    <div class="flex items-center gap-3">
                        <span class={`w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm ${
                            q.status === 'correct' ? 'bg-emerald-600 text-white' : 
                            q.status === 'wrong' ? 'bg-rose-600 text-white' : 'bg-surface-800 text-white'
                        }`}>
                            {q.orderIdx}
                        </span>
                        <span class="text-xs font-bold uppercase tracking-wider text-surface-500">Soal {q.qType === 1 ? 'PG' : 'Esai'}</span>
                    </div>
                    <div class="flex items-center gap-2">
                        {q.status === 'correct' && <span class="text-[10px] font-black text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded uppercase">Benar (Kunci: {q.correctKey})</span>}
                        {q.status === 'wrong' && <span class="text-[10px] font-black text-rose-600 bg-rose-100 px-2 py-0.5 rounded uppercase">Salah (Kunci: {q.correctKey})</span>}
                        {q.status === 'unanswered' && <span class="text-[10px] font-black text-rose-600 bg-rose-100 px-2 py-0.5 rounded uppercase underline">Kosong (Kunci: {q.correctKey})</span>}
                        <span class="text-xs font-mono font-bold text-surface-400">{q.earnedPoints > 0 ? '+' : ''}{q.earnedPoints} Poin</span>
                    </div>
                </div>

                <div class="p-6">
                    <div class="prose prose-sm max-w-none text-surface-800 mb-6" set:html={q.qText} />

                    {q.qType === 1 && (
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {q.choices.map((choice, cIdx) => {
                                const isUserSelected = choice.isSelected;
                                const isCorrect = choice.isCorrect;
                                
                                let cls = "p-3 rounded-xl border-2 flex items-start gap-3 transition-colors text-sm ";
                                if (isUserSelected && isCorrect) cls += "bg-emerald-50 border-emerald-500 text-emerald-800 shadow-sm";
                                else if (isUserSelected) cls += "bg-rose-50 border-rose-500 text-rose-800 shadow-sm";
                                else if (isCorrect) cls += "bg-emerald-50/30 border-dashed border-emerald-400 text-emerald-700";
                                else cls += "bg-surface-50 border-surface-100 text-surface-400 opacity-60";

                                return (
                                    <div class={cls}>
                                        <span class={`w-6 h-6 rounded-full text-[11px] font-black flex items-center justify-center shrink-0 ${
                                            isUserSelected && isCorrect ? 'bg-emerald-600 text-white' :
                                            isUserSelected ? 'bg-rose-600 text-white' :
                                            isCorrect ? 'bg-emerald-200 text-emerald-800' : 'bg-surface-200 text-surface-600'
                                        }`}>
                                            {charMap[cIdx] || '?'}
                                        </span>
                                        <div class="flex-1">
                                            <div set:html={choice.ansText} />
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    )}
                </div>
            </div>
        ))}
    </div>

    {processedQuestions.length === 0 && (
        <div class="bg-surface-50 border-2 border-dashed border-surface-200 rounded-3xl p-16 text-center text-surface-500">
            <i class="icon-alert-octagon w-12 h-12 mx-auto mb-4 opacity-20"></i>
            <p class="font-bold">Tidak ada rincian pengerjaan ditemukan.</p>
        </div>
    )}
</AdminLayout>
