---
import { db } from "../../../db";
import {
    tests,
    testUsers,
    testQuestions,
    questions,
    essayConfigs,
    questionAnswers,
    users,
    userGroups,
    configs,
} from "../../../db/schema";
import { eq, desc, inArray, and } from "drizzle-orm";
import { testTopicSets } from "../../../db/schema";

// Fetch school name from configs
import { sql } from 'drizzle-orm';
const allConfigs = await db.select({ 
    key: configs.key, 
    value: sql<string>`CASE WHEN ${configs.key} = 'school_logo' THEN '1' ELSE ${configs.value} END` 
}).from(configs).all();
const getConfig = (key: string) =>
    allConfigs.find((c: any) => c.key === key)?.value || "";
const schoolName = getConfig("school_name") || "Sekolah";

const admin = Astro.locals.user;
if (!admin || admin.role === "student") return Astro.redirect("/admin");

const testIdStr = Astro.url.searchParams.get("testId");
if (!testIdStr) return Astro.redirect("/admin/hasil");

const testId = parseInt(testIdStr);

// 1. Get test config
const test = await db.select().from(tests).where(eq(tests.id, testId)).get();
if (!test) return Astro.redirect("/admin/hasil");

// 2. Get all sessions
const sessions = await db
    .select({
        sessionId: testUsers.id,
        userId: testUsers.userId,
        status: testUsers.status,
        creationTime: testUsers.creationTime,
        firstName: users.firstName,
        username: users.username,
        groupName: userGroups.name,
    })
    .from(testUsers)
    .innerJoin(users, eq(testUsers.userId, users.id))
    .leftJoin(userGroups, eq(users.groupId, userGroups.id))
    .where(eq(testUsers.testId, testId))
    .orderBy(userGroups.name, users.firstName)
    .all();

// 3. Get all question scores (including essay scores) from DB
const allSessionQuestions = await db
    .select({
        sessionId: testQuestions.testUserId,
        tqId: testQuestions.id,
        questionId: questions.id,
        score: testQuestions.score,
        essayScoreOverride: testQuestions.essayScoreOverride,
        isAnswered: testQuestions.isAnswered,
        qType: questions.type,
        topicId: questions.topicId,
        essayMaxScore: essayConfigs.maxScore,
    })
    .from(testQuestions)
    .innerJoin(testUsers, eq(testQuestions.testUserId, testUsers.id))
    .innerJoin(questions, eq(testQuestions.questionId, questions.id))
    .leftJoin(
        essayConfigs,
        eq(testQuestions.questionId, essayConfigs.questionId),
    )
    .where(eq(testUsers.testId, testId))
    .all();

const isTkaMode = test.mode === 'tka';
const tkaTopicSets = isTkaMode ? await db.select().from(testTopicSets).where(eq(testTopicSets.testId, testId)).all() : [];

let parsedTkaScores: any = {};
if (isTkaMode && test.tkaScoreConfig) {
    try { parsedTkaScores = JSON.parse(test.tkaScoreConfig); } catch(e) {}
}

// Fetch Type 5 correct counts for maxRaw
const type5QuestionIds = [...new Set(allSessionQuestions.filter(q => q.qType === 5).map(q => q.questionId))] as number[];
const type5Counts = new Map<number, number>();
if (type5QuestionIds.length > 0) {
    const t5Answers = await db.select({ questionId: questionAnswers.questionId, isCorrect: questionAnswers.isCorrect })
        .from(questionAnswers)
        .where(and(inArray(questionAnswers.questionId, type5QuestionIds), eq(questionAnswers.isCorrect, true)))
        .all();
    type5QuestionIds.forEach(qid => {
        type5Counts.set(qid, Math.max(1, t5Answers.filter(a => a.questionId === qid).length));
    });
}

const scoreRight = test.scoreRight ?? 1;
const maxScore = test.maxScore ?? 0;

// 3.5 Group by latest session per user
const latestMap = new Map<number, any>();
sessions.forEach((sess) => {
    const existing = latestMap.get(sess.userId!);
    if (!existing || sess.sessionId > existing.sessionId) {
        latestMap.set(sess.userId!, sess);
    }
});
const filteredSessList = Array.from(latestMap.values());

// 3.1 Fetch weights for Type 4 questions to calculate max possible raw score
const type4QuestionIds = [...new Set(allSessionQuestions.filter(q => q.qType === 4 && q.questionId != null).map(q => q.questionId!))] as number[];
const type4Weights = new Map<number, number>();
if (type4QuestionIds.length > 0) {
    const weights = await db.select({ qId: questionAnswers.questionId, weight: questionAnswers.weight })
        .from(questionAnswers).where(inArray(questionAnswers.questionId, type4QuestionIds)).all();
    type4QuestionIds.forEach(qid => {
        const totalW = weights.filter(w => w.qId === qid).reduce((s: number, w: any) => s + (w.weight ?? 1), 0);
        type4Weights.set(qid, totalW);
    });
}

const results = filteredSessList.map((sess, idx) => {
    const sessionQs = allSessionQuestions.filter(
        (q) => q.sessionId === sess.sessionId,
    );

    const total = sessionQs.length;
    // Use essayScoreOverride when available (same logic as rekap.astro)
    const pgScore = sessionQs.reduce((sum: number, q: any) => {
        if ((q.qType === 2 || q.qType === 3) && q.essayScoreOverride !== null && q.essayScoreOverride !== undefined) {
            return sum + q.essayScoreOverride;
        }
        return sum + (q.score || 0);
    }, 0);
    const maxScoreScale = maxScore > 0 ? maxScore : 100;

    // Per-question maxRaw: essay uses essayMaxScore, Matching uses total weight, PG uses scoreRight
    const maxRaw = sessionQs.reduce((sum: number, q: any) => {
        let qScoreRight = scoreRight;
        if (isTkaMode) {
            if (parsedTkaScores[q.qType] !== undefined) {
                qScoreRight = parseFloat(parsedTkaScores[q.qType]);
            }
            const ts = tkaTopicSets.find(t => t.topicId === q.topicId && t.questionType === q.qType);
            if (ts && ts.scoreRightOverride !== null) qScoreRight = ts.scoreRightOverride;
            
            return sum + qScoreRight;
        }
        if (q.qType === 2 || q.qType === 3)
            return sum + (q.essayMaxScore ?? 100);
        if (q.qType === 4)
            return sum + (type4Weights.get(q.questionId) ?? 1);
        if (q.qType === 5)
            return sum + ((type5Counts.get(q.questionId) ?? 1) * qScoreRight);
        return sum + qScoreRight;
    }, 0);

    const totalScore = maxRaw > 0 ? (pgScore / maxRaw) * maxScoreScale : 0;
    const hasEssay = sessionQs.some((q: any) => q.qType === 2 || q.qType === 3);

    return {
        ...sess,
        totalScore: Math.round(totalScore * 100) / 100,
        hasEssay,
        formattedDate: sess.creationTime
            ? new Date(sess.creationTime)
                  .toISOString()
                  .replace("T", " ")
                  .substring(0, 19)
            : "-",
    };
});
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Cetak Hasil: {test.name}</title>
        <style>
            body {
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                font-size: 10px;
                color: #000;
                margin: 0;
                padding: 0;
                background: #f4f4f4;
            }
            .page-container {
                background: white;
                width: 210mm;
                min-height: 297mm;
                margin: 20px auto;
                padding: 15mm;
                box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
                box-sizing: border-box;
            }
            .header {
                text-align: center;
                margin-bottom: 30px;
                border-bottom: 2px solid #333;
                padding-bottom: 15px;
            }
            .header h1 {
                margin: 0;
                font-size: 20px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }
            .header p {
                margin: 5px 0 0;
                color: #555;
                font-size: 12px;
            }
            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 10px;
            }
            th,
            td {
                border: 1px solid #000;
                padding: 8px 6px;
                text-align: left;
                line-height: 1.4;
            }
            th {
                background-color: #f0f0f0 !important;
                text-transform: uppercase;
                font-weight: bold;
                -webkit-print-color-adjust: exact;
            }
            .text-center {
                text-align: center;
            }
            .text-right {
                text-align: right;
            }
            .text-bold {
                font-weight: bold;
            }
            @media print {
                @page {
                    size: A4 portrait;
                    margin: 0;
                }
                body {
                    background: white;
                    padding: 0;
                }
                .page-container {
                    margin: 0;
                    width: 100%;
                    box-shadow: none;
                    padding: 15mm;
                }
                .no-print {
                    display: none;
                }
            }
            .btn-print {
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 12px 24px;
                background: #2563eb;
                color: white;
                border: none;
                border-radius: 8px;
                cursor: pointer;
                box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
                font-weight: 600;
                font-size: 14px;
                z-index: 100;
                display: flex;
                items-center: center;
                gap: 8px;
            }
            .btn-print:hover {
                background: #1d4ed8;
            }
        </style>
    </head>
    <body>
        <button onclick="window.print()" class="btn-print no-print">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M6 9V2h12v7"></path><path
                    d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"
                ></path><rect x="6" y="14" width="12" height="8"></rect></svg
            >
            Cetak Laporan (PDF)
        </button>

        <div class="page-container">
            <div class="header">
                <h1>Laporan Nilai Ujian {test.name}</h1>
                <p style="font-size: 13px; font-weight: bold; margin: 0 0 4px;">
                    {schoolName} |
                    {
                        new Date().toLocaleString("id-ID", {
                            dateStyle: "full",
                        })
                    }
                </p>
            </div>

            <table>
                <thead>
                    <tr>
                        <th style="width: 40px;">No</th>
                        <th>Nama</th>
                        <th style="width: 100px;">Username</th>
                        <th style="width: 80px;">Kelas</th>
                        <th style="width: 80px;">Status</th>
                        <th style="width: 80px;">Nilai</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        results.map((r, idx) => (
                            <tr>
                                <td>{idx + 1}</td>
                                <td class="text-bold">{r.firstName}</td>
                                <td class="font-mono">{r.username}</td>
                                <td>{r.groupName || "-"}</td>
                                <td>
                                    {r.status === 4
                                        ? "Selesai"
                                        : r.status === 5
                                          ? "Arsip"
                                          : "Aktif"}
                                </td>
                                <td class="text-bold">
                                    {r.totalScore.toFixed(2).replace(".", ",")}
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </body>
</html>
