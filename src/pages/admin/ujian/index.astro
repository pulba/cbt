---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { tests, testUsers, testGroups, testTopicSets } from "../../../db/schema";
import { desc, sql } from "drizzle-orm";

// Fetch tests with participant count, group count, and topic set count
const allTests = await db
    .select({
        id: tests.id,
        name: tests.name,
        detail: tests.detail,
        isActive: tests.isActive,
        participantCount: sql<number>`(SELECT COUNT(*) FROM test_users WHERE test_id = tests.id)`,
        topicCount: sql<number>`(SELECT COUNT(*) FROM test_topic_sets WHERE test_id = tests.id)`,
        questionCount: sql<number>`(SELECT COALESCE(SUM(question_count), 0) FROM test_topic_sets WHERE test_id = tests.id)`,
        maxEndTime: sql<number>`(SELECT MAX(end_time) FROM test_topic_sets WHERE test_id = tests.id)`,
    })
    .from(tests)
    .orderBy(desc(tests.id));

const totalTests = allTests.length;
const activeCount = allTests.filter((t) => t.isActive).length;
---

<AdminLayout title="Ujian">
    <!-- Page Header -->
    <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
            <h2 class="text-xl font-bold text-surface-800">Manajemen Ujian / Tes</h2>
            <p class="text-sm text-surface-500 mt-1">
                Buat jadwal ujian, atur distribusi peserta, dan awasi status aktif.
            </p>
        </div>
        <a
            href="/admin/ujian/tambah"
            class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-primary-500/30 flex-shrink-0"
        >
            <i class="icon-plus w-4 h-4"></i> Buat Ujian Baru
        </a>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-white border border-surface-200 rounded-xl p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center text-primary-600">
                <i class="icon-file-text w-5 h-5"></i>
            </div>
            <div>
                <div class="text-2xl font-black text-surface-800">{totalTests}</div>
                <div class="text-xs text-surface-500 font-medium">Total Ujian</div>
            </div>
        </div>
        <div class="bg-white border border-surface-200 rounded-xl p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                <i class="icon-toggle-right w-5 h-5"></i>
            </div>
            <div>
                <div class="text-2xl font-black text-surface-800">{activeCount}</div>
                <div class="text-xs text-surface-500 font-medium">Sudah Aktif</div>
            </div>
        </div>
    </div>

    <!-- Data Table Container -->
    <div class="bg-white rounded-xl border border-surface-200 shadow-sm overflow-hidden flex flex-col">
        <!-- Table Header -->
        <div class="p-4 border-b border-surface-200 bg-surface-50/50 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <h3 class="text-sm font-semibold text-surface-700 flex items-center gap-2">
                <i class="icon-list w-4 h-4 text-surface-400"></i>
                Daftar Ujian
                <span class="px-1.5 py-0.5 bg-surface-200 text-surface-600 rounded text-[11px] font-bold">{totalTests}</span>
            </h3>
            <div class="relative w-full sm:w-64">
                <i class="icon-search absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-surface-400"></i>
                <input
                    type="text"
                    id="search-input"
                    placeholder="Cari nama ujian..."
                    class="w-full pl-9 pr-4 py-1.5 bg-white border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500"
                />
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm text-surface-600">
                <thead class="bg-surface-50 border-b border-surface-200 text-surface-700 font-semibold text-xs uppercase tracking-wide">
                    <tr>
                        <th class="px-5 py-3 w-12 text-center">#</th>
                        <th class="px-5 py-3">Nama Ujian</th>
                        <th class="px-5 py-3 text-center hidden md:table-cell">Blueprint</th>
                        <th class="px-5 py-3 text-center hidden md:table-cell">Peserta</th>
                        <th class="px-5 py-3 text-center hidden sm:table-cell">Status</th>
                        <th class="px-5 py-3 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody id="ujian-table-body" class="divide-y divide-surface-100">
                    {
                        allTests.length === 0 ? (
                            <tr>
                                <td colspan="6" class="px-5 py-12 text-center text-surface-400">
                                    <div class="flex flex-col items-center gap-3">
                                        <i class="icon-inbox w-10 h-10 opacity-40"></i>
                                        <div>
                                            <p class="font-medium text-surface-500">Belum ada ujian</p>
                                            <p class="text-xs mt-0.5">Silakan klik "Buat Ujian Baru" untuk memulai</p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        ) : (
                            allTests.map((test) => {
                                const isActive = test.participantCount > 0;
                
                                return (
                                    <tr class="hover:bg-surface-50/50 transition-colors group" data-name={test.name.toLowerCase()}>
                                        <td class="px-5 py-4 text-center text-surface-400 font-mono text-xs">
                                            {test.id}
                                        </td>
                                        <td class="px-5 py-4">
                                            <div class="flex items-start gap-3">
                                                <div class={`mt-1.5 w-2 h-2 rounded-full flex-shrink-0 ${test.isActive ? "bg-emerald-400" : "bg-surface-300"}`} title={test.isActive ? "Status Aktif" : "Status Nonaktif"} />
                                                <div>
                                                    <a href={`/admin/ujian/blueprint/${test.id}`} class="font-bold text-surface-800 hover:text-primary-700 transition-colors">
                                                        {test.name}
                                                    </a>
                                                    {test.detail && (
                                                        <div class="text-[11px] text-surface-400 mt-0.5 line-clamp-1 max-w-xs" set:html={test.detail} />
                                                    )}
                                                    <div class="flex items-center gap-2 mt-1 md:hidden">
                                                        <span class="text-[10px] bg-surface-100 text-surface-500 px-1.5 py-0.5 rounded font-mono">
                                                            {test.topicCount} topik ({test.questionCount} soal)
                                                        </span>
                                                        <span class="text-[10px] bg-surface-100 text-surface-500 px-1.5 py-0.5 rounded">
                                                            {test.participantCount} peserta
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-center hidden md:table-cell">
                                            <div class="flex flex-col items-center gap-0.5">
                                                <span class="text-sm font-bold text-surface-700">{test.topicCount}</span>
                                                <span class="text-[10px] text-surface-400 font-medium">topik soal</span>
                                                <span class="text-[10px] text-primary-500 font-mono">({test.questionCount} soal)</span>
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-center hidden md:table-cell">
                                            <div class="flex flex-col items-center gap-0.5">
                                                {test.participantCount > 0 ? (
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-emerald-50 text-emerald-700 rounded-full text-[11px] font-semibold">
                                                        <i class="icon-check-circle w-3 h-3" />
                                                        {test.participantCount} aktif
                                                    </span>
                                                ) : (
                                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-surface-100 text-surface-400 rounded-full text-[11px] font-semibold">
                                                        <i class="icon-clock w-3 h-3" />
                                                        Belum ada
                                                    </span>
                                                )}
                                            </div>
                                        </td>
                                        <td class="px-5 py-4 text-center hidden sm:table-cell">
                                            {test.isActive ? (
                                                <span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 border border-emerald-200 rounded-lg text-[10px] font-bold uppercase">
                                                    Aktif
                                                </span>
                                            ) : (
                                                <span class="px-2 py-0.5 bg-surface-100 text-surface-400 border border-surface-200 rounded-lg text-[10px] font-bold uppercase">
                                                    Nonaktif
                                                </span>
                                            )}
                                        </td>
                                        <td class="px-4 py-4">
                                            <div class="flex items-center justify-center gap-1">
                                                <!-- Konfigurasi (Blueprint & Settings) -->
                                                <a
                                                    href={`/admin/ujian/blueprint/${test.id}`}
                                                    title="Konfigurasi Ujian: Atur Topik, Grup, & Aturan"
                                                    class="h-8 px-2.5 rounded-lg text-indigo-600 bg-indigo-50 hover:bg-indigo-100 border border-indigo-200/50 transition flex items-center justify-center gap-1.5 text-xs font-medium"
                                                >
                                                    <i class="icon-settings w-3.5 h-3.5"></i>
                                                    <span class="hidden lg:inline">Konfigurasi</span>
                                                </a>

                                                <!-- Toggle Status -->
                                                {(() => {
                                                    const maxTime = test.maxEndTime;
                                                    const normalizedEndTime = maxTime ? (maxTime < 10000000000 ? maxTime * 1000 : maxTime) : null;
                                                    const isExpired = normalizedEndTime && (Date.now() > normalizedEndTime);
                                                    return (
                                                        <button
                                                            onclick={`toggleStatus(${test.id}, ${test.isActive ? 1 : 0}, ${isExpired ? 1 : 0})`}
                                                            title={test.isActive ? "Klik untuk Nonaktifkan" : (isExpired ? "Jadwal sudah berakhir! Atur ulang jadwal di Blueprint sebelum mengaktifkan." : "Klik untuk Aktifkan")}
                                                            class={`h-8 px-2.5 rounded-lg border transition flex items-center justify-center gap-1.5 text-xs font-medium ${
                                                                test.isActive 
                                                                ? "text-emerald-600 bg-emerald-50 hover:bg-emerald-100 border-emerald-200/50" 
                                                                : (isExpired ? "text-danger bg-rose-50 border-rose-200/50 opacity-60" : "text-surface-600 bg-surface-50 hover:bg-surface-100 border-surface-200/50")
                                                            }`}
                                                        >
                                                            <i class={test.isActive ? "icon-toggle-right w-3.5 h-3.5" : "icon-toggle-left w-3.5 h-3.5"}></i>
                                                            <span class="hidden lg:inline">{test.isActive ? "Aktif" : "Nonaktif"}</span>
                                                        </button>
                                                    );
                                                })()}

                                                <!-- Reset Sesi (only when has participants) -->
                                                {test.participantCount > 0 && (
                                                    <button
                                                        title={`Reset ${test.participantCount} sesi peserta — ujian bisa dikerjakan ulang`}
                                                        onclick={`resetSesiUjian(${test.id}, ${test.participantCount})`}
                                                        class="h-8 px-2.5 rounded-lg text-orange-600 bg-orange-50 hover:bg-orange-100 border border-orange-200/50 transition flex items-center justify-center gap-1.5 text-xs font-medium"
                                                    >
                                                        <i class="icon-rotate-ccw w-3.5 h-3.5"></i>
                                                        <span class="hidden lg:inline">Reset</span>
                                                    </button>
                                                )}

                                                <div class="w-px h-5 bg-surface-200 mx-0.5" />



                                                <!-- Delete -->
                                                <button
                                                    title="Hapus Ujian"
                                                    class="w-8 h-8 rounded-lg text-surface-400 hover:text-danger hover:bg-danger/10 transition flex items-center justify-center"
                                                    onclick={`deleteTest(${test.id})`}
                                                >
                                                    <i class="icon-trash-2 w-4 h-4"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                );
                            })
                        )
                    }
                </tbody>
            </table>
        </div>

        <!-- Legend -->
        <div class="px-5 py-3 bg-surface-50 border-t border-surface-200 flex flex-wrap items-center gap-x-6 gap-y-1.5 text-xs text-surface-400">
            <span class="flex items-center gap-1.5">
                <i class="icon-settings w-3.5 h-3.5 text-indigo-500"></i>
                <strong class="text-surface-600">Konfigurasi</strong> — Atur topik, grup peserta, & aturan ujian
            </span>
            <span class="flex items-center gap-1.5">
                <i class="icon-toggle-right w-3.5 h-3.5 text-emerald-500"></i>
                <strong class="text-surface-600">Status</strong> — Aktifkan atau Nonaktifkan ujian
            </span>
            <span class="flex items-center gap-1.5">
                <i class="icon-rotate-ccw w-3.5 h-3.5 text-orange-500"></i>
                <strong class="text-surface-600">Reset</strong> — Hapus sesi agar bisa dikerjakan ulang
            </span>
        </div>
    </div>
</AdminLayout>

<script>
    // Toggle Status function
    (window as any).toggleStatus = async (id: number, currentStatus: boolean, isExpired: boolean) => {
        if (!currentStatus && isExpired) {
            alert("⚠️ JADWAL SUDAH BERAKHIR\n\nUjian ini tidak bisa diaktifkan kembali karena masa berlakunya sudah habis. Silakan atur ulang jadwal (Begin Time & End Time) di bagian Blueprint terlebih dahulu.");
            return;
        }

        try {
            const btn = event?.currentTarget as HTMLButtonElement;
            if (btn) btn.disabled = true;

            const res = await fetch("/api/ujian", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id, action: "toggle_status" }),
            });
            const data = await res.json();
            if (data.status === 1) {
                window.location.reload();
            } else {
                alert("Gagal mengubah status: " + (data.message || "Server error"));
                if (btn) btn.disabled = false;
            }
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };

    // Global delete function
    (window as any).deleteTest = async (id: number) => {
        if (
            !confirm(
                "Mohon Perhatian: Menghapus ujian akan menghapus seluruh data nilai siswa dan riwayat pengerjaan yang terhubung dengan ujian ini. Yakin lanjutkan?",
            )
        )
            return;

        try {
            const res = await fetch("/api/ujian", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id }),
            });
            const data = await res.json();
            if (data.status === 1) {
                window.location.reload();
            } else {
                alert("Gagal menghapus ujian: " + (data.message || "Server error"));
            }
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };

    // Reset all participant sessions for an exam
    (window as any).resetSesiUjian = async (id: number, count: number) => {
        if (
            !confirm(
                `⚠️ PERINGATAN RESET UJIAN\n\nAnda akan menghapus ${count} sesi peserta dari ujian ini.\n\nSeluruh data jawaban peserta AKAN DIHAPUS PERMANEN dan siswa harus mengerjakan ulang dari awal.\n\nLanjutkan?`,
            )
        )
            return;

        try {
            const btn = event?.target as HTMLButtonElement;
            if (btn) btn.disabled = true;

            const res = await fetch("/api/ujian", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id, action: "reset_sessions" }),
            });
            const data = await res.json();
            if (data.status === 1) {
                // Show success toast then reload
                const toast = document.createElement("div");
                toast.className = "fixed bottom-4 right-4 bg-orange-600 text-white px-5 py-3 rounded-lg shadow-lg flex items-center gap-3 z-50 text-sm font-medium";
                toast.innerHTML = `<i class="icon-check-circle w-4 h-4"></i><span>${data.message}</span>`;
                document.body.appendChild(toast);
                setTimeout(() => { toast.remove(); window.location.reload(); }, 2500);
            } else {
                alert("Gagal mereset: " + (data.message || "Server error"));
                if (btn) btn.disabled = false;
            }
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };

    // Client-side search
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    searchInput?.addEventListener("input", (e) => {
        const text = (e.target as HTMLInputElement).value.toLowerCase();
        const rows = document.querySelectorAll<HTMLTableRowElement>("#ujian-table-body tr[data-name]");
        rows.forEach((row) => {
            const name = row.dataset.name || "";
            row.style.display = name.includes(text) ? "" : "none";
        });
    });
</script>
