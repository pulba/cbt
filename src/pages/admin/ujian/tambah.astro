---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Tambah Ujian Baru">
    <div class="mb-6">
        <nav class="flex text-sm text-surface-500 mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-2">
                <li class="inline-flex items-center">
                    <a
                        href="/admin/ujian"
                        class="hover:text-primary-600 transition-colors"
                        >Ujian</a
                    >
                </li>
                <li>
                    <div class="flex items-center">
                        <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                        <span class="text-surface-700 font-medium"
                            >Buat Baru</span
                        >
                    </div>
                </li>
            </ol>
        </nav>
        <h2 class="text-xl font-bold text-surface-800 flex items-center">
            <a
                href="/admin/ujian"
                class="mr-3 p-1.5 rounded-lg hover:bg-surface-100 transition-colors text-surface-500 hover:text-surface-700"
            >
                <i class="icon-arrow-left w-5 h-5"></i>
            </a>
            Tambah Ujian Baru
        </h2>
    </div>

    <!-- Add Quill CSS & JS for the modal -->
    <link
        href="https://cdn.quilljs.com/1.3.7/quill.snow.css"
        rel="stylesheet"
    />
    <script is:inline src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

    <div
        class="bg-white rounded-xl border border-surface-200 shadow-sm overflow-hidden p-6 max-w-4xl max-w-5xl"
    >
        <form id="tambah-form" class="space-y-6">
            <div
                id="error-alert"
                class="hidden bg-rose-50 border border-rose-200 text-rose-700 px-4 py-3 rounded-lg flex items-start gap-3"
            >
                <i class="icon-alert-circle w-5 h-5 flex-shrink-0 mt-0.5"></i>
                <div class="text-sm">
                    <strong class="font-semibold block mb-1"
                        >Gagal menyimpan ujian</strong
                    >
                    <span id="error-msg"></span>
                </div>
            </div>

            <!-- Bagian 1: Identitas Tes -->
            <div class="bg-surface-50 p-5 rounded-lg border border-surface-200">
                <h3
                    class="font-bold text-surface-800 mb-4 border-b border-surface-200 pb-2"
                >
                    1. Identitas Ujian & Waktu
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label
                            for="name"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Nama Ujian <span class="text-danger">*</span
                            ></label
                        >
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Contoh: Penilaian Tengah Semester Ganjil 2026"
                            class="w-full px-4 py-2.5 bg-white border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800"
                        />
                    </div>
                </div>
            </div>

            <!-- Bagian 2: Penilaian & Aturan -->
            <div class="bg-surface-50 p-5 rounded-lg border border-surface-200">
                <h3
                    class="font-bold text-surface-800 mb-4 border-b border-surface-200 pb-2"
                >
                    2. Sistem Penilaian & Aturan
                </h3>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-6">
                    <div>
                        <label
                            for="maxScore"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Skala Nilai Maksimal</label
                        >
                        <input
                            type="number"
                            step="0.1"
                            id="maxScore"
                            name="maxScore"
                            value="100"
                            class="w-full px-4 py-2.5 bg-primary-50 border border-primary-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-primary-900 font-bold"
                        />
                        <p class="text-[10px] text-surface-400 mt-1">Nilai tertinggi yang bisa didapat.</p>
                    </div>
                    <div>
                        <label
                            for="scoreRight"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Poin Benar (Mentah)</label
                        >
                        <input
                            type="number"
                            step="0.1"
                            id="scoreRight"
                            name="scoreRight"
                            value="1"
                            class="w-full px-4 py-2.5 bg-white border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800 font-mono"
                        />
                    </div>
                    <div>
                        <label
                            for="scoreWrong"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Poin Salah</label
                        >
                        <input
                            type="number"
                            step="0.1"
                            id="scoreWrong"
                            name="scoreWrong"
                            value="0"
                            class="w-full px-4 py-2.5 bg-white border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800 font-mono"
                        />
                    </div>
                    <div>
                        <label
                            for="scoreUnanswered"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Poin Kosong</label
                        >
                        <input
                            type="number"
                            step="0.1"
                            id="scoreUnanswered"
                            name="scoreUnanswered"
                            value="0"
                            class="w-full px-4 py-2.5 bg-white border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800 font-mono"
                        />
                    </div>
                </div>

                <div class="flex flex-wrap gap-x-8 gap-y-4">

                    <label class="relative flex cursor-pointer items-center">
                        <input
                            type="checkbox"
                            id="showResult"
                            name="showResult"
                            class="peer sr-only"
                        />
                        <div
                            class="h-6 w-11 rounded-full bg-surface-200 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-surface-300 after:bg-white after:transition-all after:content-[''] peer-checked:bg-primary-600 peer-checked:after:translate-x-full peer-checked:after:border-white peer-focus:outline-none focus:ring-4 focus:ring-primary-500/20 disabled:cursor-not-allowed disabled:bg-surface-100 disabled:after:bg-surface-50"
                        >
                        </div>
                        <span class="ml-3 text-sm font-medium text-surface-700"
                            >Tampilkan Nilai ke Siswa</span
                        >
                    </label>

                    <label class="relative flex cursor-pointer items-center">
                        <input
                            type="checkbox"
                            id="showDetail"
                            name="showDetail"
                            class="peer sr-only"
                        />
                        <div
                            class="h-6 w-11 rounded-full bg-surface-200 after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-surface-300 after:bg-white after:transition-all after:content-[''] peer-checked:bg-primary-600 peer-checked:after:translate-x-full peer-checked:after:border-white peer-focus:outline-none focus:ring-4 focus:ring-primary-500/20 disabled:cursor-not-allowed disabled:bg-surface-100 disabled:after:bg-surface-50"
                        >
                        </div>
                        <span class="ml-3 text-sm font-medium text-surface-700"
                            >Tampilkan Detail Jawaban (Pembahasan)</span
                        >
                    </label>
                </div>
            </div>

            <!-- Bagian 3: Instruksi Tes -->
            <div>
                <label class="block text-sm font-medium text-surface-700 mb-1.5"
                    >Instruksi / Pengantar Ujian (Opsional)</label
                >
                <div
                    class="bg-surface-50 border border-surface-200 rounded-t-lg border-b-0"
                    id="toolbar-container"
                >
                    <span class="ql-formats">
                        <button class="ql-bold"></button>
                        <button class="ql-italic"></button>
                        <button class="ql-underline"></button>
                    </span>
                    <span class="ql-formats">
                        <button class="ql-list" value="ordered"></button>
                        <button class="ql-list" value="bullet"></button>
                    </span>
                    <span class="ql-formats">
                        <button class="ql-link"></button>
                        <button class="ql-image"></button>
                    </span>
                </div>
                <div
                    id="editor-container"
                    class="bg-white min-h-[150px] rounded-b-lg text-base"
                >
                </div>
                <p class="text-xs text-surface-500 mt-2">
                    Dapat diisi instruksi cara pengerjaan, pedoman larangan
                    mencontek, atau gambar logo selamat datang.
                </p>
            </div>

            <div
                class="pt-4 border-t border-surface-200 flex justify-end gap-3"
            >
                <a
                    href="/admin/ujian"
                    class="px-5 py-2.5 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition"
                >
                    Batal
                </a>
                <button
                    type="submit"
                    id="submit-btn"
                    class="px-5 py-2.5 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-primary-500/30 flex items-center justify-center disabled:opacity-70 disabled:cursor-not-allowed"
                >
                    <span id="btn-text">Simpan & Lanjutkan</span>
                    <div
                        id="btn-spinner"
                        class="hidden ml-2 w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"
                    >
                    </div>
                </button>
            </div>
        </form>
    </div>
</AdminLayout>

<script>
    // Initialize simple Quill editor for instructions
    const quill = new (window as any).Quill("#editor-container", {
        modules: {
            toolbar: "#toolbar-container",
        },
        placeholder: "Ketikkan pengantar sesi ujian di sini...",
        theme: "snow",
    });

    const form = document.getElementById("tambah-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const errorAlert = document.getElementById("error-alert");
    const errorMsg = document.getElementById("error-msg");

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (errorAlert) errorAlert.classList.add("hidden");

        // Get Form Data
        const formData = new FormData(form);
        const submitData = {
            name: formData.get("name"),
            scoreRight: parseFloat(formData.get("scoreRight") as string) || 1,
            scoreWrong: parseFloat(formData.get("scoreWrong") as string) || 0,
            scoreUnanswered:
                parseFloat(formData.get("scoreUnanswered") as string) || 0,
            maxScore: parseFloat(formData.get("maxScore") as string) || 100,
            showResult: formData.has("showResult"),
            showDetail: formData.has("showDetail"),
            detail:
                quill.root.innerHTML === "<p><br></p>"
                    ? ""
                    : quill.root.innerHTML,
        };

        // Loading state
        submitBtn.disabled = true;
        document.getElementById("btn-text")!.innerText = "Menyimpan...";
        document.getElementById("btn-spinner")!.classList.remove("hidden");

        try {
            const res = await fetch("/api/ujian", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(submitData),
            });
            const data = await res.json();

            if (!data.status) {
                if (errorAlert && errorMsg) {
                    errorMsg.innerText =
                        data.message || "Penyimpanan ditolak oleh server.";
                    errorAlert.classList.remove("hidden");
                }
                submitBtn.disabled = false;
                document.getElementById("btn-text")!.innerText =
                    "Simpan & Lanjutkan";
                document.getElementById("btn-spinner")!.classList.add("hidden");
                return;
            }

            // Success, instantly route to blueprint config
            window.location.href = `/admin/ujian/blueprint/${data.data.id}`;
        } catch (err: any) {
            if (errorAlert && errorMsg) {
                errorMsg.innerText =
                    err.message || "Terjadi kesalahan jaringan.";
                errorAlert.classList.remove("hidden");
            }
            submitBtn.disabled = false;
            document.getElementById("btn-text")!.innerText =
                "Simpan & Lanjutkan";
            document.getElementById("btn-spinner")!.classList.add("hidden");
        }
    });
</script>
