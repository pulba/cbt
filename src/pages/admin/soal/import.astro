---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { topics } from "../../../db/schema";

const allTopics = await db.select().from(topics).all();
---

<AdminLayout title="Smart Import Soal">
    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    <script is:inline src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <!-- KaTeX for math -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.js"></script>

    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <nav
                class="flex text-sm text-surface-500 mb-2"
                aria-label="Breadcrumb"
            >
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a
                            href="/admin/soal"
                            class="hover:text-primary-600 transition-colors"
                            >Bank Soal</a
                        >
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <span class="text-surface-700 font-medium"
                                >Smart Import</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>
            <h2 class="text-xl font-bold text-surface-800">
                Smart Import Soal
            </h2>
            <p class="text-sm text-surface-500 mt-1">
                Unggah file Excel (.xlsx), Microsoft Word (.docx), atau PDF
                untuk mengekstrak pertanyaan dan jawaban otomatis.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Form -->
        <div class="lg:col-span-2 space-y-6">
            <div
                class="bg-white rounded-xl border border-surface-200 shadow-sm p-6"
            >
                <h3
                    class="font-semibold text-surface-800 mb-4 border-b border-surface-100 pb-3"
                >
                    Formulir Upload Modul
                </h3>

                <div
                    id="error-alert"
                    class="hidden mb-6 p-4 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm flex items-start"
                >
                    <i class="icon-alert-circle w-5 h-5 mr-3 shrink-0"></i>
                    <span id="error-msg">Terjadi kesalahan</span>
                </div>

                <div
                    id="success-alert"
                    class="hidden mb-6 p-4 rounded-lg bg-success/10 border border-success/20 text-success text-sm flex items-start"
                >
                    <i class="icon-check-circle w-5 h-5 mr-3 shrink-0"></i>
                    <span id="success-msg">Berhasil mengimpor soal.</span>
                </div>

                <form id="import-form" class="space-y-6">
                    <div>
                        <label
                            for="topicId"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Pilih Topik Tujuan <span class="text-danger"
                                >*</span
                            ></label
                        >
                        <select
                            id="topicId"
                            name="topicId"
                            required
                            class="w-full px-4 py-2.5 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800"
                        >
                            <option value="" disabled selected
                                >-- Pilih Mata Pelajaran / Topik --</option
                            >
                            {
                                allTopics.map((topic: any) => (
                                    <option value={topic.id}>
                                        {topic.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>

                    <!-- Jenis Soal Selector -->
                    <div>
                        <label class="block text-sm font-medium text-surface-700 mb-1.5">
                            Jenis Soal <span class="text-danger">*</span>
                        </label>
                        <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-3 mb-6" id="type-selector">
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="1" checked class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-primary-500 bg-primary-50 text-center transition-all h-full flex flex-col items-center justify-center" data-type="1">
                                    <i class="icon-list w-6 h-6 mb-1.5 text-primary-600"></i>
                                    <p class="text-xs font-bold text-primary-700">Pilihan Ganda</p>
                                    <p class="text-[10px] text-primary-500 mt-0.5">Format A/B/C/D/E</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="2" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center" data-type="2">
                                    <i class="icon-edit-3 w-6 h-6 mb-1.5 text-surface-400"></i>
                                    <p class="text-xs font-bold text-surface-600">Esai</p>
                                    <p class="text-[10px] text-surface-400 mt-0.5">Jawaban panjang</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="3" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center" data-type="3">
                                    <i class="icon-pen-tool w-6 h-6 mb-1.5 text-surface-400"></i>
                                    <p class="text-xs font-bold text-surface-600">Jawaban Singkat</p>
                                    <p class="text-[10px] text-surface-400 mt-0.5">Satu baris/kata</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="4" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center" data-type="4">
                                    <i class="icon-link w-6 h-6 mb-1.5 text-surface-400"></i>
                                    <p class="text-xs font-bold text-surface-600">Menjodohkan</p>
                                    <p class="text-[10px] text-surface-400 mt-0.5">Pasangan Kiri-Kanan</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="5" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center" data-type="5">
                                    <i class="icon-check-square w-6 h-6 mb-1.5 text-surface-400"></i>
                                    <p class="text-xs font-bold text-surface-600">Ceklis</p>
                                    <p class="text-[10px] text-surface-400 mt-0.5">Banyak Jawaban Benar</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="6" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center" data-type="6">
                                    <i class="icon-toggle-right w-6 h-6 mb-1.5 text-surface-400"></i>
                                    <p class="text-xs font-bold text-surface-600">Benar/Salah</p>
                                    <p class="text-[10px] text-surface-400 mt-0.5">Format Pernyataan</p>
                                </div>
                            </label>
                            <label class="type-option cursor-pointer">
                                <input type="radio" name="questionType" value="7" class="sr-only" />
                                <div class="type-card p-3 rounded-xl border-2 border-surface-200 bg-white text-center transition-all h-full flex flex-col items-center justify-center border-indigo-200 bg-indigo-50" data-type="7">
                                    <i class="icon-layers w-6 h-6 mb-1.5 text-indigo-500"></i>
                                    <p class="text-xs font-bold text-indigo-700">TKA / Campur</p>
                                    <p class="text-[10px] text-indigo-500 mt-0.5">Berisi 6 Format TKA</p>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Essay Config (shows when type 2 or 3) -->
                    <div id="essay-config-section" class="hidden bg-indigo-50 border border-indigo-200 rounded-xl p-5 space-y-4">
                        <div class="flex items-center gap-2 mb-1">
                            <i class="icon-settings w-4 h-4 text-indigo-500"></i>
                            <h4 class="text-sm font-bold text-indigo-800">Konfigurasi Penilaian Esai</h4>
                        </div>
                        <p class="text-xs text-indigo-600 -mt-2">Konfigurasi ini akan diterapkan ke <strong>semua</strong> soal esai yang diimport dari file ini.</p>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="gradingMode" class="block text-xs font-semibold text-indigo-800 mb-1.5">Mode Penilaian</label>
                                <select id="gradingMode" name="gradingMode"
                                    class="w-full px-3 py-2 bg-white border border-indigo-200 rounded-lg text-sm focus:ring-indigo-400/30 focus:border-indigo-400">
                                    <option value="manual">Manual — Guru koreksi langsung</option>
                                    <option value="keyword">Keyword — Otomatis (kata kunci)</option>
                                    <option value="hybrid">Hybrid — Keyword + kemiripan teks</option>
                                </select>
                            </div>
                            <div>
                                <label for="essayMaxScore" class="block text-xs font-semibold text-indigo-800 mb-1.5">Skor Maks per Soal</label>
                                <input type="number" id="essayMaxScore" name="essayMaxScore" value="100" min="1" max="1000"
                                    class="w-full px-3 py-2 bg-white border border-indigo-200 rounded-lg text-sm focus:ring-indigo-400/30 focus:border-indigo-400" />
                            </div>
                        </div>

                        <p class="text-[11px] text-indigo-500">
                            <i class="icon-info w-3 h-3 inline-block mr-1"></i>
                            Kata kunci spesifik dapat ditambahkan nanti per-soal via menu <strong>Edit Soal</strong> setelah import.
                        </p>
                    </div>

                    <!-- Mode Tab Selector -->
                    <div>
                        <label class="block text-sm font-medium text-surface-700 mb-2">Mode Input Soal <span class="text-danger">*</span></label>
                        <div class="flex rounded-lg border border-surface-200 overflow-hidden mb-4" id="mode-tabs">
                            <button type="button" data-mode="paste" class="mode-tab flex-1 px-4 py-2.5 text-sm font-semibold transition-all bg-primary-600 text-white flex items-center justify-center gap-2">
                                <i class="icon-clipboard w-4 h-4"></i> Smart Paste
                            </button>
                            <button type="button" data-mode="file" class="mode-tab flex-1 px-4 py-2.5 text-sm font-semibold transition-all bg-white text-surface-600 hover:bg-surface-50 flex items-center justify-center gap-2">
                                <i class="icon-upload-cloud w-4 h-4"></i> Upload File
                            </button>
                        </div>
                    </div>

                    <!-- MODE 1: Smart Paste Canvas -->
                    <div id="paste-mode" class="space-y-3">
                        <div class="p-3 bg-amber-50 border border-amber-200 rounded-lg text-amber-800 text-xs flex items-start gap-2">
                            <i class="icon-info w-4 h-4 shrink-0 mt-0.5 text-amber-600"></i>
                            <div>
                                <strong>Cara Pakai:</strong> Buka file Word Anda, blok semua soal (Ctrl+A), salin (Ctrl+C), lalu tempelkan (Ctrl+V) ke kotak editor di bawah. Gambar yang ikut di-paste akan otomatis tersimpan.
                                <br/><span class="text-amber-600 font-medium">Tips: Perkecil ukuran gambar sebelum paste agar database tidak membengkak.</span>
                            </div>
                        </div>
                        <div class="bg-surface-50 border border-surface-200 rounded-t-lg border-b-0" id="paste-toolbar">
                            <span class="ql-formats">
                                <button class="ql-bold"></button>
                                <button class="ql-italic"></button>
                                <button class="ql-underline"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-script" value="sub"></button>
                                <button class="ql-script" value="super"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-list" value="ordered"></button>
                                <button class="ql-list" value="bullet"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-image"></button>
                                <button class="ql-formula"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-clean"></button>
                            </span>
                        </div>
                        <div id="paste-editor" class="bg-white min-h-[280px] rounded-b-lg text-sm border border-surface-200 border-t-0"></div>
                        <p class="text-[11px] text-surface-400 flex items-center gap-1">
                            <i class="icon-info w-3 h-3"></i>
                            Pastikan format soal sesuai panduan di panel sebelah kanan sebelum klik Mulai Ekstraksi.
                        </p>
                    </div>

                    <!-- MODE 2: File Upload (for xlsx, pdf) -->
                    <div id="file-mode" class="hidden space-y-3">
                        <div
                            class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-surface-300 border-dashed rounded-xl hover:bg-surface-50 transition relative group"
                            id="drop-zone"
                        >
                            <div class="space-y-2 text-center">
                                <i class="icon-upload-cloud items-center mx-auto text-surface-400 w-10 h-10 mb-3 block group-hover:text-primary-500 transition-colors"></i>
                                <div class="flex flex-col items-center text-sm text-surface-600">
                                    <label
                                        for="file-upload"
                                        class="relative cursor-pointer bg-white rounded-md font-medium text-primary-600 hover:text-primary-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-primary-500 px-3 py-1 border border-primary-200"
                                    >
                                        <span>Telusuri File</span>
                                        <input id="file-upload" name="file" type="file" class="sr-only" accept=".xlsx,.xls,.pdf" />
                                    </label>
                                    <p class="pl-1 mt-2">atau seret dan lepas file ke sini</p>
                                </div>
                                <p class="text-xs text-surface-500">Excel (.xlsx) atau PDF hingga 10MB.</p>
                            </div>
                        </div>
                        <div id="file-name-display" class="text-sm font-medium text-primary-600 hidden flex items-center bg-primary-50 px-3 py-2 rounded-lg border border-primary-100">
                            <i class="icon-file-text w-4 h-4 mr-2"></i>
                            <span id="file-name-text">filename.xlsx</span>
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button
                            type="submit"
                            id="submit-btn"
                            class="px-6 py-2.5 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition-colors flex items-center shadow-md shadow-primary-500/20 w-full sm:w-auto justify-center"
                        >
                            <i class="icon-play w-4 h-4 mr-2"></i> Mulai Ekstraksi &amp; Import
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Instructions Panel -->
        <div class="space-y-6">
            <div
                class="bg-primary-50 rounded-xl border border-primary-100 p-5 shadow-sm text-primary-900"
            >
                <div class="flex items-center gap-4 mb-3 border-b border-primary-200/50 pb-2">
                     <div class="font-bold flex items-center text-primary-700 border-b-2 border-primary-600 pb-2 -mb-[9px]">
                        <i class="icon-file-text w-4 h-4 mr-2"></i> Format File
                     </div>
                </div>

                <!-- TAB 1: FORMAT FILE -->
                <div id="tab-format" class="tab-content space-y-4 text-sm leading-relaxed text-primary-800/80">
                    <div id="format-pg">
                        <strong
                            class="font-semibold text-primary-900 block mb-1"
                            >Format Word / PDF — Pilihan Ganda</strong
                        >
                        Gunakan nomor (1., 2.) untuk Soal dan Huruf kapital (A., B., C., D., E.) untuk
                        opsi jawaban. Akhiri soal dengan Kunci Jawaban.<br />
                        <div
                            class="bg-white p-3 rounded-lg mt-2 border border-primary-200 font-mono text-xs opacity-90 text-surface-700"
                        >
                            1. Siapakah presiden pertama Indonesia?<br />
                            A. Ir. Soekarno<br />
                            B. B.J. Habibie<br />
                            C. Joko Widodo<br />
                            D. Megawati Soekarnoputri<br />
                            E. Susilo Bambang Yudhoyono<br />
                            Kunci Jawaban: A
                        </div>
                    </div>

                    <div id="format-essay" class="hidden">
                        <strong class="font-semibold text-primary-900 block mb-1">Format Word / PDF — Esai / Jawaban Singkat</strong>
                        Cukup tulis nomor dan teks soal. Tidak perlu opsi A/B/C/D. Satu baris = satu soal (atau paragraf terpisah).<br />
                        <div class="bg-white p-3 rounded-lg mt-2 border border-primary-200 font-mono text-xs opacity-90 text-surface-700">
                            1. Jelaskan proses fotosintesis dan faktor yang mempengaruhinya!<br /><br />
                            2. Apa yang dimaksud dengan ekosistem?<br /><br />
                            3. Sebutkan tiga fungsi utama hutan hujan tropis!
                        </div>
                        <div class="mt-2 p-2 bg-amber-50 border border-amber-200 rounded-lg text-amber-700 text-[11px]">
                            <i class="icon-alert-triangle w-3.5 h-3.5 inline-block mr-1"></i>
                            Untuk soal esai, sistem hanya mengekstrak teks pertanyaan. Kata kunci penilaian dapat ditambahkan per-soal setelah import.
                        </div>
                    </div>

                    <div id="format-matching" class="hidden">
                        <strong class="font-semibold text-primary-900 block mb-1">Format Word / PDF — Menjodohkan</strong>
                        Tulis nomor soal lalu setiap pasangan diawali dengan <code class="bg-white px-1 border border-primary-200 rounded text-[11px]">PASANGAN:</code> diikuti format <code class="bg-white px-1 border border-primary-200 rounded text-[11px]">Kiri = Kanan = Bobot</code>.<br />
                        <div class="bg-white p-3 rounded-lg mt-2 border border-primary-200 font-mono text-xs opacity-90 text-surface-700">
                            1. Pasangkan nama ibukota negara berikut:<br />
                            PASANGAN: Ibukota Indonesia = Jakarta = 10<br />
                            PASANGAN: 2 + 2 = 4 = 10<br />
                            PASANGAN: Planet terbesar = Jupiter = 10<br /><br />
                            2. Jodohkan unsur kimia dengan simbolnya:<br />
                            PASANGAN: Emas = Au = 10<br />
                            PASANGAN: Besi = Fe = 10
                        </div>
                        <div class="mt-2 p-2 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-700 text-[11px]">
                            <i class="icon-info w-3.5 h-3.5 inline-block mr-1"></i>
                            Format Excel: Kolom A=No, B=Jenis (SOAL/PASANGAN), C=Isi Kiri, D=Isi Kanan, E=Bobot
                        </div>
                    </div>

                    <div id="format-ceklis" class="hidden">
                        <strong class="font-semibold text-primary-900 block mb-1">Format Word / PDF — Ceklis (Banyak Jawaban)</strong>
                        Mirip seperti pilihan ganda, namun pada Kunci Jawaban isi dengan lebih dari satu angka koma (Kunci: 1,3,4) atau (Kunci Jawaban: 1, 3, 4).<br />
                        <div class="bg-white p-3 rounded-lg mt-2 border border-primary-200 font-mono text-xs opacity-90 text-surface-700">
                            1. Manakah dari hewan berikut yang termasuk mamalia?<br />
                            1. Sapi<br />
                            2. Ayam<br />
                            3. Paus<br />
                            4. Ular<br />
                            Kunci Jawaban: 1, 3
                        </div>
                        <div class="mt-2 p-2 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-700 text-[11px]">
                            <i class="icon-info w-3.5 h-3.5 inline-block mr-1"></i>
                            Gunakan angka (1., 2., 3., 4.) untuk opsi jawaban, bukan abjad.
                        </div>
                    </div>

                    <div id="format-benarsalah" class="hidden">
                        <strong class="font-semibold text-primary-900 block mb-1">Format Word / PDF — Benar/Salah</strong>
                        Cukup tulis nomor, pertanyaan, lalu beri "Kunci Jawaban: Benar" atau "Kunci Jawaban: Salah".<br />
                        <div class="bg-white p-3 rounded-lg mt-2 border border-primary-200 font-mono text-xs opacity-90 text-surface-700">
                            1. Ibukota Indonesia adalah Jakarta.<br />
                            Kunci Jawaban: Benar<br /><br />
                            2. Matahari mengelilingi Bumi.<br />
                            Kunci Jawaban: Salah
                        </div>
                    </div>

                    <div class="pt-3 border-t border-primary-200/50">
                        <strong class="font-semibold text-primary-900 block mb-2 text-xs">Unduh Template Kosongan:</strong>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                            <a
                                href="/templates/Form Import Soal.docx"
                                download
                                class="text-primary-700 font-bold text-xs flex items-center justify-center bg-white hover:bg-primary-100 border border-primary-200 p-2.5 rounded-lg transition-colors shadow-sm"
                            >
                                <i class="icon-download w-4 h-4 mr-1.5 text-primary-500"></i> Template Pilihan Ganda
                            </a>
                            <a
                                href="/templates/Template-Soal-Esai.docx"
                                download
                                class="text-surface-700 font-bold text-xs flex items-center justify-center bg-white hover:bg-surface-100 border border-surface-200 p-2.5 rounded-lg transition-colors shadow-sm"
                            >
                                <i class="icon-file-text w-4 h-4 mr-1.5 text-surface-400"></i> Template Esai
                            </a>
                            <a
                                href="/templates/Template-Soal-Menjodohkan.xlsx"
                                download
                                id="template-matching-btn"
                                class="hidden text-emerald-700 font-bold text-xs flex items-center justify-center bg-white hover:bg-emerald-50 border border-emerald-300 p-2.5 rounded-lg transition-colors shadow-sm"
                            >
                                <i class="icon-link w-4 h-4 mr-1.5 text-emerald-500"></i> Template Menjodohkan (.xlsx)
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    // ─── Globals ───
    const form = document.getElementById("import-form") as HTMLFormElement;
    const fileInput = document.getElementById("file-upload") as HTMLInputElement;
    const fileNameDisplay = document.getElementById("file-name-display");
    const fileNameText = document.getElementById("file-name-text");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const errorAlert = document.getElementById("error-alert");
    const errorMsg = document.getElementById("error-msg");
    const successAlert = document.getElementById("success-alert");
    const successMsg = document.getElementById("success-msg");
    const dropZone = document.getElementById("drop-zone");
    const essayConfigSection = document.getElementById("essay-config-section");
    const formatPg = document.getElementById("format-pg");
    const formatEssay = document.getElementById("format-essay");
    const formatMatching = document.getElementById("format-matching");
    const formatCeklis = document.getElementById("format-ceklis");
    const formatBenarSalah = document.getElementById("format-benarsalah");
    const templateMatchingBtn = document.getElementById("template-matching-btn");

    // ─── Mode Tab Logic ───
    let currentMode = 'paste'; // 'paste' or 'file'
    const pasteMode = document.getElementById('paste-mode');
    const fileMode = document.getElementById('file-mode');
    const modeTabs = document.querySelectorAll('.mode-tab');

    modeTabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const mode = (tab as HTMLElement).dataset.mode!;
            currentMode = mode;
            modeTabs.forEach(t => {
                const isActive = (t as HTMLElement).dataset.mode === mode;
                t.classList.toggle('bg-primary-600', isActive);
                t.classList.toggle('text-white', isActive);
                t.classList.toggle('bg-white', !isActive);
                t.classList.toggle('text-surface-600', !isActive);
            });
            if (pasteMode) pasteMode.classList.toggle('hidden', mode !== 'paste');
            if (fileMode) fileMode.classList.toggle('hidden', mode !== 'file');
        });
    });

    // ─── Initialize Quill (Smart Paste Editor) ───
    (window as any).katex = (window as any).katex;
    const quill = new (window as any).Quill('#paste-editor', {
        modules: {
            toolbar: '#paste-toolbar',
        },
        placeholder: 'Tempelkan (Ctrl+V) soal dari Microsoft Word di sini...\n\n1. Siapakah presiden pertama Indonesia?\nA. Ir. Soekarno\nB. B.J. Habibie\n...',
        theme: 'snow',
    });

    // ─── Type Selector Logic ───
    const typeCards = document.querySelectorAll('.type-card');
    const typeInputs = document.querySelectorAll('input[name="questionType"]');

    function updateTypeUI(selectedVal: string) {
        typeCards.forEach((card) => {
            const cardType = card.getAttribute('data-type');
            const isSelected = cardType === selectedVal;
            card.classList.toggle('border-primary-500', isSelected && (selectedVal === '1' || selectedVal === '5' || selectedVal === '6'));
            card.classList.toggle('bg-primary-50', isSelected && (selectedVal === '1' || selectedVal === '5' || selectedVal === '6'));
            card.querySelector('i')?.classList.toggle('text-primary-600', isSelected && (selectedVal === '1' || selectedVal === '5' || selectedVal === '6'));
            card.querySelector('i')?.classList.toggle('text-surface-400', !(isSelected && (selectedVal === '1' || selectedVal === '5' || selectedVal === '6')));
            
            card.classList.toggle('border-emerald-500', isSelected && selectedVal === '4');
            card.classList.toggle('bg-emerald-50', isSelected && selectedVal === '4');
            if (selectedVal === '4') {
                card.querySelector('i')?.classList.toggle('text-emerald-500', isSelected);
                card.querySelector('i')?.classList.toggle('text-surface-400', !isSelected);
            }
            
            card.classList.toggle('border-indigo-500', isSelected && (selectedVal === '2' || selectedVal === '3' || selectedVal === '7'));
            card.classList.toggle('bg-indigo-50', isSelected && (selectedVal === '2' || selectedVal === '3' || selectedVal === '7'));
            if (selectedVal === '2' || selectedVal === '3' || selectedVal === '7') {
                card.querySelector('i')?.classList.toggle('text-indigo-500', isSelected);
                card.querySelector('i')?.classList.toggle('text-surface-400', !isSelected);
            }
            
            card.classList.toggle('border-surface-200', !isSelected);
            card.classList.toggle('bg-white', !isSelected);
        });

        const isEssay = selectedVal === '2' || selectedVal === '3';
        const isMatching = selectedVal === '4';
        const isCeklis = selectedVal === '5';
        const isBenarSalah = selectedVal === '6';
        const isMixed = selectedVal === '7';
        if (essayConfigSection) {
            essayConfigSection.classList.toggle('hidden', !isEssay);
        }
        if (formatPg) formatPg.classList.toggle('hidden', selectedVal !== '1');
        if (formatEssay) formatEssay.classList.toggle('hidden', !isEssay);
        if (formatMatching) formatMatching.classList.toggle('hidden', !isMatching);
        if (formatCeklis) formatCeklis.classList.toggle('hidden', !isCeklis);
        if (formatBenarSalah) formatBenarSalah.classList.toggle('hidden', !isBenarSalah);
        if (templateMatchingBtn) templateMatchingBtn.classList.toggle('hidden', !isMatching);
    }

    document.querySelectorAll('.type-option').forEach((label) => {
        label.addEventListener('click', () => {
            const input = label.querySelector('input[type="radio"]') as HTMLInputElement;
            if (input) {
                input.checked = true;
                updateTypeUI(input.value);
            }
        });
    });

    updateTypeUI('1');

    // ─── Drag and Drop (File Mode) ───
    ["dragenter", "dragover", "dragleave", "drop"].forEach((eventName) => {
        dropZone?.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e: Event) {
        e.preventDefault();
        e.stopPropagation();
    }

    ["dragenter", "dragover"].forEach((eventName) => {
        dropZone?.addEventListener(eventName, () => {
            dropZone.classList.add("border-primary-500", "bg-primary-50");
        }, false);
    });

    ["dragleave", "drop"].forEach((eventName) => {
        dropZone?.addEventListener(eventName, () => {
            dropZone.classList.remove("border-primary-500", "bg-primary-50");
        }, false);
    });

    dropZone?.addEventListener("drop", (e: DragEvent) => {
        const dt = e.dataTransfer;
        const files = dt?.files;
        if (files && files.length > 0) {
            fileInput.files = files;
            updateFileName();
        }
    }, false);

    fileInput?.addEventListener("change", updateFileName);

    function updateFileName() {
        if (fileInput.files && fileInput.files.length > 0) {
            if (fileNameDisplay && fileNameText) {
                fileNameText.textContent = fileInput.files[0].name;
                fileNameDisplay.classList.remove("hidden");
            }
        } else {
            if (fileNameDisplay) fileNameDisplay.classList.add("hidden");
        }
    }

    // ─── Form Submit ───
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (errorAlert) errorAlert.classList.add("hidden");
        if (successAlert) successAlert.classList.add("hidden");

        const isPasteMode = currentMode === 'paste';

        if (isPasteMode) {
            const editorContent = quill.root.innerHTML.trim();
            if (!editorContent || editorContent === '<p><br></p>' || editorContent === '<p></p>') {
                showError("Kotak editor masih kosong. Silakan paste/tempel soal dari Word terlebih dahulu.");
                return;
            }
        } else {
            if (!fileInput.files || fileInput.files.length === 0) {
                showError("Pilih file terlebih dahulu.");
                return;
            }
        }

        const originalHtml = submitBtn.innerHTML;
        submitBtn.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Sedang Mengekstrak...`;
        submitBtn.disabled = true;

        const formData = new FormData(form);

        const questionType = (document.querySelector('input[name="questionType"]:checked') as HTMLInputElement)?.value || '1';
        formData.set('questionType', questionType);

        if (questionType !== '1') {
            const gradingMode = (document.getElementById('gradingMode') as HTMLSelectElement)?.value || 'manual';
            const maxScore = (document.getElementById('essayMaxScore') as HTMLInputElement)?.value || '100';
            formData.set('gradingMode', gradingMode);
            formData.set('essayMaxScore', maxScore);
        }

        // If Smart Paste mode, send editor HTML instead of file
        if (isPasteMode) {
            formData.delete('file');
            formData.set('editorHtml', quill.root.innerHTML);
        }

        try {
            const res = await fetch("/api/soal/import", {
                method: "POST",
                body: formData,
            });

            const result = await res.json();

            if (result.success) {
                if (successAlert && successMsg) {
                    successMsg.textContent = result.message;
                    successAlert.classList.remove("hidden");
                }
                form.reset();
                quill.root.innerHTML = '';
                updateTypeUI('1');
                if (fileNameDisplay) fileNameDisplay.classList.add("hidden");
                const topicId = formData.get("topicId");
                setTimeout(() => {
                    window.location.href = `/admin/soal/daftar/${topicId}`;
                }, 1500);
            } else {
                showError(result.error || "Gagal memproses file");
            }
        } catch (error) {
            showError("Terjadi kesalahan jaringan atau server saat mengekstrak.");
        } finally {
            submitBtn.innerHTML = originalHtml;
            submitBtn.disabled = false;
        }
    });

    function showError(msg: string) {
        if (errorAlert && errorMsg) {
            errorMsg.textContent = msg;
            errorAlert.classList.remove("hidden");
        }
    }
</script>
