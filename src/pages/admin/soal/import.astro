---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { topics } from "../../../db/schema";

const allTopics = await db.select().from(topics).all();
---

<AdminLayout title="Smart Import Soal">
    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <nav
                class="flex text-sm text-surface-500 mb-2"
                aria-label="Breadcrumb"
            >
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a
                            href="/admin/soal"
                            class="hover:text-primary-600 transition-colors"
                            >Bank Soal</a
                        >
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <span class="text-surface-700 font-medium"
                                >Smart Import</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>
            <h2 class="text-xl font-bold text-surface-800">
                Smart Import Soal
            </h2>
            <p class="text-sm text-surface-500 mt-1">
                Unggah file Excel (.xlsx), Microsoft Word (.docx), atau PDF
                untuk mengekstrak pertanyaan dan jawaban otomatis.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Form -->
        <div class="lg:col-span-2 space-y-6">
            <div
                class="bg-white rounded-xl border border-surface-200 shadow-sm p-6"
            >
                <h3
                    class="font-semibold text-surface-800 mb-4 border-b border-surface-100 pb-3"
                >
                    Formulir Upload Modul
                </h3>

                <div
                    id="error-alert"
                    class="hidden mb-6 p-4 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm flex items-start"
                >
                    <i class="icon-alert-circle w-5 h-5 mr-3 shrink-0"></i>
                    <span id="error-msg">Terjadi kesalahan</span>
                </div>

                <div
                    id="success-alert"
                    class="hidden mb-6 p-4 rounded-lg bg-success/10 border border-success/20 text-success text-sm flex items-start"
                >
                    <i class="icon-check-circle w-5 h-5 mr-3 shrink-0"></i>
                    <span id="success-msg">Berhasil mengimpor soal.</span>
                </div>

                <form id="import-form" class="space-y-6">
                    <div>
                        <label
                            for="topicId"
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Pilih Topik Tujuan <span class="text-danger"
                                >*</span
                            ></label
                        >
                        <select
                            id="topicId"
                            name="topicId"
                            required
                            class="w-full px-4 py-2.5 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800"
                        >
                            <option value="" disabled selected
                                >-- Pilih Mata Pelajaran / Topik --</option
                            >
                            {
                                allTopics.map((topic) => (
                                    <option value={topic.id}>
                                        {topic.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>

                    <div>
                        <label
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Pilih File Modul Soal <span class="text-danger"
                                >*</span
                            ></label
                        >
                        <div
                            class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-surface-300 border-dashed rounded-xl hover:bg-surface-50 transition relative group"
                            id="drop-zone"
                        >
                            <div class="space-y-2 text-center">
                                <i
                                    class="icon-upload-cloud items-center mx-auto text-surface-400 w-10 h-10 mb-3 block group-hover:text-primary-500 transition-colors"
                                ></i>
                                <div
                                    class="flex flex-col items-center text-sm text-surface-600"
                                >
                                    <label
                                        for="file-upload"
                                        class="relative cursor-pointer bg-white rounded-md font-medium text-primary-600 hover:text-primary-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-primary-500 px-3 py-1 border border-primary-200"
                                    >
                                        <span>Telusuri File</span>
                                        <input
                                            id="file-upload"
                                            name="file"
                                            type="file"
                                            class="sr-only"
                                            accept=".xlsx,.xls,.doc,.docx,.pdf"
                                            required
                                        />
                                    </label>
                                    <p class="pl-1 mt-2">
                                        atau seret dan lepas file ke sini
                                    </p>
                                </div>
                                <p class="text-xs text-surface-500">
                                    Excel (.xlsx), Word (.docx), atau PDF hingga
                                    10MB.
                                </p>
                            </div>
                        </div>
                        <div
                            id="file-name-display"
                            class="mt-3 text-sm font-medium text-primary-600 hidden flex items-center bg-primary-50 px-3 py-2 rounded-lg border border-primary-100"
                        >
                            <i class="icon-file-text w-4 h-4 mr-2"></i>
                            <span id="file-name-text">filename.docx</span>
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button
                            type="submit"
                            id="submit-btn"
                            class="px-6 py-2.5 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition-colors flex items-center shadow-md shadow-primary-500/20 w-full sm:w-auto justify-center"
                        >
                            <i class="icon-play w-4 h-4 mr-2"></i> Mulai Ekstraksi
                            & Import
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Instructions Panel -->
        <div class="space-y-6">
            <div
                class="bg-primary-50 rounded-xl border border-primary-100 p-5 shadow-sm text-primary-900"
            >
                <h4 class="font-bold flex items-center mb-3">
                    <i class="icon-info w-5 h-5 mr-2 text-primary-600"></i>
                    Panduan Smart Import
                </h4>

                <div
                    class="space-y-4 text-sm leading-relaxed text-primary-800/80"
                >
                    <div>
                        <strong
                            class="font-semibold text-primary-900 block mb-1"
                            >A. Format Excel (.xlsx)</strong
                        >
                        Gunakan format tabel vertikal dengan 4 kolom (No | Jenis |
                        Isi | Jawaban):<br />
                        <ul
                            class="list-disc list-inside mt-1 text-xs text-primary-800/80 space-y-0.5"
                        >
                            <li>
                                <strong>Jenis:</strong> Isi dengan "SOAL" atau "JAWABAN"
                                (ke bawah berurutan).
                            </li>
                            <li>
                                <strong>Isi:</strong> Teks pertanyaan atau teks opsi
                                jawaban.
                            </li>
                            <li>
                                <strong>Jawaban:</strong> Isi angka <code
                                    class="bg-white px-1 rounded font-mono font-bold"
                                    >1</code
                                > untuk opsi yang benar, dan <code
                                    class="bg-white px-1 rounded font-mono font-bold"
                                    >0</code
                                > untuk yang salah. Kosongkan untuk baris SOAL.
                            </li>
                        </ul>
                    </div>

                    <div>
                        <strong
                            class="font-semibold text-primary-900 block mb-1"
                            >B. Format Word (.docx) / PDF</strong
                        >
                        Gunakan nomor (1., 2.) untuk Soal dan Huruf (A., B.) untuk
                        opsi. Contoh:<br />
                        <div
                            class="bg-white p-2.5 rounded-lg mt-1 border border-primary-200 font-mono text-xs opacity-90"
                        >
                            1. Siapakah presiden pertama Indonesia?<br />
                            A. Ir. Soekarno<br />
                            B. B.J. Habibie<br />
                            Kunci: A
                        </div>
                    </div>

                    <div class="pt-3 border-t border-primary-200/50">
                        <a
                            href="/templates/Template_Import_Soal.xlsx"
                            download
                            class="text-primary-600 hover:text-primary-700 font-medium text-sm flex items-center underline-offset-4 hover:underline"
                        >
                            <i class="icon-download w-4 h-4 mr-1.5"></i> Unduh Template
                            Excel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    const form = document.getElementById("import-form") as HTMLFormElement;
    const fileInput = document.getElementById(
        "file-upload",
    ) as HTMLInputElement;
    const fileNameDisplay = document.getElementById("file-name-display");
    const fileNameText = document.getElementById("file-name-text");
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const errorAlert = document.getElementById("error-alert");
    const errorMsg = document.getElementById("error-msg");
    const successAlert = document.getElementById("success-alert");
    const successMsg = document.getElementById("success-msg");
    const dropZone = document.getElementById("drop-zone");

    // Drag and drop handlers
    ["dragenter", "dragover", "dragleave", "drop"].forEach((eventName) => {
        dropZone?.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e: Event) {
        e.preventDefault();
        e.stopPropagation();
    }

    ["dragenter", "dragover"].forEach((eventName) => {
        dropZone?.addEventListener(
            eventName,
            () => {
                dropZone.classList.add("border-primary-500", "bg-primary-50");
            },
            false,
        );
    });

    ["dragleave", "drop"].forEach((eventName) => {
        dropZone?.addEventListener(
            eventName,
            () => {
                dropZone.classList.remove(
                    "border-primary-500",
                    "bg-primary-50",
                );
            },
            false,
        );
    });

    dropZone?.addEventListener(
        "drop",
        (e: DragEvent) => {
            const dt = e.dataTransfer;
            const files = dt?.files;
            if (files && files.length > 0) {
                fileInput.files = files;
                updateFileName();
            }
        },
        false,
    );

    fileInput?.addEventListener("change", updateFileName);

    function updateFileName() {
        if (fileInput.files && fileInput.files.length > 0) {
            if (fileNameDisplay && fileNameText) {
                fileNameText.textContent = fileInput.files[0].name;
                fileNameDisplay.classList.remove("hidden");
            }
        } else {
            if (fileNameDisplay) fileNameDisplay.classList.add("hidden");
        }
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (errorAlert) errorAlert.classList.add("hidden");
        if (successAlert) successAlert.classList.add("hidden");

        if (!fileInput.files || fileInput.files.length === 0) {
            showError("Pilih file terlebih dahulu.");
            return;
        }

        const originalHtml = submitBtn.innerHTML;
        submitBtn.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Sedang Mengekstrak...`;
        submitBtn.disabled = true;

        const formData = new FormData(form);

        try {
            const res = await fetch("/api/soal/import", {
                method: "POST",
                body: formData, // fetch automatically handles the multipart Content-Type
            });

            const result = await res.json();

            if (result.success) {
                if (successAlert && successMsg) {
                    successMsg.textContent = result.message;
                    successAlert.classList.remove("hidden");
                }
                form.reset();
                if (fileNameDisplay) fileNameDisplay.classList.add("hidden");
                // Optional: redirect to topic view after small delay
                const topicId = formData.get("topicId");
                setTimeout(() => {
                    window.location.href = `/admin/soal/daftar/${topicId}`;
                }, 1500);
            } else {
                showError(result.error || "Gagal memproses file");
            }
        } catch (error) {
            showError(
                "Terjadi kesalahan jaringan atau server saat mengekstrak file.",
            );
        } finally {
            submitBtn.innerHTML = originalHtml;
            submitBtn.disabled = false;
        }
    });

    function showError(msg: string) {
        if (errorAlert && errorMsg) {
            errorMsg.textContent = msg;
            errorAlert.classList.remove("hidden");
        }
    }
</script>
