---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { topics, questions } from "../../../db/schema";
import { eq } from "drizzle-orm";

// Fetch all topics and count their questions
const allTopics = await db.select().from(topics).all();
const allQuestions = await db.select().from(questions).all();

// Group question counts by topic
const topicsWithStats = allTopics.map(topic => {
    const topicQuestions = allQuestions.filter(q => q.topicId === topic.id);
    const pgCount = topicQuestions.filter(q => q.type === 1).length;
    const essayCount = topicQuestions.filter(q => q.type !== 1).length;
    
    return {
        ...topic,
        totalQuestions: topicQuestions.length,
        pgCount,
        essayCount
    };
});
---

<AdminLayout title="Mata Pelajaran">
    <div class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
            <h2 class="text-xl font-bold text-surface-800">
                Mata Pelajaran Ujian
            </h2>
            <p class="text-sm text-surface-500 mt-1">
                Pilih mata pelajaran untuk melihat atau mengelola daftar bank soalnya.
            </p>
        </div>
        <div class="flex gap-2 flex-wrap">
            <a href="/admin/soal/topik" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-emerald-500/30">
                <i class="icon-layers w-4 h-4 inline-block mr-1"></i> Kelola Topik
            </a>
            <a href="/admin/soal/import" class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm hidden sm:block">
                <i class="icon-upload w-4 h-4 inline-block mr-1"></i> Smart Import
            </a>
        </div>
    </div>

    {topicsWithStats.length === 0 ? (
        <div class="bg-white rounded-xl border border-surface-200 shadow-sm p-12 text-center text-surface-500">
            <div class="w-16 h-16 bg-surface-100 rounded-full flex items-center justify-center mx-auto mb-3 text-surface-400">
                <i class="icon-book-open w-8 h-8"></i>
            </div>
            <p class="font-medium text-surface-700 mb-1">Belum ada Mata Pelajaran</p>
            <p class="text-sm mb-4">Silakan buat topik/mata pelajaran terlebih dahulu.</p>
            <a href="/admin/soal/topik" class="px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-500 transition inline-block">
                <i class="icon-plus w-4 h-4 inline-block mr-1"></i> Buat Topik Baru
            </a>
        </div>
    ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {topicsWithStats.map(topic => (
                <a href={`/admin/soal/daftar/${topic.id}`} class="block group">
                    <div class="bg-white rounded-2xl border border-surface-200 shadow-sm p-5 hover:border-primary-300 hover:shadow-md transition-all duration-300 h-full flex flex-col relative overflow-hidden">
                        
                        <!-- BG Accent -->
                        <div class="absolute -right-6 -top-6 w-24 h-24 bg-primary-50 rounded-full group-hover:bg-primary-100 transition-colors z-0"></div>
                        
                        <div class="relative z-10">
                            <!-- Header Icon -->
                            <div class="w-12 h-12 rounded-xl bg-primary-50 text-primary-600 flex items-center justify-center mb-4 border border-primary-100 group-hover:bg-primary-600 group-hover:text-white transition-colors">
                                <i class="icon-book-open w-6 h-6"></i>
                            </div>

                            <!-- Content -->
                            <h3 class="font-bold text-surface-800 text-lg mb-1 group-hover:text-primary-600 transition-colors line-clamp-2" title={topic.name}>
                                {topic.name}
                            </h3>
                            <p class="text-xs text-surface-500 mb-4 line-clamp-2">
                                {topic.description || 'Tidak ada deskripsi untuk mata pelajaran ini.'}
                            </p>
                        </div>

                        <!-- Stats Footer -->
                        <div class="mt-auto pt-4 border-t border-surface-100 flex items-center justify-between text-xs font-medium text-surface-600 relative z-10">
                            <div class="flex gap-3">
                                <span class="flex items-center" title="Pilihan Ganda">
                                    <span class="w-2 h-2 rounded-full bg-primary-500 mr-1.5"></span>
                                    {topic.pgCount} PG
                                </span>
                                <span class="flex items-center" title="Esai">
                                    <span class="w-2 h-2 rounded-full bg-emerald-500 mr-1.5"></span>
                                    {topic.essayCount} Esai
                                </span>
                            </div>
                            <span class="text-primary-600 group-hover:translate-x-1 transition-transform flex items-center gap-1">
                                Kelola <i class="icon-arrow-right w-3.5 h-3.5"></i>
                            </span>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    )}
</AdminLayout>
