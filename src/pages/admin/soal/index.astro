---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { db } from "../../../db";
import { topics, questions } from "../../../db/schema";
import { eq } from "drizzle-orm";

// Fetch all topics and count their questions
const allTopics = await db.select().from(topics).all();
const allQuestions = await db.select().from(questions).all();

// Group question counts by topic
const topicsWithStats = allTopics.map((topic) => {
    const topicQuestions = allQuestions.filter((q) => q.topicId === topic.id);
    const pgCount = topicQuestions.filter((q) => q.type === 1).length;
    const essayCount = topicQuestions.filter((q) => q.type !== 1).length;

    return {
        ...topic,
        totalQuestions: topicQuestions.length,
        pgCount,
        essayCount,
    };
});
---

<AdminLayout title="Mata Pelajaran">
    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <h2 class="text-xl font-bold text-surface-800">
                Mata Pelajaran Ujian
            </h2>
            <p class="text-sm text-surface-500 mt-1">
                Pilih mata pelajaran untuk melihat atau mengelola daftar bank
                soalnya.
            </p>
        </div>
        <div class="flex gap-2 flex-wrap">
            <a
                href="/admin/soal/topik"
                class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-emerald-500/30 flex items-center"
            >
                <i class="icon-layers w-4 h-4 mr-1"></i> Kelola Topik
            </a>
            <a
                href="/admin/soal/topik"
                class="px-4 py-2 bg-white border border-surface-200 text-surface-700 text-sm font-medium rounded-lg hover:bg-surface-50 transition shadow-sm hidden sm:flex items-center"
            >
                <i class="icon-plus w-4 h-4 mr-1"></i> Tambah Topik
            </a>
        </div>
    </div>

    {
        topicsWithStats.length === 0 ? (
            <div class="bg-white rounded-xl border border-surface-200 shadow-sm p-12 text-center text-surface-500">
                <div class="w-16 h-16 bg-surface-100 rounded-full flex items-center justify-center mx-auto mb-3 text-surface-400">
                    <i class="icon-book-open w-8 h-8" />
                </div>
                <p class="font-medium text-surface-700 mb-1">
                    Belum ada Mata Pelajaran
                </p>
                <p class="text-sm mb-4">
                    Silakan buat topik/mata pelajaran terlebih dahulu.
                </p>
                <a
                    href="/admin/soal/topik"
                    class="px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-500 transition inline-block"
                >
                    <i class="icon-plus w-4 h-4 inline-block mr-1" /> Buat Topik
                    Baru
                </a>
            </div>
        ) : (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 gap-2 md:gap-4">
                {topicsWithStats.map((topic) => (
                    <a
                        href={`/admin/soal/daftar/${topic.id}`}
                        class="block group"
                    >
                        <div class="bg-white rounded-xl border border-surface-200 shadow-sm p-5 hover:border-primary-300 hover:shadow-md transition-all h-full flex flex-col justify-between">
                            <h3
                                class="font-semibold text-surface-800 text-base mb-4 line-clamp-1 group-hover:text-primary-600 transition-colors"
                                title={topic.name}
                            >
                                {topic.name}
                            </h3>
                            <div class="flex items-center text-xs text-surface-400 font-medium">
                                <span class="flex items-center gap-1.5">
                                    <i class="icon-list w-4 h-4" />{" "}
                                    {topic.totalQuestions} Soal
                                </span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        )
    }
</AdminLayout>
