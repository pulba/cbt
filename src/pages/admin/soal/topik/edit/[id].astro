---
import AdminLayout from "../../../../../layouts/AdminLayout.astro";
import { db } from "../../../../../db";
import { topics } from "../../../../../db/schema";
import { eq } from "drizzle-orm";

const { id } = Astro.params;

if (!id) {
    return Astro.redirect("/admin/soal/topik");
}

const topic = await db
    .select()
    .from(topics)
    .where(eq(topics.id, parseInt(id)))
    .get();

if (!topic) {
    return Astro.redirect("/admin/soal/topik");
}
---

<AdminLayout title="Edit Topik">
    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <nav
                class="flex text-sm text-surface-500 mb-2"
                aria-label="Breadcrumb"
            >
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a
                            href="/admin/soal/topik"
                            class="hover:text-primary-600 transition-colors"
                            >Topik</a
                        >
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <span class="text-surface-700 font-medium"
                                >Edit Topik</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>
            <h2 class="text-xl font-bold text-surface-800 flex items-center">
                <a
                    href="/admin/soal/topik"
                    class="mr-3 p-1.5 rounded-lg hover:bg-surface-100 transition-colors text-surface-500 hover:text-surface-700"
                >
                    <i class="icon-arrow-left w-5 h-5"></i>
                </a>
                Edit Topik
            </h2>
        </div>
    </div>

    <div
        class="bg-white rounded-xl border border-surface-200 shadow-sm max-w-3xl"
    >
        <div class="p-6 border-b border-surface-200">
            <h3 class="font-semibold text-surface-800">Formulir Edit Topik</h3>
            <p class="text-sm text-surface-500 mt-1">
                Ubah detail topik/mata pelajaran di bawah ini.
            </p>
        </div>

        <div
            id="error-alert"
            class="hidden mx-6 mt-6 p-4 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm flex items-start"
        >
            <i class="icon-alert-circle w-5 h-5 mr-3 shrink-0"></i>
            <span id="error-msg">Terjadi kesalahan</span>
        </div>

        <form id="edit-form" class="p-6 space-y-6">
            <input type="hidden" id="topicId" name="topicId" value={topic.id} />

            <div>
                <label
                    for="name"
                    class="block text-sm font-medium text-surface-700 mb-1.5"
                    >Nama Topik / Mata Pelajaran <span class="text-danger"
                        >*</span
                    ></label
                >
                <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    value={topic.name}
                    class="w-full px-4 py-2.5 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800"
                    placeholder="Contoh: Matematika Kelas X"
                />
            </div>

            <div>
                <label
                    for="description"
                    class="block text-sm font-medium text-surface-700 mb-1.5"
                    >Deskripsi Singkat</label
                >
                <textarea
                    id="description"
                    name="description"
                    rows="3"
                    class="w-full px-4 py-2.5 bg-surface-50 border border-surface-200 rounded-lg text-sm transition focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500 text-surface-800"
                    placeholder="Contoh: Modul latihan soal ulangan harian"
                    >{topic.description}</textarea
                >
            </div>

            <div>
                <label class="block text-sm font-medium text-surface-700 mb-2"
                    >Status Topik</label
                >
                <label class="relative inline-flex items-center cursor-pointer">
                    <input
                        type="checkbox"
                        id="status"
                        name="status"
                        class="sr-only peer"
                        checked={topic.status ? true : false}
                    />
                    <div
                        class="w-11 h-6 bg-surface-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-surface-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary-600"
                    >
                    </div>
                    <span
                        class="ml-3 text-sm font-medium text-surface-600"
                        id="status-text"
                        >{topic.status ? "Aktif" : "Nonaktif"}</span
                    >
                </label>
            </div>

            <div
                class="pt-4 border-t border-surface-100 flex justify-end gap-3"
            >
                <a
                    href="/admin/soal/topik"
                    class="px-5 py-2.5 bg-white border border-surface-200 hover:bg-surface-50 text-surface-700 text-sm font-medium rounded-lg transition-colors"
                >
                    Batal
                </a>
                <button
                    type="submit"
                    id="submit-btn"
                    class="px-5 py-2.5 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition-colors flex items-center shadow-md shadow-primary-500/20"
                >
                    <i class="icon-save w-4 h-4 mr-2"></i> Simpan Perubahan
                </button>
            </div>
        </form>
    </div>
</AdminLayout>

<script>
    const form = document.getElementById("edit-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
        "submit-btn",
    ) as HTMLButtonElement;
    const errorAlert = document.getElementById("error-alert");
    const errorMsg = document.getElementById("error-msg");
    const statusCheckbox = document.getElementById(
        "status",
    ) as HTMLInputElement;
    const statusText = document.getElementById("status-text");

    statusCheckbox?.addEventListener("change", function () {
        if (statusText) {
            statusText.textContent = this.checked ? "Aktif" : "Nonaktif";
        }
    });

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (errorAlert) errorAlert.classList.add("hidden");

        const originalHtml = submitBtn.innerHTML;
        submitBtn.innerHTML = `<i class="icon-loader w-4 h-4 mr-2 animate-spin"></i> Memproses...`;
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const data = {
            id: parseInt(formData.get("topicId") as string),
            name: formData.get("name"),
            description: formData.get("description"),
            status: formData.get("status") === "on",
        };

        try {
            const res = await fetch("/api/soal/topik", {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            });

            const result = await res.json();

            if (result.success) {
                window.location.href = "/admin/soal/topik";
            } else {
                if (errorAlert && errorMsg) {
                    errorMsg.textContent =
                        result.error || "Gagal menyimpan data";
                    errorAlert.classList.remove("hidden");
                }
            }
        } catch (error) {
            if (errorAlert && errorMsg) {
                errorMsg.textContent =
                    "Terjadi kesalahan jaringan, silakan coba lagi.";
                errorAlert.classList.remove("hidden");
            }
        } finally {
            submitBtn.innerHTML = originalHtml;
            submitBtn.disabled = false;
        }
    });
</script>
