---
import AdminLayout from "../../../../layouts/AdminLayout.astro";
import { db } from "../../../../db";
import { topics, questions, questionAnswers } from "../../../../db/schema";
import { eq } from "drizzle-orm"; // Note: removed "desc"

const { soalId: id } = Astro.params;

if (!id) {
    return Astro.redirect("/admin/soal/topik");
}

const soalId = parseInt(id);
const soal = await db
    .select()
    .from(questions)
    .where(eq(questions.id, soalId))
    .get();

if (!soal) {
    return Astro.redirect("/admin/soal/topik");
}

// Only multiple choice questions have these options
if (soal.type !== 1) {
    return Astro.redirect(`/admin/soal/daftar/${soal.topicId}`);
}

const topic = await db
    .select()
    .from(topics)
    .where(eq(topics.id, soal.topicId!))
    .get();

// Fetch Answers
const answers = await db
    .select()
    .from(questionAnswers)
    .where(eq(questionAnswers.questionId, soalId))
    .all();
// Sort by ID to keep order A, B, C, D (ascending) typically
answers.sort((a, b) => a.id - b.id);

const letters = ["A", "B", "C", "D", "E"];
---

<AdminLayout title={`Opsi Jawaban: Soal #${soal.id}`}>
    <!-- Add Quill CSS & JS for the modal -->
    <link
        href="https://cdn.quilljs.com/1.3.7/quill.snow.css"
        rel="stylesheet"
    />
    <script is:inline src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

    <div
        class="mb-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
        <div>
            <nav
                class="flex text-sm text-surface-500 mb-2"
                aria-label="Breadcrumb"
            >
                <ol class="inline-flex items-center space-x-1 md:space-x-2">
                    <li class="inline-flex items-center">
                        <a
                            href="/admin/soal/topik"
                            class="hover:text-primary-600 transition-colors"
                            >Topik</a
                        >
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <a
                                href={`/admin/soal/daftar/${topic?.id}`}
                                class="hover:text-primary-600 transition-colors line-clamp-1 max-w-[150px]"
                                >{topic?.name}</a
                            >
                        </div>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <i class="icon-chevron-right w-4 h-4 mx-1"></i>
                            <span class="text-surface-700 font-medium"
                                >Opsi Jawaban</span
                            >
                        </div>
                    </li>
                </ol>
            </nav>
            <h2 class="text-xl font-bold text-surface-800 flex items-center">
                <a
                    href={`/admin/soal/daftar/${topic?.id}`}
                    class="mr-3 p-1.5 rounded-lg hover:bg-surface-100 transition-colors text-surface-500 hover:text-surface-700"
                >
                    <i class="icon-arrow-left w-5 h-5"></i>
                </a>
                Kelola Opsi Jawaban
            </h2>
        </div>
        <div class="flex gap-2">
            <button
                onclick="openModal()"
                class="px-4 py-2 bg-primary-600 hover:bg-primary-500 text-white text-sm font-medium rounded-lg transition shadow-soft-xl shadow-primary-500/30 font-medium flex items-center"
            >
                <i class="icon-plus w-4 h-4 mr-1.5"></i> Tambah Opsi
            </button>
        </div>
    </div>

    <!-- Question Context Preview -->
    <div
        class="bg-white rounded-xl border border-surface-200 shadow-sm p-5 mb-6"
    >
        <h3
            class="text-xs font-bold text-surface-400 uppercase tracking-wider mb-3"
        >
            Teks Pertanyaan
        </h3>
        <div
            class="prose prose-sm max-w-none text-surface-700 prose-p:my-1 prose-img:max-h-24"
            set:html={soal.text}
        />
    </div>

    <!-- Answers List -->
    <div class="space-y-4">
        {
            answers.length === 0 ? (
                <div class="bg-white rounded-xl border border-surface-200 shadow-sm p-12 text-center text-surface-500">
                    <div class="w-16 h-16 bg-surface-100 rounded-full flex items-center justify-center mx-auto mb-3 text-surface-400">
                        <i class="icon-list w-8 h-8" />
                    </div>
                    <p class="font-medium text-surface-700 mb-1">
                        Belum ada opsi jawaban
                    </p>
                    <p class="text-sm">
                        Silakan tambah opsi jawaban A, B, C, D dst. untuk soal
                        ini.
                    </p>
                </div>
            ) : (
                answers.map((answer, index) => (
                    <div
                        class={`bg-white rounded-xl border ${answer.isCorrect ? "border-emerald-500 shadow-md shadow-emerald-500/10" : "border-surface-200 shadow-sm"} p-4 flex gap-4 transition-all`}
                    >
                        <div class="flex-shrink-0 flex flex-col items-center gap-3">
                            <div
                                class={`w-10 h-10 rounded-lg flex items-center justify-center font-bold text-lg ${answer.isCorrect ? "bg-emerald-500 text-white" : "bg-surface-100 text-surface-500"}`}
                            >
                                {letters[index] || "?"}
                            </div>
                            <button
                                title={
                                    answer.isCorrect
                                        ? "Ini Kunci Jawaban"
                                        : "Jadikan Kunci Jawaban"
                                }
                                class={`w-8 h-8 rounded-full flex items-center justify-center transition-colors ${answer.isCorrect ? "bg-emerald-100 text-emerald-600 cursor-default" : "bg-surface-50 border border-surface-200 text-surface-400 hover:border-emerald-500 hover:text-emerald-500"}`}
                                onclick={
                                    !answer.isCorrect
                                        ? `setCorrectAnswer(${answer.id})`
                                        : ""
                                }
                            >
                                <i class="icon-check w-4 h-4" />
                            </button>
                        </div>

                        <div class="flex-grow py-1">
                            <div
                                class="prose prose-sm max-w-none text-surface-700 prose-p:my-0 prose-img:max-h-16"
                                set:html={answer.text}
                            />
                        </div>

                        <div class="flex-shrink-0 flex flex-col items-end gap-2">
                            <div class="flex items-center gap-1">
                                <button
                                    onclick={`editAnswer(${answer.id}, \`${encodeURIComponent(answer.text)}\`, ${answer.isCorrect})`}
                                    class="w-8 h-8 rounded-md text-surface-500 hover:text-primary-600 flex items-center justify-center transition"
                                >
                                    <i class="icon-edit-2 w-4 h-4" />
                                </button>
                                <button
                                    onclick={`deleteAnswer(${answer.id})`}
                                    class="w-8 h-8 rounded-md text-surface-500 hover:text-danger flex items-center justify-center transition"
                                >
                                    <i class="icon-trash-2 w-4 h-4" />
                                </button>
                            </div>
                            {answer.isCorrect && (
                                <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded inline-block mt-auto mb-1 border border-emerald-100">
                                    KUNCI
                                </span>
                            )}
                        </div>
                    </div>
                ))
            )
        }
    </div>

    <!-- Editor Modal for Answer Option -->
    <div
        id="answer-modal"
        class="fixed inset-0 z-[100] hidden bg-surface-900/60 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300"
    >
        <div
            class="bg-white rounded-2xl shadow-xl w-full max-w-2xl overflow-hidden flex flex-col max-h-[90vh] scale-95 transition-transform duration-300"
            id="answer-modal-panel"
        >
            <div
                class="px-6 py-4 border-b border-surface-200 flex justify-between items-center bg-surface-50"
            >
                <div>
                    <h3 class="font-bold text-surface-800" id="modal-title">
                        Tambah Opsi Jawaban
                    </h3>
                    <p class="text-xs text-surface-500 mt-0.5">
                        Edit teks atau gambar pilihan jawaban
                    </p>
                </div>
                <button
                    onclick="closeModal()"
                    class="w-8 h-8 rounded-full bg-white border border-surface-200 text-surface-500 flex items-center justify-center hover:bg-surface-100 transition"
                >
                    <i class="icon-x w-4 h-4"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto">
                <form id="answer-form">
                    <input type="hidden" id="answer-id" value="" />
                    <input type="hidden" id="soal-id" value={soalId} />

                    <div
                        id="modal-error"
                        class="hidden mb-4 p-3 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm flex items-start"
                    >
                        <i
                            class="icon-alert-circle w-4 h-4 mr-2 shrink-0 mt-0.5"
                        ></i>
                        <span id="modal-error-msg">Error</span>
                    </div>

                    <div class="mb-5">
                        <label
                            class="block text-sm font-medium text-surface-700 mb-1.5"
                            >Teks Opsi (Rich Text) <span class="text-danger"
                                >*</span
                            ></label
                        >
                        <!-- Quill Editor Container -->
                        <div
                            class="bg-surface-50 border border-surface-200 rounded-t-lg border-b-0"
                            id="modal-toolbar"
                        >
                            <span class="ql-formats">
                                <button class="ql-bold"></button>
                                <button class="ql-italic"></button>
                                <button class="ql-underline"></button>
                                <button class="ql-strike"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-script" value="sub"></button>
                                <button class="ql-script" value="super"
                                ></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-image"></button>
                                <button class="ql-formula"></button>
                            </span>
                            <span class="ql-formats">
                                <button class="ql-clean"></button>
                            </span>
                        </div>
                        <div
                            id="modal-editor"
                            class="bg-white min-h-[150px] rounded-b-lg text-sm border-surface-200"
                        >
                        </div>
                    </div>

                    <div
                        class="mb-5 p-3 rounded-lg border border-surface-200 bg-surface-50"
                    >
                        <label
                            class="relative inline-flex items-center cursor-pointer w-full"
                        >
                            <input
                                type="checkbox"
                                id="is-correct"
                                class="sr-only peer"
                            />
                            <div
                                class="w-11 h-6 bg-surface-300 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-emerald-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-surface-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"
                            >
                            </div>
                            <span
                                class="ml-3 text-sm font-semibold text-surface-700"
                                >Tandai sebagai Kunci Jawaban Benar</span
                            >
                        </label>
                        <p class="text-xs text-surface-500 mt-2 ml-14">
                            Hanya satu opsi yang bisa menjadi kunci jawaban
                            benar.
                        </p>
                    </div>

                    <div class="flex justify-end gap-3 pt-2">
                        <button
                            type="button"
                            onclick="closeModal()"
                            class="px-4 py-2 bg-white border border-surface-200 text-surface-600 hover:bg-surface-50 rounded-lg text-sm font-medium transition"
                        >
                            Batal
                        </button>
                        <button
                            type="button"
                            id="btn-save-answer"
                            class="px-5 py-2 bg-primary-600 hover:bg-primary-500 text-white rounded-lg text-sm font-medium transition shadow-md shadow-primary-500/20 flex items-center"
                        >
                            <i class="icon-save w-4 h-4 mr-1.5"></i> Simpan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    let quillModal: any;

    document.addEventListener("DOMContentLoaded", () => {
        // Initialize Quill inside modal
        quillModal = new (window as any).Quill("#modal-editor", {
            modules: {
                toolbar: "#modal-toolbar",
            },
            placeholder: "Ketik opsi jawaban...",
            theme: "snow",
        });
    });

    const modal = document.getElementById("answer-modal");
    const modalPanel = document.getElementById("answer-modal-panel");
    const errorAlert = document.getElementById("modal-error");
    const errorMsg = document.getElementById("modal-error-msg");

    (window as any).openModal = () => {
        if (!modal || !modalPanel) return;

        // Reset form
        (document.getElementById("answer-id") as HTMLInputElement).value = "";
        quillModal.root.innerHTML = "";
        (document.getElementById("is-correct") as HTMLInputElement).checked =
            false;
        (document.getElementById("modal-title") as HTMLElement).innerText =
            "Tambah Opsi Jawaban";

        if (errorAlert) errorAlert.classList.add("hidden");

        modal.classList.remove("hidden");
        // small delay to allow display flex to apply before opacity transition
        setTimeout(() => {
            modal.classList.remove("opacity-0");
            modalPanel.classList.remove("scale-95");
        }, 10);
    };

    (window as any).closeModal = () => {
        if (!modal || !modalPanel) return;

        modal.classList.add("opacity-0");
        modalPanel.classList.add("scale-95");

        setTimeout(() => {
            modal.classList.add("hidden");
        }, 300);
    };

    (window as any).editAnswer = (
        id: number,
        textBase64: string,
        isCorrect: boolean,
    ) => {
        if (!modal || !modalPanel) return;

        const html = decodeURIComponent(textBase64);

        (document.getElementById("answer-id") as HTMLInputElement).value =
            id.toString();
        quillModal.root.innerHTML = html;
        (document.getElementById("is-correct") as HTMLInputElement).checked =
            isCorrect;
        (document.getElementById("modal-title") as HTMLElement).innerText =
            "Edit Opsi Jawaban";

        if (errorAlert) errorAlert.classList.add("hidden");

        modal.classList.remove("hidden");
        setTimeout(() => {
            modal.classList.remove("opacity-0");
            modalPanel.classList.remove("scale-95");
        }, 10);
    };

    const btnSave = document.getElementById(
        "btn-save-answer",
    ) as HTMLButtonElement;
    btnSave?.addEventListener("click", async () => {
        const id = (document.getElementById("answer-id") as HTMLInputElement)
            .value;
        const soalId = (document.getElementById("soal-id") as HTMLInputElement)
            .value;
        const isCorrect = (
            document.getElementById("is-correct") as HTMLInputElement
        ).checked;
        const htmlText = quillModal.root.innerHTML;

        if (htmlText === "<p><br></p>" || htmlText.trim() === "") {
            if (errorAlert && errorMsg) {
                errorMsg.textContent = "Teks opsi jawaban tidak boleh kosong.";
                errorAlert.classList.remove("hidden");
            }
            return;
        }

        const originalText = btnSave.innerHTML;
        btnSave.innerHTML = `<i class="icon-loader w-4 h-4 mr-1.5 animate-spin"></i> Menyimpan...`;
        btnSave.disabled = true;

        const data = {
            id: id ? parseInt(id) : undefined,
            questionId: parseInt(soalId),
            text: htmlText,
            isCorrect,
        };

        const method = id ? "PUT" : "POST";

        try {
            const res = await fetch("/api/soal/jawaban", {
                method: method,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            });
            const result = await res.json();

            if (result.success) {
                window.location.reload();
            } else {
                if (errorAlert && errorMsg) {
                    errorMsg.textContent =
                        result.error || "Gagal menyimpan data";
                    errorAlert.classList.remove("hidden");
                }
                btnSave.innerHTML = originalText;
                btnSave.disabled = false;
            }
        } catch (e) {
            if (errorAlert && errorMsg) {
                errorMsg.textContent = "Terjadi kesalahan jaringan.";
                errorAlert.classList.remove("hidden");
            }
            btnSave.innerHTML = originalText;
            btnSave.disabled = false;
        }
    });

    (window as any).deleteAnswer = async (id: number) => {
        if (!confirm("Apakah Anda yakin ingin menghapus opsi jawaban ini?"))
            return;

        try {
            const res = await fetch("/api/soal/jawaban", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id }),
            });
            const data = await res.json();

            if (!data.success) {
                alert("Gagal menghapus: " + data.error);
                return;
            }
            window.location.reload();
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };

    (window as any).setCorrectAnswer = async (id: number) => {
        const soalId = (document.getElementById("soal-id") as HTMLInputElement)
            .value;
        try {
            const res = await fetch("/api/soal/jawaban", {
                method: "PATCH",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ id, questionId: parseInt(soalId) }),
            });
            const data = await res.json();

            if (!data.success) {
                alert("Gagal memperbarui kunci jawaban: " + data.error);
                return;
            }
            window.location.reload();
        } catch (e) {
            alert("Terjadi kesalahan jaringan.");
        }
    };
</script>

<style is:global>
    /* Slight adjustments for Quill modal */
    .ql-toolbar.ql-snow {
        border-color: #e5e7eb !important;
        border-top-left-radius: 0.5rem;
        border-top-right-radius: 0.5rem;
    }
    .ql-container.ql-snow {
        border-color: #e5e7eb !important;
        border-bottom-left-radius: 0.5rem;
        border-bottom-right-radius: 0.5rem;
        font-family: inherit !important;
    }
    #modal-editor .ql-editor {
        min-height: 150px;
        max-height: 300px;
        padding: 0.75rem 1rem !important;
    }
</style>
