---
import StudentLayout from "../../../../layouts/StudentLayout.astro";
import { db } from "../../../../db";
import {
    topics,
    questions,
    questionAnswers,
} from "../../../../db/schema";
import { eq, asc, inArray } from "drizzle-orm";

const { topikId: idParam } = Astro.params;
const user = Astro.locals.user;

if (!idParam || !user || user.role !== "admin") {
    return Astro.redirect("/admin/soal/topik");
}

const topicId = parseInt(idParam);

const topic = await db.select().from(topics).where(eq(topics.id, topicId)).get();
if (!topic) return Astro.redirect("/admin/soal/topik");

// Fetch real questions
const allQuestions = await db
    .select()
    .from(questions)
    .where(eq(questions.topicId, topicId))
    .orderBy(asc(questions.id))
    .all();

// Synthesize session questions structurally
const sessionQuestions = allQuestions.map((q: any, idx: number) => ({
    tqId: q.id, // fake tqId with real qId to avoid conflicts
    orderIdx: idx + 1,
    isDoubtful: false,
    qId: q.id,
    qType: q.type,
    qText: q.text,
    qAudioPath: q.audio,
    answerText: "",
}));

const questionIds = allQuestions.map((q: any) => q.id);
let sessionAnswers: any[] = [];

if (questionIds.length > 0) {
    const allAnswers = await db
        .select()
        .from(questionAnswers)
        .where(inArray(questionAnswers.questionId, questionIds))
        .all();

    // Group answers to simulate testQuestionAnswers wrapper
    sessionAnswers = allAnswers.map((a: any, idx: number) => ({
        id: a.id,
        tqId: a.questionId, // matches synthesized tqId
        isSelected: !!a.isCorrect, // pre-select correct answers for admin view? Wait, no, empty for preview. Actually empty is better. Let's make it false.
        orderIdx: a.orderIdx || idx,
        ansId: a.id,
        ansText: a.text,
        matchRight: a.matchRight,
    }));
    // Override isSelected to always false
    sessionAnswers.forEach((a: any) => a.isSelected = false);
}

const spaState = JSON.stringify({
    session: { id: 0, status: 1 },
    test: {
        id: 0,
        name: `PREVIEW: ${topic.name}`,
        durationMinutes: 120,
    },
    questions: sessionQuestions.map((q: any) => {
        const answers = sessionAnswers
            .filter((a: any) => a.tqId === q.tqId)
            .sort((a: any, b: any) => a.orderIdx - b.orderIdx);
            
        let rightOptions: string[] = [];
        if (q.qType === 4) {
            rightOptions = answers
                .map((a: any) => a.matchRight)
                .filter(Boolean)
                .sort(() => Math.random() - 0.5);
        }
        
        return {
            ...q,
            answers,
            rightOptions
        };
    }),
});

const totalQuestions = sessionQuestions.length;
const studentName = "ADMIN PREVIEW";
---

<StudentLayout title={`Preview - ${topic.name}`}>
    <!-- Highlighting for code chunks -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

    <!-- KaTeX for math formulas -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.css" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/katex.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js"></script>

    <script id="exam-data" type="application/json" set:html={spaState} />

    <!-- Full Screen Exam UI -->
    <div class="fixed inset-0 bg-slate-100 z-50 flex flex-col overflow-hidden" id="exam-root">

        <!-- ═══ HEADER ═══ -->
        <header class="bg-white border-b border-slate-200 shadow-sm shrink-0 z-20">
            <div class="flex items-center justify-between px-3 sm:px-5 h-14 gap-2">
                <!-- Left: Logo + test name -->
                <div class="flex items-center gap-2 min-w-0 flex-1">
                    <div class="flex items-center shrink-0">
                        <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-lg bg-primary-600 flex items-center justify-center mr-1.5">
                            <i class="icon-book-open w-4 h-4 text-white"></i>
                        </div>
                        <span class="font-black text-slate-800 text-sm hidden xs:block">SAS<span class="font-light text-slate-400 ml-0.5">CBT</span></span>
                    </div>
                    <div class="w-px h-5 bg-slate-200 shrink-0 hidden sm:block"></div>
                    <span class="text-xs sm:text-sm font-semibold text-amber-600 truncate hidden sm:block max-w-[160px] md:max-w-xs uppercase bg-amber-100 px-2 py-0.5 rounded border border-amber-200">PREVIEW</span>
                </div>

                <!-- Center: Question counter + Sync status -->
                <div class="flex items-center gap-2">
                    <div class="flex items-center gap-1.5 bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5">
                        <span class="text-[10px] text-slate-400 hidden sm:block font-medium">Soal</span>
                        <span class="text-sm font-black text-slate-800 font-mono"><span id="header-q-num">1</span><span id="header-total-num" class="text-slate-300 font-light">/{totalQuestions}</span></span>
                    </div>
                    <div id="sync-status" class="flex items-center gap-1 px-2 text-[10px] font-black uppercase tracking-widest text-emerald-500 transition-opacity duration-300 opacity-0">
                        <i class="icon-refresh-cw w-3 h-3 animate-spin"></i>
                        <span>Saving</span>
                    </div>
                </div>

                <!-- Right: Timer + Nav toggle (mobile) + Finish -->
                <div class="flex items-center gap-2 shrink-0">
                    <!-- Timer -->
                    <div class="flex items-center gap-1.5 bg-slate-800 text-white rounded-lg px-2.5 sm:px-3 py-1.5">
                        <i class="icon-clock w-3.5 h-3.5 text-amber-300 shrink-0"></i>
                        <span id="countdown-timer" class="text-sm font-mono font-bold text-amber-300 tracking-widest">00:00:00</span>
                    </div>

                    <!-- Nav toggle (mobile only) -->
                    <button
                        id="nav-toggle-btn"
                        onclick="toggleNavPanel()"
                        class="sm:hidden w-9 h-9 rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center relative"
                        title="Navigasi Soal"
                    >
                        <i class="icon-layout-grid w-4 h-4 text-slate-600"></i>
                        <span id="nav-badge" class="absolute -top-1 -right-1 w-4 h-4 bg-primary-600 text-white text-[9px] font-bold rounded-full flex items-center justify-center hidden">0</span>
                    </button>

                    <!-- Finish -->
                    <button
                        onclick="finishTest()"
                        class="flex items-center gap-1.5 px-2.5 sm:px-3 py-2 bg-slate-100 border border-slate-300 hover:bg-slate-200 text-slate-700 text-xs font-bold rounded-lg transition shadow-sm"
                    >
                        <i class="icon-log-out w-3.5 h-3.5"></i>
                        <span class="hidden xs:inline">Keluar Preview</span>
                    </button>
                </div>
            </div>

            <!-- Progress bar -->
            <div class="h-1 bg-slate-100">
                <div id="progress-bar" class="h-full bg-gradient-to-r from-primary-500 to-indigo-500 transition-all duration-500" style="width: 0%"></div>
            </div>
        </header>

        <!-- ═══ BODY ═══ -->
        <div class="flex-1 flex overflow-hidden relative">

            <!-- ─── QUESTION PANEL ─── -->
            <div class="flex-1 overflow-y-auto" id="question-panel-scroll">
                <div class="max-w-4xl mx-auto px-3 sm:px-6 lg:px-8 py-5 pb-24 sm:pb-8">

                    <!-- Question header -->
                    <div id="question-header" class="flex items-center justify-end mb-5 gap-3">
                        <div class="hidden items-center gap-3">
                            <div id="q-badge"
                                class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-primary-600 text-white flex items-center justify-center text-base sm:text-lg font-black font-mono shadow-md shadow-primary-600/25 shrink-0">
                                1
                            </div>
                            <div>
                                <div class="text-[10px] text-slate-400 font-medium uppercase tracking-wider">Soal Nomor</div>
                                <div class="text-lg font-black text-slate-800 leading-tight font-mono">
                                    <span id="q-num">1</span><span id="hero-total-num" class="text-slate-300 text-sm font-light"> / {totalQuestions}</span>
                                </div>
                            </div>
                        </div>

                        <!-- Flag button -->
                        <button
                            id="flag-btn"
                            onclick="toggleFlag()"
                            class="flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-xl border border-slate-200 text-slate-500 hover:bg-amber-50 hover:text-amber-600 hover:border-amber-300 text-xs sm:text-sm font-bold transition whitespace-nowrap"
                        >
                            <i id="flag-icon" class="icon-flag w-3.5 h-3.5"></i>
                            <span>Ragu-ragu</span>
                        </button>
                    </div>

                    <!-- Question text card -->
                    <div id="question-card" class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 sm:p-7 mb-5">
                        <div id="question-content" class="prose prose-slate prose-sm sm:prose-base max-w-none text-slate-800 leading-relaxed font-medium">
                            <!-- Rendered by JS -->
                        </div>
                    </div>

                    <!-- Answer options -->
                    <div class="space-y-2.5 sm:space-y-3" id="options-container">
                        <!-- Rendered by JS -->
                    </div>

                    <!-- Mobile bottom nav -->
                    <div class="flex gap-3 mt-6 sm:hidden">
                        <button id="btn-prev-m" onclick="navigateItem(-1)"
                            class="w-28 py-3 bg-white border-2 border-slate-200 rounded-xl font-bold text-slate-600 text-sm transition hover:bg-slate-50 flex justify-center items-center gap-1.5">
                            <i class="icon-chevron-left w-4 h-4"></i> Prev
                        </button>
                        <button id="btn-next-m" onclick="smartNext()"
                            class="flex-1 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1.5">
                            Next <i class="icon-chevron-right w-4 h-4" id="icon-next-m"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- ─── NAV PANEL (sidebar desktop / drawer mobile) ─── -->
            <!-- Mobile overlay -->
            <div id="nav-overlay" class="fixed inset-0 bg-slate-900/50 z-30 hidden sm:hidden" onclick="toggleNavPanel()"></div>

            <!-- Nav panel itself -->
            <aside id="nav-panel"
                class="
                    fixed bottom-0 left-0 right-0 z-40 max-h-[70vh]
                    sm:static sm:max-h-none sm:z-auto
                    bg-white border-t sm:border-t-0 sm:border-l border-slate-200
                    sm:w-64 md:w-72 lg:w-80 shrink-0
                    flex flex-col
                    shadow-[0_-4px_24px_rgba(0,0,0,0.08)] sm:shadow-[-4px_0_12px_-2px_rgba(0,0,0,0.04)]
                    rounded-t-2xl sm:rounded-none
                    translate-y-full sm:translate-y-0
                    transition-transform duration-300
                ">

                <!-- Panel header -->
                <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between shrink-0">
                    <!-- Mobile drag handle -->
                    <div class="sm:hidden absolute top-2 left-1/2 -translate-x-1/2 w-10 h-1 bg-slate-300 rounded-full"></div>

                    <div class="flex items-center gap-2 text-sm font-bold text-slate-700">
                        <i class="icon-layout-grid w-4 h-4 text-primary-500"></i>
                        Navigasi Soal
                    </div>
                    <div class="text-right">
                        <div class="text-[10px] text-slate-400 leading-none">Terjawab</div>
                        <div class="text-sm font-black text-slate-800 leading-tight">
                            <span id="answered-count">0</span><span id="nav-total-num" class="text-slate-300 font-light text-xs">/{totalQuestions}</span>
                        </div>
                    </div>
                </div>

                <!-- Mini progress -->
                <div class="px-4 py-2 bg-slate-50 border-b border-slate-100 shrink-0">
                    <div class="h-1.5 bg-slate-200 rounded-full overflow-hidden">
                        <div id="side-progress" class="h-full bg-gradient-to-r from-primary-500 to-indigo-500 rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Legend -->
                <div class="px-4 py-2 border-b border-slate-100 shrink-0">
                    <div class="flex items-center justify-center gap-4 text-[10px] font-semibold text-slate-500">
                        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-slate-200 inline-block"></span>Kosong</span>
                        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-primary-600 inline-block"></span>Dijawab</span>
                        <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-amber-400 inline-block"></span>Ragu</span>
                    </div>
                </div>

                <!-- Question grid -->
                <div class="p-3 overflow-y-auto flex-1" style="scrollbar-width: thin; scrollbar-color: #e2e8f0 transparent;">
                    <div class="grid grid-cols-6 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-7 gap-1.5" id="nav-grid">
                        <!-- Rendered by JS -->
                    </div>
                </div>

                <!-- Desktop nav buttons -->
                <div class="p-3 border-t border-slate-100 hidden sm:flex gap-2 shrink-0">
                    <button id="btn-prev" onclick="navigateItem(-1)"
                        class="flex-1 py-2.5 bg-slate-100 hover:bg-slate-200 rounded-xl font-bold text-slate-600 text-sm transition flex justify-center items-center gap-1">
                        <i class="icon-chevron-left w-4 h-4"></i> Prev
                    </button>
                    <button id="btn-next" onclick="smartNext()"
                        class="flex-1 py-2.5 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1">
                        Next <i class="icon-chevron-right w-4 h-4" id="icon-next"></i>
                    </button>
                </div>
            </aside>
        </div>
    </div>
</StudentLayout>

<style>
/* Option hover - smooth left bar expansion */
/* Option label */

/* Timer warning pulse */
#countdown-timer.warning { animation: timer-pulse 1s ease-in-out infinite; }
@keyframes timer-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

/* Nav grid scrollbar */
#nav-panel ::-webkit-scrollbar { width: 3px; }
#nav-panel ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }
</style>

<script>
// ─── TYPES ───
interface Answer { id: number; tqId: number; isSelected: boolean; orderIdx: number; ansId: number; ansText: string; matchRight?: string; }
interface Question { tqId: number; orderIdx: number; isDoubtful: boolean; qId: number; qType: number; qText: string; qAudioPath: string | null; answerText: string | null; answers: Answer[]; rightOptions?: string[]; }
interface State { session: { id: number; status: number }; test: { id: number; name: string; durationMinutes: number }; questions: Question[]; }

// ─── STATE ───
let state: State = { session: null as any, test: null as any, questions: [] };
let cur = 0;
let isSystemAction = false; // Flag to ignore blur during alerts/confirms
let _matchFocus: { type: 'left' | 'right', id: string, tqId: number } | null = null; // for click-to-connect

// ─── INIT ───
document.addEventListener("DOMContentLoaded", () => {
    const raw = document.getElementById("exam-data")?.innerHTML;
    if (!raw) { alert("Gagal memuat data ujian."); return; }
    state = JSON.parse(raw);
    updateTotalDisplay();
    render();
    renderGrid();
    updateProgress();
    startTimer();
    initAntiCheat();
});

// ─── ANTI-CHEAT ───
function initAntiCheat() {
    // Disabled in Preview
}

async function handleViolation() {
    // Disabled in Preview
}

// ─── RENDER QUESTION ───
function render(shouldScroll = true) {
    const q = state.questions[cur];
    if (!q) return;

    // Number badges
    let blockStart = cur;
    let blockEnd = cur;
    if (q.qType === 6) {
        while (blockStart > 0 && state.questions[blockStart - 1].qType === 6) blockStart--;
        while (blockEnd < state.questions.length - 1 && state.questions[blockEnd + 1].qType === 6) blockEnd++;
    }
    
    const numDisplay = (blockStart !== blockEnd) 
        ? `${state.questions[blockStart].orderIdx}-${state.questions[blockEnd].orderIdx}` 
        : q.orderIdx.toString();

    ["header-q-num", "q-num"].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = numDisplay;
    });
    const badge = document.getElementById("q-badge");
    if (badge) badge.textContent = numDisplay;

    // Flag button state (hidden for clustered Type 6)
    const flagBtn = document.getElementById("flag-btn");
    if (flagBtn) {
        if (blockStart !== blockEnd) {
            flagBtn.style.display = 'none'; // hide for clustered, flag per row instead
        } else {
            flagBtn.style.display = 'flex';
            flagBtn.className = q.isDoubtful
                ? "flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-xl text-xs sm:text-sm font-bold transition border border-amber-400 text-amber-600 bg-amber-50"
                : "flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-xl border border-slate-200 text-slate-500 hover:bg-amber-50 hover:text-amber-600 hover:border-amber-300 text-xs sm:text-sm font-bold transition whitespace-nowrap";
        }
    }

    // Question content
    const contentCard = document.getElementById("question-card");
    const contentEl = document.getElementById("question-content");
    if (contentEl && contentCard) {
        if (q.qType === 6) {
            contentCard.style.display = "none";
        } else {
            contentCard.style.display = "block";
            let html = q.qText || "<em class='text-slate-400'>Soal tidak tersedia</em>";
            if (q.qAudioPath) {
                html = `<div class="mb-5 p-3.5 bg-slate-50 border border-slate-200 rounded-xl flex items-center gap-3">
                    <i class="icon-volume-2 text-primary-500 w-5 h-5 shrink-0"></i>
                    <audio controls src="${q.qAudioPath}" class="w-full h-9 accent-primary-600"></audio>
                </div>` + html;
            }
            contentEl.innerHTML = html;
        }
    }

    // Answer options
    const optsEl = document.getElementById("options-container");
    if (optsEl) {
        const charMap = ["A", "B", "C", "D", "E", "F"];
        let html = "";

        if (q.qType === 1 || q.qType === 5) {
            if (q.answers.length === 0) {
                html = `<div class="p-5 bg-amber-50 border border-amber-200 rounded-xl text-amber-700 text-sm font-medium flex items-center gap-2">
                    <i class="icon-alert-triangle w-4 h-4 shrink-0"></i>
                    Pilihan jawaban belum tersedia. Hubungi pengawas.
                </div>`;
            } else {
                html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-3">`;
                q.answers.forEach((ans, idx) => {
                    const ch = charMap[idx] ?? String(idx + 1);
                    const sel = ans.isSelected;
                    const type = q.qType === 1 ? "radio" : "checkbox";
                    const isCheckbox = q.qType === 5;
                    const accentColor = isCheckbox ? "emerald" : "primary";
                    const activeClasses = isCheckbox 
                        ? "border-emerald-500 shadow-md shadow-emerald-100" 
                        : "border-primary-500 shadow-md shadow-primary-100";
                    const bgAccent = isCheckbox ? "bg-emerald-600 border-emerald-500" : "bg-primary-600 border-primary-500";
                    const contentAccent = isCheckbox ? "bg-emerald-50/50" : "bg-primary-50/50";
                    const onChange = isCheckbox ? `toggleAnswer(${q.tqId}, ${ans.ansId})` : `saveAnswer(${q.tqId}, ${ans.ansId})`;
                    
                    html += `
                    <label class="opt-label flex items-stretch rounded-xl border-2 cursor-pointer overflow-hidden
                        ${sel ? activeClasses : "border-slate-200 hover:border-slate-300 hover:shadow-sm"}">
                        <!-- Letter -->
                        <div class="w-11 flex items-center justify-center shrink-0 border-r-2
                            ${sel ? bgAccent : "bg-slate-50 border-slate-200"}">
                            <span class="text-xs font-black ${sel ? "text-white" : "text-slate-400"}">${ch}</span>
                        </div>
                        <!-- Content -->
                        <div class="flex items-start gap-3 flex-1 px-4 py-3 ${sel ? contentAccent : "bg-white"}">
                            <input
                                type="${type}"
                                ${q.qType === 1 ? `name="q${q.tqId}"` : ""}
                                value="${ans.ansId}"
                                ${sel ? "checked" : ""}
                                onchange="${onChange}"
                                class="mt-0.5 w-4 h-4 flex-shrink-0 accent-slate-900">
                            <div class="flex-1 text-slate-800 text-sm leading-relaxed">${ans.ansText}</div>
                        </div>
                    </label>`;
                });
                html += `</div>`;
            }
        } else if (q.qType === 6) {
            let rowsHtml = "";
            for (let i = blockStart; i <= blockEnd; i++) {
                const bq = state.questions[i];
                const qText = bq.qText || "<em class='text-slate-400'>Soal tidak tersedia</em>";
                const ansBenar = bq.answers.find((a: any) => a.ansText.toLowerCase() === 'benar');
                const ansSalah = bq.answers.find((a: any) => a.ansText.toLowerCase() === 'salah');
                const opt1 = ansBenar || bq.answers[0];
                const opt2 = ansSalah || bq.answers[1];
                
                let audioHtml = "";
                if (bq.qAudioPath) {
                    audioHtml = `<div class="mb-4 p-3 bg-slate-50 border border-slate-200 rounded-xl flex items-center gap-3">
                        <i class="icon-volume-2 text-primary-500 w-5 h-5 shrink-0"></i>
                        <audio controls src="${bq.qAudioPath}" class="w-full h-9 accent-primary-600"></audio>
                    </div>`;
                }

                rowsHtml += `
                <div class="px-4 sm:px-6 py-5 sm:py-6 flex flex-col sm:flex-row sm:items-center justify-between hover:bg-slate-50/50 transition-colors gap-6 sm:gap-8 border-b border-slate-100 last:border-0 relative">
                    <!-- Absolute flag/number badge to indicate question number -->
                    <div onclick="toggleFlagSpecific(${i})" class="absolute top-4 sm:top-6 left-1 sm:left-2 w-6 h-6 rounded-full ${bq.isDoubtful ? 'bg-amber-100 text-amber-500 ring-2 ring-amber-200' : 'bg-slate-100 text-slate-500 hover:bg-amber-50'} text-[10px] font-bold flex items-center justify-center cursor-pointer transition shadow-sm" title="Tandai Ragu-ragu (Soal ${bq.orderIdx})">
                        ${bq.orderIdx}
                    </div>
                    
                    <div class="flex-1 pl-6 sm:pl-8">
                        ${audioHtml}
                        <div class="text-sm sm:text-base text-slate-800 leading-relaxed font-semibold prose prose-sm max-w-none">
                            ${qText}
                        </div>
                    </div>
                    
                    <div class="flex shrink-0 gap-4 sm:gap-8 justify-center sm:justify-end pr-2 sm:pr-4">
                        <label class="relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer ${opt1?.isSelected ? 'bg-primary-50 border-2 border-primary-500 shadow-sm ring-2 ring-primary-50' : 'bg-slate-50 border-2 border-slate-200 hover:border-primary-300 hover:bg-white'} transition-all">
                            <input type="radio" name="bs${bq.tqId}" onchange="saveAnswer(${bq.tqId}, ${opt1?.ansId})" ${opt1?.isSelected ? 'checked' : ''} class="w-5 h-5 sm:w-6 sm:h-6 accent-primary-600 cursor-pointer">
                        </label>
                        <label class="relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer ${opt2?.isSelected ? 'bg-rose-50 border-2 border-rose-500 shadow-sm ring-2 ring-rose-50' : 'bg-slate-50 border-2 border-slate-200 hover:border-rose-300 hover:bg-white'} transition-all">
