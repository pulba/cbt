        document.getElementById("question-panel-scroll")?.scrollTo({ top: 0, behavior: "smooth" });
    }
}

// ─── NAV BLOCKS LOGIC ───
// To support grouping Type 6 questions into a single table/navigation button
function getQuestionBlocks() {
    let blocks = [];
    let i = 0;
    while (i < state.questions.length) {
        if (state.questions[i].qType === 6) {
            let start = i;
            let end = i;
            while (end + 1 < state.questions.length && state.questions[end + 1].qType === 6) {
                end++;
            }
            blocks.push({
                start, end,
                label: start !== end ? `${state.questions[start].orderIdx}-${state.questions[end].orderIdx}` : state.questions[start].orderIdx.toString(),
                isGroup: true
            });
            i = end + 1;
        } else {
            blocks.push({
                start: i, end: i,
                label: state.questions[i].orderIdx.toString(),
                isGroup: false
            });
            i++;
        }
    }
    return blocks;
}

// Update total counters
function updateTotalDisplay() {
    const blocks = getQuestionBlocks();
    const len = blocks.length;
    ['header-total-num', 'nav-total-num'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = `/${len}`;
    });
    const heroEl = document.getElementById("hero-total-num");
    if (heroEl) heroEl.textContent = ` / ${len}`;
}

// ─── RENDER NAV GRID ───
function renderGrid() {
    const grid = document.getElementById("nav-grid");
    if (!grid) return;

    let answeredBlocks = 0;
    let html = "";
    const blocks = getQuestionBlocks();

    blocks.forEach(block => {
        let isBlockAns = true; 
        let isBlockDoubtful = false;
        
        for (let i = block.start; i <= block.end; i++) {
            const q = state.questions[i];
            if (q.isDoubtful) isBlockDoubtful = true;
            
            let isAns = false;
            if (q.qType === 1 || q.qType === 5 || q.qType === 6) {
                isAns = q.answers.some((a: any) => a.isSelected);
            } else if (q.qType === 4) {
                try { isAns = Object.values(JSON.parse(q.answerText || "{}")).some(v => v !== ""); } catch(e) { isAns = false; }
            } else {
                isAns = !!(q.answerText && q.answerText.trim());
            }
            if (!isAns) isBlockAns = false;
        }
        
        if (isBlockAns) answeredBlocks++;

        let cls = "w-full aspect-[2/1] sm:aspect-square flex items-center justify-center rounded-lg font-bold font-mono text-xs transition-all duration-150 border ";
        if (isBlockDoubtful) cls += "bg-amber-400 border-amber-400 text-slate-900";
        else if (isBlockAns) cls += "bg-primary-600 border-primary-600 text-white";
        else cls += "bg-white border-slate-200 text-slate-500 hover:border-primary-400 hover:bg-primary-50";
        
        if (cur >= block.start && cur <= block.end) cls += " ring-2 ring-offset-1 ring-primary-500 scale-110 z-10";

        html += `<button onclick="jumpTo(${block.start})" class="${cls}">${block.label}</button>`;
    });

    grid.innerHTML = html;

    const countEl = document.getElementById("answered-count");
    if (countEl) countEl.textContent = answeredBlocks.toString();

    const badge = document.getElementById("nav-badge");
    if (badge) {
        badge.textContent = answeredBlocks.toString();
        badge.classList.toggle("hidden", answeredBlocks === 0);
    }
}

// ─── PROGRESS ───
function updateProgress() {
    const blocks = getQuestionBlocks();
    const total = blocks.length;
    
    let ans = 0;
    blocks.forEach(block => {
        let isBlockAns = true;
        for (let i = block.start; i <= block.end; i++) {
            const q = state.questions[i];
            let isAns = false;
            if (q.qType === 1 || q.qType === 5 || q.qType === 6) {
                isAns = q.answers.some((a: any) => a.isSelected);
            } else if (q.qType === 4) {
                try { isAns = Object.values(JSON.parse(q.answerText || "{}")).some(v => v !== ""); } catch(e) { isAns = false; }
            } else {
                isAns = !!(q.answerText && q.answerText.trim());
            }
            if (!isAns) isBlockAns = false;
        }
        if (isBlockAns) ans++;
    });

    const pct = total > 0 ? (ans / total) * 100 : 0;
    const bar = document.getElementById("progress-bar");
    const side = document.getElementById("side-progress");
    if (bar) bar.style.width = `${pct}%`;
    if (side) side.style.width = `${pct}%`;
}

// ─── INTERACTIONS ───
(window as any).jumpTo = (idx: number) => {
    cur = idx;
    render();
    renderGrid();
    // Close nav panel on mobile after jump
    closeNavPanel();
};

// ─── SMART NEXT BUTTON ───
function updateNextButton() {
    const total = state.questions.length;
    let blockEnd = cur;
    if (state.questions[cur] && state.questions[cur].qType === 6) {
        while (blockEnd < total - 1 && state.questions[blockEnd + 1].qType === 6) blockEnd++;
    }
    const isLast = blockEnd === total - 1;

    const unanswered = state.questions.filter((q: any) => {
        if (q.qType === 1 || q.qType === 5 || q.qType === 6) return !q.answers.some((a: any) => a.isSelected);
        if (q.qType === 4) { try { return !Object.values(JSON.parse(q.answerText || "{}")).some(v => v !== ""); } catch(e) { return true; } }
        return !(q.answerText && q.answerText.trim());
    }).length;
    const doubtful = state.questions.filter((q: any) => q.isDoubtful).length;
    const allClear = unanswered === 0 && doubtful === 0;

    ["btn-next", "btn-next-m"].forEach(id => {
        const b = document.getElementById(id) as HTMLButtonElement;
        if (!b) return;

        if (isLast) {
            // Last question: transform to Selesai
            if (allClear) {
                // ✅ All done — green, enabled
                b.className = b.id === "btn-next"
                    ? "flex-1 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1"
                    : "flex-1 py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1.5";
                b.disabled = false;
                b.style.opacity = "1";
                b.innerHTML = `<i class="icon-check-circle w-4 h-4"></i> Selesai`;
                b.title = "Selesaikan ujian";
            } else {
                // 🔒 Still has issues — red disabled with tooltip
                let tip = [];
                if (unanswered > 0) tip.push(`${unanswered} soal belum dijawab`);
                if (doubtful > 0) tip.push(`${doubtful} soal masih ragu-ragu`);
                b.className = b.id === "btn-next"
                    ? "flex-1 py-2.5 bg-slate-300 text-slate-500 rounded-xl font-bold text-sm flex justify-center items-center gap-1 cursor-not-allowed"
                    : "flex-1 py-3 bg-slate-300 text-slate-500 rounded-xl font-bold text-sm flex justify-center items-center gap-1.5 cursor-not-allowed";
                b.disabled = true;
                b.style.opacity = "1";
                b.innerHTML = `<i class="icon-lock w-4 h-4"></i> Selesai`;
                b.title = tip.join(" & ");
            }
        } else {
            // Not last: normal Next
            b.className = b.id === "btn-next"
                ? "flex-1 py-2.5 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1"
                : "flex-1 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-bold text-sm transition shadow-md flex justify-center items-center gap-1.5";
            b.disabled = false;
            b.style.opacity = "1";
            b.innerHTML = b.id === "btn-next" ? `Next <i class="icon-chevron-right w-4 h-4"></i>` : `Next <i class="icon-chevron-right w-4 h-4"></i>`;
            b.title = "";
        }
    });
}

(window as any).toggleAnswer = (tqId: number, ansId: number) => {
    const q = state.questions.find(x => x.tqId === tqId);
    if (q) {
        const a = q.answers.find(x => x.ansId === ansId);
        if (a) a.isSelected = !a.isSelected;
        
        // Manual DOM update
        const isCb = true;
        const activeClasses = isCb ? ["border-emerald-500", "shadow-md", "shadow-emerald-100"] : ["border-primary-500", "shadow-md", "shadow-primary-100"];
        const inactiveClasses = ["border-slate-200", "hover:border-slate-300", "hover:shadow-sm"];
        const bgAccent = isCb ? ["bg-emerald-600", "border-emerald-500"] : ["bg-primary-600", "border-primary-500"];
        const bgInactive = ["bg-slate-50", "border-slate-200"];
        const contentAccent = isCb ? "bg-emerald-50/50" : "bg-primary-50/50";
        
        q.answers.forEach((ans:any) => {
            const input = document.querySelector(`input[value="${ans.ansId}"]`) as HTMLInputElement | null;
            if (!input) return;
            input.checked = ans.isSelected;
            const label = input.closest('label');
            if (!label) return;
            
            const letterBox = label.firstElementChild;
            const contentBox = label.lastElementChild;
            const letterText = letterBox?.firstElementChild;
            
            if (ans.isSelected) {
                label.classList.remove(...inactiveClasses); label.classList.add(...activeClasses);
                if (letterBox) { letterBox.classList.remove(...bgInactive); letterBox.classList.add(...bgAccent); }
                if (letterText) { letterText.classList.remove("text-slate-400"); letterText.classList.add("text-white"); }
                if (contentBox) { contentBox.classList.remove("bg-white"); contentBox.classList.add(contentAccent); }
            } else {
                label.classList.remove(...activeClasses); label.classList.add(...inactiveClasses);
                if (letterBox) { letterBox.classList.remove(...bgAccent); letterBox.classList.add(...bgInactive); }
                if (letterText) { letterText.classList.remove("text-white"); letterText.classList.add("text-slate-400"); }
                if (contentBox) { contentBox.classList.remove(contentAccent); contentBox.classList.add("bg-white"); }
            }
        });

        renderGrid();
        updateProgress();
        updateNextButton();
        (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "answer", testQuestionId: tqId, answerId: ansId });
    }
};

// ─── SMART NEXT / FINISH ───
(window as any).smartNext = () => {
    let blockEnd = cur;
    if (state.questions[cur].qType === 6) {
        while (blockEnd < state.questions.length - 1 && state.questions[blockEnd + 1].qType === 6) blockEnd++;
    }
    
    const total = state.questions.length;
    if (blockEnd < total - 1) {
        // Navigate to next question (jump past the block)
        cur = blockEnd + 1;
        render();
        renderGrid();
    } else {
        // On last question — act as Selesai
        const unanswered = state.questions.filter((q: any) => {
            if (q.qType === 1 || q.qType === 5 || q.qType === 6) return !q.answers.some((a: any) => a.isSelected);
            if (q.qType === 4) { try { return !Object.values(JSON.parse(q.answerText || "{}")).some(v => v !== ""); } catch(e) { return true; } }
            return !(q.answerText && q.answerText.trim());
        }).length;
        const doubtful = state.questions.filter((q: any) => q.isDoubtful).length;
        if (unanswered === 0 && doubtful === 0) {
            (window as any).finishTest();
        }
    }
};

(window as any).navigateItem = (offset: number) => {
    let newCur = cur;
    if (offset > 0) {
        if (state.questions[cur].qType === 6) {
            let blockEnd = cur;
            while (blockEnd < state.questions.length - 1 && state.questions[blockEnd + 1].qType === 6) blockEnd++;
            newCur = blockEnd + 1;
        } else {
            newCur += offset;
        }
    } else if (offset < 0) {
        if (cur > 0 && state.questions[cur - 1].qType === 6) {
            let blockStart = cur - 1;
            while (blockStart > 0 && state.questions[blockStart - 1].qType === 6) blockStart--;
            newCur = blockStart;
        } else {
            newCur += offset;
        }
    }
    
    if (newCur >= 0 && newCur < state.questions.length) {
        cur = newCur;
        render();
        renderGrid();
    }
};

(window as any).toggleFlagSpecific = (idx: number) => {
    const q = state.questions[idx];
    q.isDoubtful = !q.isDoubtful;
    render(false);
    renderGrid();
    updateNextButton();
    (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "flag", testQuestionId: q.tqId, isDoubtful: q.isDoubtful });
};

(window as any).toggleFlag = () => {
    const q = state.questions[cur];
    q.isDoubtful = !q.isDoubtful;
    render(false);
    renderGrid();
    updateNextButton();
    (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "flag", testQuestionId: q.tqId, isDoubtful: q.isDoubtful });
};

(window as any).saveAnswer = (tqId: number, ansId: number) => {
    const q = state.questions.find(x => x.tqId === tqId);
    if (q) {
        q.answers.forEach(a => a.isSelected = false);
        const a = q.answers.find(x => x.ansId === ansId);
        if (a) a.isSelected = true;
        
        // Manual DOM update to prevent MathJax re-render flash
        if (q.qType === 1 || q.qType === 5) {
            const isCb = q.qType === 5;
            const activeClasses = isCb ? ["border-emerald-500", "shadow-md", "shadow-emerald-100"] : ["border-primary-500", "shadow-md", "shadow-primary-100"];
            const inactiveClasses = ["border-slate-200", "hover:border-slate-300", "hover:shadow-sm"];
            const bgAccent = isCb ? ["bg-emerald-600", "border-emerald-500"] : ["bg-primary-600", "border-primary-500"];
            const bgInactive = ["bg-slate-50", "border-slate-200"];
            const contentAccent = isCb ? "bg-emerald-50/50" : "bg-primary-50/50";
            
            q.answers.forEach((ans:any) => {
                const input = document.querySelector(`input[value="${ans.ansId}"]`) as HTMLInputElement | null;
                if (!input) return;
                input.checked = ans.isSelected;
                const label = input.closest('label');
                if (!label) return;
                
                const letterBox = label.firstElementChild;
                const contentBox = label.lastElementChild;
                const letterText = letterBox?.firstElementChild;
                
                if (ans.isSelected) {
                    label.classList.remove(...inactiveClasses); label.classList.add(...activeClasses);
                    if (letterBox) { letterBox.classList.remove(...bgInactive); letterBox.classList.add(...bgAccent); }
                    if (letterText) { letterText.classList.remove("text-slate-400"); letterText.classList.add("text-white"); }
                    if (contentBox) { contentBox.classList.remove("bg-white"); contentBox.classList.add(contentAccent); }
                } else {
                    label.classList.remove(...activeClasses); label.classList.add(...inactiveClasses);
                    if (letterBox) { letterBox.classList.remove(...bgAccent); letterBox.classList.add(...bgInactive); }
                    if (letterText) { letterText.classList.remove("text-white"); letterText.classList.add("text-slate-400"); }
                    if (contentBox) { contentBox.classList.remove(contentAccent); contentBox.classList.add("bg-white"); }
                }
            });
        } else if (q.qType === 6) {
            const inputs = document.querySelectorAll(`input[name="bs${tqId}"]`);
            inputs.forEach((input: any) => {
                const label = input.closest('label');
                if (!label) return;
                const isBenar = input.classList.contains('accent-primary-600');
                if (input.checked) {
                    label.className = isBenar 
                        ? "relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer bg-primary-50 border-2 border-primary-500 shadow-sm ring-2 ring-primary-50 transition-all"
                        : "relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer bg-rose-50 border-2 border-rose-500 shadow-sm ring-2 ring-rose-50 transition-all";
                } else {
                    label.className = isBenar
                        ? "relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer bg-slate-50 border-2 border-slate-200 hover:border-primary-300 hover:bg-white transition-all"
                        : "relative group flex items-center justify-center p-3 sm:p-4 rounded-xl cursor-pointer bg-slate-50 border-2 border-slate-200 hover:border-rose-300 hover:bg-white transition-all";
                }
            });
        }
        
        // Removed render(false) to prevent html destruction
        renderGrid();
        updateProgress();
        updateNextButton();
        (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "answer", testQuestionId: tqId, answerId: ansId });
    }
};

(window as any).toggleAnswer = (tqId: number, ansId: number) => {
    const q = state.questions.find((x: any) => x.tqId === tqId);
    if (!q) return;
    const a = q.answers.find((x: any) => x.ansId === ansId);
    if (a) a.isSelected = !a.isSelected;
    render(false);
    renderGrid();
    updateProgress();
    updateNextButton();
    (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "toggle_answer", testQuestionId: tqId, answerId: ansId });
};

(window as any).saveTextAnswer = (tqId: number, text: string) => {
    const q = state.questions.find(x => x.tqId === tqId);
    if (q) {
        q.answerText = text;
        renderGrid();
        updateProgress();
        updateNextButton();
        (window as any).bgFetch("/api/peserta/simpan-jawaban", { action: "save_text", testQuestionId: tqId, answerText: text });
    }
};

// ─── CLICK TO CONNECT ENGINE ───
(window as any).matchClick = (type: 'left' | 'right', id: string, tqId: number) => {
    const q = state.questions.find((x: any) => x.tqId === tqId);
    if (!q) return;

    let m: any = {}; try { m = JSON.parse(q.answerText || '{}'); } catch(e){}

    // Check if clicking to unmatch an existing line
    if (!_matchFocus) {
        let isMatched = false;
        if (type === 'left' && m[id]) {
            m[id] = "";
            isMatched = true;
        } else if (type === 'right' && Object.values(m).includes(id)) {
            for (const k in m) if (m[k] === id) m[k] = "";
            isMatched = true;
        }
        
        if (isMatched) {
            q.answerText = JSON.stringify(m);
            render(false);
            renderGrid();
            updateProgress();
            updateNextButton();
            (window as any).bgFetch('/api/peserta/simpan-jawaban', { action: 'save_text', testQuestionId: tqId, answerText: q.answerText });
            return;
        }
    }

    // Unselect dot
    if (_matchFocus && _matchFocus.type === type && _matchFocus.id == id) {
        _matchFocus = null;
        render(false); // clear highlights
        return;
    }

    // Switch focus on same column mode
    if (!_matchFocus || _matchFocus.type === type) {
        _matchFocus = { type, id, tqId };
        render(false); // add highlight to new item
        return;
    }

    // Crossed side - create a line
    if (_matchFocus.tqId !== tqId) {
        _matchFocus = { type, id, tqId }; // Reset across different questions
        render(false);
        return;
    }

    const leftId = type === 'left' ? id : _matchFocus.id;
    const rightId = type === 'right' ? id : _matchFocus.id;

    // Remove any previous line going to this right destination
    for (const k in m) if (m[k] === rightId) m[k] = ""; 
    
    // Connect new pair
    m[leftId] = rightId;
    q.answerText = JSON.stringify(m);
    _matchFocus = null;

    render(false);
    renderGrid();
    updateProgress();
    updateNextButton();
    (window as any).bgFetch('/api/peserta/simpan-jawaban', { action: 'save_text', testQuestionId: tqId, answerText: q.answerText });
};

(window as any).clearMatching = (tqId: number) => {
    const q = state.questions.find((x: any) => x.tqId === tqId);
    if (q) { 
        q.answerText = "{}"; 
        _matchFocus = null;
        render(false); 
        renderGrid();
        updateProgress(); 
        updateNextButton();
        (window as any).bgFetch('/api/peserta/simpan-jawaban', { action: 'save_text', testQuestionId: tqId, answerText: "{}" }); 
    }
};

function renderMatching(tqId: number) {
    const q = state.questions.find((x:any) => x.tqId === tqId);
    const svg = document.getElementById(`matching-svg-${tqId}`) as any;
    const cont = document.getElementById(`matching-container-${tqId}`);
    if (!q || !svg || !cont) return;
    const cR = cont.getBoundingClientRect();
    let m: any = {}; try { m = JSON.parse(q.answerText || '{}'); } catch(er){}
    let h = "";
    for (const lId in m) {
        const rv = m[lId]; if (!rv) continue;
        const lD = cont.querySelector(`.left-dot[data-left-id="${lId}"]`) as HTMLElement;
        const rD = cont.querySelector(`.right-dot[data-right-val="${rv.replace(/"/g, '&quot;')}"]`) as HTMLElement;
        if (lD && rD) {
            const lR = lD.getBoundingClientRect(), rR = rD.getBoundingClientRect();
            const x1 = (lR.left + Math.max(0, lR.width/2))-cR.left;
            const y1 = (lR.top + Math.max(0, lR.height/2))-cR.top;
            const x2 = (rR.left + Math.max(0, rR.width/2))-cR.left;
            const y2 = (rR.top + Math.max(0, rR.height/2))-cR.top;
            h += `<path d="M ${x1} ${y1} C ${(x1+x2)/2} ${y1}, ${(x1+x2)/2} ${y2}, ${x2} ${y2}" stroke="url(#grad-${tqId})" stroke-width="4" stroke-linecap="round" fill="none" class="filter drop-shadow-md" />`;
            // Add a circle on connection point
            h += `<circle cx="${x2}" cy="${y2}" r="5" fill="#10b981" />`;
            h += `<circle cx="${x1}" cy="${y1}" r="5" fill="#6366f1" />`;
        }
    }
    svg.innerHTML = `<defs><linearGradient id="grad-${tqId}" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#3b82f6" /><stop offset="100%" style="stop-color:#10b981" /></linearGradient></defs>${h}`;
}

(window as any).finishTest = () => {
    isSystemAction = true;
    window.location.href = `/admin/soal/daftar/${state.test.id}?topicId=preview_end`; // Note: test.id in stat was mocked to 0, let's fix it later. We can just use the literal topicId from server side. Wait, we can't do that easily inside client. Wait! Let's provide topicId safely.
};

// ─── MOBILE NAV TOGGLE ───
let navOpen = false;
function closeNavPanel() {
    if (!navOpen) return;
    document.getElementById("nav-panel")?.classList.add("translate-y-full");
    document.getElementById("nav-panel")?.classList.remove("translate-y-0");
    document.getElementById("nav-overlay")?.classList.add("hidden");
    navOpen = false;
}
(window as any).toggleNavPanel = () => {
    const panel = document.getElementById("nav-panel");
    const overlay = document.getElementById("nav-overlay");
    if (!panel) return;
    navOpen = !navOpen;
    if (navOpen) {
        panel.classList.remove("translate-y-full");
        panel.classList.add("translate-y-0");
        overlay?.classList.remove("hidden");
    } else {
        panel.classList.add("translate-y-full");
        panel.classList.remove("translate-y-0");
        overlay?.classList.add("hidden");
    }
};

// ─── BACKGROUND FETCH ───
async function bgFetch(url: string, payload: any) {
    console.log("Mock Save:", url, payload);
    const sync = document.getElementById("sync-status");
    if (sync) {
        sync.classList.remove("opacity-0");
        sync.classList.add("text-emerald-500");
        sync.innerHTML = `<i class="icon-refresh-cw w-3 h-3 animate-spin"></i> <span>Saving</span>`;
        setTimeout(() => {
            sync.innerHTML = `<i class="icon-check w-3 h-3"></i> <span>Preview</span>`;
            setTimeout(() => sync.classList.add("opacity-0"), 1000);
        }, 300);
    }
}
(window as any).bgFetch = bgFetch;

// ─── TIMER ───
function startTimer() {
    let secs = Number(state.test.durationMinutes) * 60;
    const display = document.getElementById("countdown-timer");
    const tick = () => {
        if (secs <= 0) {
            if (display) display.textContent = "HABIS";
            window.location.href = `/api/peserta/selesai?sessionId=${state.session.id}`;
            return;
        }
        const h = Math.floor(secs / 3600).toString().padStart(2, "0");
        const m = Math.floor((secs % 3600) / 60).toString().padStart(2, "0");
        const s = Math.floor(secs % 60).toString().padStart(2, "0");
        if (display) {
            display.textContent = `${h}:${m}:${s}`;
            display.classList.toggle("warning", secs < 300);
        }
        secs--;
    };
    setInterval(tick, 1000);
    tick();
}
</script>
