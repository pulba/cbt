---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { users, questions, tests, topics, testUsers } from '../../db/schema';
import { count } from 'drizzle-orm';

// Fetch stats
const [totalStudents] = await db.select({ value: count() }).from(users);
const [totalQuestions] = await db.select({ value: count() }).from(questions);
const [totalTests] = await db.select({ value: count() }).from(tests);
const [totalTopics] = await db.select({ value: count() }).from(topics);

const stats = [
    { label: 'Total Siswa', value: totalStudents.value, icon: 'users', color: 'bg-primary-500' },
    { label: 'Bank Soal', value: totalQuestions.value, icon: 'book-open', color: 'bg-emerald-500' },
    { label: 'Ujian Aktif', value: totalTests.value, icon: 'clipboard-check', color: 'bg-amber-500' },
    { label: 'Topik/Mapel', value: totalTopics.value, icon: 'layers', color: 'bg-violet-500' },
];

const user = Astro.locals.user;
const role = user?.role || 'admin';
---

<AdminLayout title="Dashboard">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
        {stats.map((stat) => (
            <div class="bg-white rounded-xl border border-surface-200 p-5 hover:shadow-lg hover:shadow-surface-200/50 transition-all duration-300">
                <div class="flex items-center justify-between mb-3">
                    <div class={`w-10 h-10 ${stat.color} rounded-lg flex items-center justify-center`}>
                        <i class={`icon-${stat.icon} w-5 h-5 text-white`}></i>
                    </div>
                </div>
                <p class="text-2xl font-bold text-surface-800">{stat.value}</p>
                <p class="text-xs text-surface-500 mt-1">{stat.label}</p>
            </div>
        ))}
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl border border-surface-200 p-6">
            <h3 class="text-sm font-semibold text-surface-700 mb-4">Menu Cepat</h3>
            <div class="grid grid-cols-2 gap-3">
                {role !== 'operator' && (
                    <>
                        <a href="/admin/soal" class="flex items-center gap-3 p-3 rounded-lg bg-surface-50 hover:bg-primary-50 hover:text-primary-700 transition-all text-sm text-surface-600 border border-transparent hover:border-primary-200">
                            <i class="icon-plus-circle w-4 h-4"></i>
                            Tambah Soal
                        </a>
                        <a href="/admin/ujian" class="flex items-center gap-3 p-3 rounded-lg bg-surface-50 hover:bg-primary-50 hover:text-primary-700 transition-all text-sm text-surface-600 border border-transparent hover:border-primary-200">
                            <i class="icon-file-plus w-4 h-4"></i>
                            Buat Ujian
                        </a>
                        <a href="/admin/peserta" class="flex items-center gap-3 p-3 rounded-lg bg-surface-50 hover:bg-primary-50 hover:text-primary-700 transition-all text-sm text-surface-600 border border-transparent hover:border-primary-200">
                            <i class="icon-user-plus w-4 h-4"></i>
                            Tambah Peserta
                        </a>
                    </>
                )}
                <a href="/admin/hasil" class="flex items-center gap-3 p-3 rounded-lg bg-surface-50 hover:bg-primary-50 hover:text-primary-700 transition-all text-sm text-surface-600 border border-transparent hover:border-primary-200">
                    <i class="icon-download w-4 h-4"></i>
                    Unduh Nilai
                </a>
                <a href="/admin/monitoring" class="flex items-center gap-3 p-3 rounded-lg bg-surface-50 hover:bg-primary-50 hover:text-primary-700 transition-all text-sm text-surface-600 border border-transparent hover:border-primary-200">
                    <i class="icon-activity w-4 h-4"></i>
                    Buka Monitoring
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-surface-200 p-6">
            <h3 class="text-sm font-semibold text-surface-700 mb-4">Informasi Sistem</h3>
            <div class="space-y-3">
                <div class="flex items-center justify-between text-sm">
                    <span class="text-surface-500">Platform</span>
                    <span class="font-medium text-surface-700">Astro + Turso Edge</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-surface-500">Database</span>
                    <span class="font-medium text-success">● Connected</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-surface-500">Hosting</span>
                    <span class="font-medium text-surface-700">Cloudflare Edge</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                    <span class="text-surface-500">Versi</span>
                    <span class="font-medium text-surface-700">2.0.0</span>
                </div>
            </div>
        </div>
    </div>
</AdminLayout>
