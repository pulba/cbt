                    </div>
                    
                    <!-- Rows container -->
                    <div class="flex flex-col">
                        ${rowsHtml}
                    </div>
                </div>`;
            } else {
                html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-3">`;
                q.answers.forEach((ans, idx) => {
                    const ch = charMap[idx] ?? String(idx + 1);
                    const sel = ans.isSelected;
                    const type = q.qType === 1 ? "radio" : "checkbox";
