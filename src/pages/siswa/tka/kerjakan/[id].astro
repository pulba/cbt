                                <input type="radio" name="bs${bq.tqId}" onchange="saveAnswer(${bq.tqId}, ${opt2?.ansId})" ${opt2?.isSelected ? 'checked' : ''} class="w-5 h-5 sm:w-6 sm:h-6 accent-rose-600 cursor-pointer">
