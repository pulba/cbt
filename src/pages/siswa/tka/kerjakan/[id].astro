                    const activeClasses = isCheckbox 
                        ? "border-emerald-500 shadow-md shadow-emerald-100" 
                        : "border-primary-500 shadow-md shadow-primary-100";
                    const bgAccent = isCheckbox ? "bg-emerald-600 border-emerald-500" : "bg-primary-600 border-primary-500";
                    const contentAccent = isCheckbox ? "bg-emerald-50/50" : "bg-primary-50/50";
                    const onChange = isCheckbox ? `toggleAnswer(${q.tqId}, ${ans.ansId})` : `saveAnswer(${q.tqId}, ${ans.ansId})`;
                    
                    html += `
                    <label class="opt-label flex items-stretch rounded-xl border-2 cursor-pointer overflow-hidden
                        ${sel ? activeClasses : "border-slate-200 hover:border-slate-300 hover:shadow-sm"}">
                        <!-- Letter -->
                        <div class="w-11 flex items-center justify-center shrink-0 border-r-2
                            ${sel ? bgAccent : "bg-slate-50 border-slate-200"}
                            transition-colors">
                            <span class="text-xs font-black ${sel ? "text-white" : "text-slate-400"}">${ch}</span>
                        </div>
                        <!-- Content -->
                        <div class="flex items-start gap-3 flex-1 px-4 py-3 ${sel ? contentAccent : "bg-white"}">
                            <input
                                type="${type}"
                                ${q.qType === 1 ? `name="q${q.tqId}"` : ""}
                                value="${ans.ansId}"
                                ${sel ? "checked" : ""}
                                onchange="${onChange}"
                                class="mt-0.5 w-4 h-4 flex-shrink-0 accent-slate-900">
                            <div class="flex-1 text-slate-800 text-sm leading-relaxed">${ans.ansText}</div>
                        </div>
                    </label>`;
                });
                html += `</div>`;
            }
        } else if (q.qType === 2 || q.qType === 3) {
            html = `
            <div class="space-y-3">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider">Jawaban Anda:</label>
                <textarea
                    id="essay-input"
                    class="w-full p-4 border-2 border-slate-200 rounded-xl text-sm text-slate-800 font-medium focus:border-primary-500 focus:outline-none resize-none bg-slate-50 transition min-h-[160px]"
                    placeholder="Ketik jawaban Anda di sini..."
                    onblur="saveTextAnswer(${q.tqId}, this.value)">${q.answerText || ""}</textarea>
                <div class="text-[10px] text-slate-400 italic flex items-center gap-1">
                    <i class="icon-info w-3 h-3"></i> Jawaban otomatis tersimpan saat Anda berpindah soal atau klik di luar area input.
                </div>
            </div>`;
        } else if (q.qType === 4) {
            let saved: any = {}; try { saved = JSON.parse(q.answerText || '{}'); } catch(e){}
            const left = q.answers.map((ans: any) => {
                const isSel = _matchFocus && _matchFocus.type === 'left' && _matchFocus.id == ans.ansId;
                const isSaved = saved[ans.ansId];
                return `
                <div onclick="matchClick('left', '${ans.ansId}', ${q.tqId})" class="flex items-center gap-3 py-2 cursor-pointer group">
                    <div class="flex-1 bg-white border-2 ${isSel ? 'border-primary-500 ring-4 ring-primary-50 shadow-lg translate-x-1' : (isSaved ? 'border-emerald-100 bg-emerald-50/30' : 'border-slate-100 group-hover:border-primary-200')} rounded-2xl px-5 py-4 text-sm font-bold text-slate-700 shadow-sm transition-all duration-200">${ans.ansText}</div>
                    <div class="left-dot w-5 h-5 rounded-full border-4 border-white shadow-sm ring-2 transition-all duration-300 ${isSel ? 'ring-primary-500 bg-primary-500 scale-125' : (isSaved ? 'ring-emerald-500 bg-emerald-500' : 'ring-slate-200 bg-slate-100 group-hover:ring-primary-300 group-hover:bg-primary-100')}" data-left-id="${ans.ansId}"></div>
                </div>`;
            }).join('');
            
            const right = (q.rightOptions || []).map((opt: string) => {
                const optEsc = opt.replace(/'/g, "\\'");
                const isSel = _matchFocus && _matchFocus.type === 'right' && _matchFocus.id === opt;
                const isSaved = Object.values(saved).includes(opt);
                return `
                <div onclick="matchClick('right', '${optEsc}', ${q.tqId})" class="flex items-center gap-3 py-2 cursor-pointer group">
                    <div class="right-dot w-5 h-5 rounded-full border-4 border-white shadow-sm ring-2 transition-all duration-300 ${isSel ? 'ring-primary-500 bg-primary-500 scale-125' : (isSaved ? 'ring-emerald-500 bg-emerald-500' : 'ring-slate-200 bg-slate-100 group-hover:ring-primary-300 group-hover:bg-primary-100')}" data-right-val="${opt.replace(/"/g, '&quot;')}"></div>
                    <div class="flex-1 bg-white border-2 ${isSel ? 'border-primary-500 ring-4 ring-primary-50 shadow-lg -translate-x-1' : (isSaved ? 'border-emerald-100 bg-emerald-50/30' : 'border-slate-100 group-hover:border-primary-200')} rounded-2xl px-5 py-4 text-sm font-bold text-slate-700 text-right shadow-sm transition-all duration-200">${opt}</div>
                </div>`;
            }).join('');

            html = `
            <div class="mb-4">
                <div class="flex items-center gap-2 px-4 py-2 bg-primary-50 border border-primary-100 rounded-xl mb-6">
                    <i class="icon-info w-4 h-4 text-primary-500"></i>
                    <p class="text-[11px] font-medium text-primary-700 leading-tight">
                        <span class="font-bold">Cara Menjawab:</span> Klik kotak di kolom kiri, lalu klik kotak pasangannya di kolom kanan. Klik kembali pada kotak yang sudah terhubung untuk membatalkan.
