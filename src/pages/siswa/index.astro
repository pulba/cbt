---
import "../../styles/global.css";

// If student is already logged in, redirect to dashboard
const token = Astro.cookies.get("cbt_student_session")?.value;
if (token) {
	const { verifyToken } = await import("../../lib/auth");
	const user = await verifyToken(token);
	if (user && user.role === "student") {
		return Astro.redirect("/siswa/ujian");
	}
}
---

<!doctype html>
<html lang="id" class="h-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>Login Ujian | SAS CBT</title>
	</head>
	<body
		class="h-full bg-gradient-to-br from-primary-800 via-primary-700 to-primary-900 flex items-center justify-center p-4"
	>
		<div class="w-full max-w-sm">
			<!-- Card -->
			<div class="bg-white rounded-2xl shadow-2xl p-8">
				<!-- Header -->
				<div class="text-center mb-8">
					<div
						class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-700 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-primary-500/30"
					>
						<span class="text-white font-bold text-xl">CBT</span>
					</div>
					<h1 class="text-lg font-bold text-surface-800">
						Ujian Online
					</h1>
					<p class="text-xs text-surface-500 mt-1">
						Masukkan Username dan Password dari Kartu Ujian
					</p>
				</div>

				<!-- Error Alert -->
				<div
					id="error-alert"
					class="hidden mb-4 p-3 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm"
				>
				</div>

				<!-- Form -->
				<form id="login-form" class="space-y-4">
					<div>
						<label
							class="block text-xs font-medium text-surface-600 mb-1.5"
							>Username / No. Peserta</label
						>
						<input
							type="text"
							name="username"
							id="username"
							required
							autocomplete="username"
							class="w-full px-4 py-2.5 rounded-lg bg-surface-50 border border-surface-200 text-surface-800 placeholder:text-surface-400 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition"
							placeholder="Masukkan username"
						/>
					</div>
					<div>
						<label
							class="block text-xs font-medium text-surface-600 mb-1.5"
							>Password</label
						>
						<input
							type="password"
							name="password"
							id="password"
							required
							autocomplete="current-password"
							class="w-full px-4 py-2.5 rounded-lg bg-surface-50 border border-surface-200 text-surface-800 placeholder:text-surface-400 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/30 focus:border-primary-500 transition"
							placeholder="Masukkan password"
						/>
					</div>
					<button
						type="submit"
						id="submit-btn"
						class="w-full py-3 rounded-lg bg-primary-600 hover:bg-primary-500 text-white text-sm font-semibold transition-all duration-200 shadow-lg shadow-primary-600/25 hover:shadow-primary-500/40 cursor-pointer"
					>
						Mulai Ujian
					</button>
				</form>
			</div>

			<!-- Footer -->
			<p class="text-center mt-6 text-xs text-white/50">
				Login sebagai Admin? <a
					href="/"
					class="text-white/80 hover:text-white underline"
					>Klik di sini</a
				>
			</p>
		</div>

		<script>
			const form = document.getElementById(
				"login-form",
			) as HTMLFormElement;
			const errorAlert = document.getElementById(
				"error-alert",
			) as HTMLDivElement;
			const submitBtn = document.getElementById(
				"submit-btn",
			) as HTMLButtonElement;

			form.addEventListener("submit", async (e) => {
				e.preventDefault();
				errorAlert.classList.add("hidden");
				submitBtn.textContent = "Memproses...";
				submitBtn.disabled = true;

				const username = (
					document.getElementById("username") as HTMLInputElement
				).value;
				const password = (
					document.getElementById("password") as HTMLInputElement
				).value;

				try {
					const res = await fetch("/api/auth/login", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							username,
							password,
							type: "student",
						}),
					});

					const data = await res.json();

					if (data.status === 1) {
						window.location.href = "/siswa/ujian";
					} else {
						errorAlert.textContent = data.error || "Login gagal";
						errorAlert.classList.remove("hidden");
					}
				} catch {
					errorAlert.textContent = "Terjadi kesalahan jaringan";
					errorAlert.classList.remove("hidden");
				} finally {
					submitBtn.textContent = "Mulai Ujian";
					submitBtn.disabled = false;
				}
			});
		</script>
	</body>
</html>
