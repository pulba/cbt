---
import "../styles/global.css";
import { verifyToken } from '../lib/auth';
import { db } from '../db';
import { configs } from '../db/schema';

import { sql } from 'drizzle-orm';

const allConfigs = await db.select({ 
    key: configs.key, 
    value: sql<string>`CASE WHEN ${configs.key} = 'school_logo' THEN '1' ELSE ${configs.value} END` 
}).from(configs).all();
const getConfig = (key: string) => allConfigs.find((c: any) => c.key === key)?.value || "";
const hasLogo = !!getConfig("school_logo");
const schoolName = getConfig("school_name") || "SAS CBT";

// Hanya redirect ke admin jika session admin valid
const adminToken = Astro.cookies.get('cbt_admin_session')?.value;
const secret = (Astro.locals as any).runtime?.env?.JWT_SECRET;

if (adminToken) {
const u = await verifyToken(adminToken, secret);
if (u && u.role !== 'student') {
return Astro.redirect('/admin');
}
}
// Halaman ini adalah Admin Login - tidak perlu redirect ke siswa
---

<!doctype html>
<html lang="id" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" href={hasLogo ? "/api/public/logo" : "/favicon.svg"} />
        <title>Login Admin | {schoolName}</title>
    </head>
    <body
        class="h-full bg-gradient-to-br from-surface-900 via-surface-800 to-primary-900 flex items-center justify-center p-4"
    >
        <div class="w-full max-w-md">
            <!-- Card -->
            <div
                class="bg-white/10 backdrop-blur-xl rounded-2xl border border-white/10 shadow-2xl p-8"
            >
                <!-- Header -->
                <div class="text-center mb-8">
                    {hasLogo ? (
                        <img src="/api/public/logo" alt="Logo Sekolah" class="w-16 h-16 object-contain mx-auto mb-4 drop-shadow-md bg-white/10 rounded-xl p-2" />
                    ) : (
                        <div class="w-14 h-14 bg-primary-500 rounded-xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-primary-500/30">
                            <span class="text-white font-bold text-lg">CBT</span>
                        </div>
                    )}
                    <h1 class="text-xl font-bold text-white">CBT Admin</h1>
                    <p class="text-sm text-white/50 mt-1">
                        {schoolName}
                    </p>
                </div>

                <!-- Error Alert -->
                <div
                    id="error-alert"
                    class="hidden mb-4 p-3 rounded-lg bg-danger/10 border border-danger/20 text-danger text-sm"
                >
                </div>

                <!-- Form -->
                <form id="login-form" class="space-y-4">
                    <div>
                        <label
                            class="block text-xs font-medium text-white/60 mb-1.5"
                            >Username</label
                        >
                        <input
                            type="text"
                            name="username"
                            id="username"
                            required
                            autocomplete="username"
                            class="w-full px-4 py-2.5 rounded-lg bg-white/8 border border-white/10 text-white placeholder:text-white/30 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition"
                            placeholder="Masukkan username"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-xs font-medium text-white/60 mb-1.5"
                            >Password</label
                        >
                        <input
                            type="password"
                            name="password"
                            id="password"
                            required
                            autocomplete="current-password"
                            class="w-full px-4 py-2.5 rounded-lg bg-white/8 border border-white/10 text-white placeholder:text-white/30 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition"
                            placeholder="Masukkan password"
                        />
                    </div>
                    <button
                        type="submit"
                        id="submit-btn"
                        class="w-full py-2.5 rounded-lg bg-primary-600 hover:bg-primary-500 text-white text-sm font-semibold transition-all duration-200 shadow-lg shadow-primary-600/25 hover:shadow-primary-500/40 cursor-pointer"
                    >
                        Masuk
                    </button>
                </form>
            </div>

            <!-- Footer Link -->
            <p class="text-center mt-6 text-xs text-white/30">
                Login sebagai Siswa? <a
                    href="/siswa"
                    class="text-primary-400 hover:text-primary-300 underline"
                    >Klik di sini</a
                >
            </p>
        </div>

        <script>
            const form = document.getElementById(
                "login-form",
            ) as HTMLFormElement;
            const errorAlert = document.getElementById(
                "error-alert",
            ) as HTMLDivElement;
            const submitBtn = document.getElementById(
                "submit-btn",
            ) as HTMLButtonElement;

            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                errorAlert.classList.add("hidden");
                submitBtn.textContent = "Memproses...";
                submitBtn.disabled = true;

                const username = (
                    document.getElementById("username") as HTMLInputElement
                ).value;
                const password = (
                    document.getElementById("password") as HTMLInputElement
                ).value;

                try {
                    const res = await fetch("/api/auth/login", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            username,
                            password,
                            type: "admin",
                        }),
                    });

                    const data = await res.json();

                    if (data.status === 1) {
                        window.location.href = "/admin";
                    } else {
                        errorAlert.textContent = data.error || "Login gagal";
                        errorAlert.classList.remove("hidden");
                    }
                } catch {
                    errorAlert.textContent = "Terjadi kesalahan jaringan";
                    errorAlert.classList.remove("hidden");
                } finally {
                    submitBtn.textContent = "Masuk";
                    submitBtn.disabled = false;
                }
            });
        </script>
    </body>
</html>
