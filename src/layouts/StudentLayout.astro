---
import "../styles/global.css";
import "lucide-static/font/lucide.css";
import { db } from "../db";
import { configs } from "../db/schema";

interface Props {
    title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;

const currentPath = Astro.url.pathname;
const isUjianCBT = currentPath.includes("/siswa/kerjakan");

// Fetch system configs
import { sql } from 'drizzle-orm';
const allConfigs = await db.select({ 
    key: configs.key, 
    value: sql<string>`CASE WHEN ${configs.key} = 'school_logo' THEN '1' ELSE ${configs.value} END` 
}).from(configs).all();
const getConfig = (key: string) => allConfigs.find((c: any) => c.key === key)?.value || "";
const cbtNama = getConfig("cbt_nama") || "Computer Based Test";
const schoolName = getConfig("school_name") || "CBT App";
const hasLogo = !!getConfig("school_logo");
---

<!doctype html>
<html lang="id" class="h-full bg-surface-50">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Amiri:wght@400;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" href={hasLogo ? "/api/public/logo" : "/favicon.svg"} />
        <title>{title} | {cbtNama}</title>
        
        <!-- MathJax Configuration for OMML/LaTeX rendering -->
        <script is:inline>
            window.MathJax = {
                tex: {
                    inlineMath: [['\\(', '\\)'], ['$', '$']],
                    displayMath: [['\\[', '\\]'], ['$$', '$$']],
                    processEscapes: true
                },
                options: {
                    ignoreHtmlClass: 'tex2jax_ignore',
                    processHtmlClass: 'tex2jax_process'
                }
            };
        </script>
        <script is:inline id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    </head>
    <body class="h-full text-surface-800 flex flex-col font-sans">
        {
            !isUjianCBT && (
                <header class="bg-primary-700 text-white shadow-md sticky top-0 z-40">
                    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <img 
                                src={hasLogo ? "/api/public/logo" : "/favicon.svg"} 
                                alt="Logo" 
                                class="w-8 h-8 rounded object-contain bg-white/20 p-1" 
                            />
                            <span class="font-semibold tracking-wide hidden sm:block">
                                {cbtNama}
                            </span>
                        </div>

                        <div class="flex items-center gap-4">
                            <div class="text-right hidden sm:block">
                                <p class="text-sm font-medium">
                                    {user?.username}
                                </p>
                                <p class="text-xs text-white/70">
                                    Peserta Ujian
                                </p>
                            </div>
                            <div class="w-9 h-9 rounded-full bg-white text-primary-700 flex items-center justify-center font-bold border-2 border-primary-400">
                                {user?.username?.charAt(0).toUpperCase() || "S"}
                            </div>
                            <a
                                href="/api/auth/logout"
                                class="ml-2 text-white/50 hover:text-white transition"
                                title="Keluar"
                            >
                                <i class="icon-log-out w-5 h-5" />
                            </a>
                        </div>
                    </div>
                </header>
            )
        }

        <!-- Main Content Area centered constraint -->
        <main
            class={`flex-1 ${!isUjianCBT ? "max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8" : ""}`}
        >
            <slot />
        </main>

        {
            !isUjianCBT && (
                <footer class="bg-white border-t border-surface-200 py-6 mt-auto">
                    <div class="max-w-5xl mx-auto px-4 text-center text-sm text-surface-500">
                        &copy; {new Date().getFullYear()} {schoolName}. All rights
                        reserved.
                    </div>
                </footer>
            )
        }
    </body>
</html>
