---
import "../styles/global.css";
import "lucide-static/font/lucide.css";
import { db } from "../db";
import { configs } from "../db/schema";

interface Props {
    title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;

// Fetch system configs
const allConfigs = await db.select().from(configs).all();
const getConfig = (key: string) => allConfigs.find(c => c.key === key)?.value || "";
const cbtNama = getConfig("cbt_nama") || "SAS CBT";
const schoolName = getConfig("school_name") || "Sekolah";

const allMenuItems = [
    { label: "Dashboard", href: "/admin", icon: "grid", roles: ['admin', 'guru', 'operator'] },
    { label: "Bank Soal", href: "/admin/soal", icon: "book", roles: ['admin', 'guru'] },
    { label: "Peserta", href: "/admin/peserta", icon: "users", roles: ['admin', 'guru'] },
    { label: "Ujian", href: "/admin/ujian", icon: "clipboard", roles: ['admin', 'guru'] },
    { label: "Hasil & Laporan", href: "/admin/hasil", icon: "bar-chart", roles: ['admin', 'guru', 'operator'] },
    { label: "Pengaturan", href: "/admin/pengaturan", icon: "settings", roles: ['admin'] },
];

const role = user?.role || 'admin';
const menuItems = allMenuItems.filter(item => item.roles.includes(role));

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="id" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <title>{title} | {cbtNama} Admin</title>
    </head>
    <body class="h-full bg-surface-50 text-surface-800">
        <div class="flex h-screen overflow-hidden">
            <!-- Sidebar -->
            <aside
                id="admin-sidebar"
                class="fixed inset-y-0 left-0 z-50 w-64 bg-surface-900 text-white shadow-xl transform -translate-x-full lg:translate-x-0 lg:static lg:inset-auto lg:flex lg:flex-col transition-transform duration-300 ease-in-out"
            >
                <!-- Brand -->
                <div
                    class="flex items-center gap-3 px-6 py-5 border-b border-white/10"
                >
                    <div
                        class="w-9 h-9 rounded-lg bg-primary-500 flex items-center justify-center font-bold text-sm shrink-0"
                    >
                        CBT
                    </div>
                    <div class="min-w-0">
                        <h1 class="text-sm font-semibold tracking-wide truncate">
                            {schoolName}
                        </h1>
                        <p class="text-[11px] text-white/50">Admin Panel</p>
                    </div>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
                    {
                        menuItems.map((item) => {
                            const isActive =
                                currentPath === item.href ||
                                (item.href !== "/admin" &&
                                    currentPath.startsWith(item.href));
                            return (
                                <a
                                    href={item.href}
                                    class:list={[
                                        "flex items-center gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium transition-all duration-150",
                                        isActive
                                            ? "bg-primary-600 text-white shadow-md shadow-primary-600/30"
                                            : "text-white/60 hover:text-white hover:bg-white/8",
                                    ]}
                                >
                                    <i class={`icon-${item.icon} w-4 h-4`} />
                                    {item.label}
                                </a>
                            );
                        })
                    }
                </nav>

                <!-- User Info -->
                <div class="px-4 py-4 border-t border-white/10">
                    <div class="flex items-center gap-3">
                        <div
                            class="w-8 h-8 rounded-full bg-primary-400/20 flex items-center justify-center text-primary-300 text-xs font-bold"
                        >
                            {user?.username?.charAt(0).toUpperCase() || "A"}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-medium truncate">
                                {user?.username || "Admin"}
                            </p>
                            <p class="text-[10px] text-white/40 capitalize">
                                {user?.role || "admin"}
                            </p>
                        </div>
                        <a
                            href="/api/auth/logout"
                            class="text-white/30 hover:text-white/70 transition"
                        >
                            <i class="icon-log-out w-4 h-4"></i>
                        </a>
                    </div>
                </div>
                <p
                    class="text-[10px] font-bold text-surface-400 uppercase tracking-widest mt-6 mb-2 pl-3"
                >
                    Aktivitas
                </p>
                <div class="space-y-1">
                    <a
                        href="/admin/monitoring"
                        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-surface-600 hover:text-white hover:bg-white/8 transition"
                    >
                        <i class="icon-activity w-5 h-5 text-surface-400"></i>
                         Live Monitoring
                    </a>
                    <a
                        href="/admin/peserta/reset"
                        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-surface-600 hover:text-white hover:bg-white/8 transition"
                    >
                        <i class="icon-key w-5 h-5 text-surface-400"></i>
                         Status Login
                    </a>
                </div>
            </aside>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Top Bar -->
                <header
                    class="h-14 bg-white border-b border-surface-200 flex items-center justify-between px-6 shrink-0"
                >
                    <div class="flex items-center gap-3">
                        <button
                            id="mobile-menu-btn"
                            class="lg:hidden p-1.5 rounded-md hover:bg-surface-100"
                        >
                            <i class="icon-menu w-5 h-5"></i>
                        </button>
                        <h2 class="text-sm font-semibold text-surface-700">
                            {title}
                        </h2>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-surface-500 hidden sm:block"
                            >{
                                new Date().toLocaleDateString("id-ID", {
                                    weekday: "long",
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })
                            }</span
                        >
                    </div>
                </header>

                <!-- Page Content -->
                <main class="flex-1 overflow-y-auto p-6">
                    <slot />
                </main>
            </div>
        </div>

        <!-- Sidebar Overlay (Mobile) -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

        <script>
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const adminSidebar = document.getElementById('admin-sidebar');
            const sidebarOverlay = document.getElementById('sidebar-overlay');

            if (mobileMenuBtn && adminSidebar && sidebarOverlay) {
                const toggleSidebar = () => {
                    const isHidden = adminSidebar.classList.contains('-translate-x-full');
                    if (isHidden) {
                        adminSidebar.classList.remove('-translate-x-full');
                        sidebarOverlay.classList.remove('hidden');
                        document.body.style.overflow = 'hidden';
                    } else {
                        adminSidebar.classList.add('-translate-x-full');
                        sidebarOverlay.classList.add('hidden');
                        document.body.style.overflow = '';
                    }
                };

                mobileMenuBtn.addEventListener('click', toggleSidebar);
                sidebarOverlay.addEventListener('click', toggleSidebar);
            }
        </script>
    </body>
</html>
